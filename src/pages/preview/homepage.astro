---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { previewFetch } from '../../lib/sanity';

const secret = Astro.url.searchParams.get('secret');
if (secret !== import.meta.env.SANITY_PREVIEW_SECRET) {
  return new Response('Unauthorized', { status: 401 });
}

const cms = await previewFetch(
  `*[_type == "homepage"][0]{
    heroHeadline,
    heroSubtitle,
    "heroImage": heroImage.asset->url,
    heroCta,
    heroSecondaryCta,
    quoteText,
    quoteAttribution,
    pillarsLabel,
    pillarsHeading,
    pillarsDescription,
    pillars[]{
      title,
      description,
      "image": image.asset->url,
      imageAlt,
      linkUrl,
      linkText
    },
    videoUrl,
    videoCaption
  }`
);

const base = import.meta.env.BASE_URL;
const heroHeadline = cms?.heroHeadline || 'Inspiring Canadian Catholic Culture';
const heroSubtitle = cms?.heroSubtitle || 'Forming leaders. Teaching the tradition. Publishing research.';
const heroImage = cms?.heroImage || (base + 'images/art/disputation-holy-sacrament.jpg');
const primaryCta = cms?.heroCta || { text: 'Subscribe to the Magnalia Letter', url: '/magnalia/letter/' };
const secondaryCta = cms?.heroSecondaryCta?.text ? cms.heroSecondaryCta : { text: 'Explore Our Programs', url: '/programs/' };
const videoId = cms?.videoUrl ? (cms.videoUrl.match(/(?:v=|youtu\.be\/)([^&]+)/) || [])[1] : 'Lhzqr8tMYsI';
---

<BaseLayout title="Preview: Homepage">
  <div class="preview-banner">
    PREVIEW MODE — Homepage draft. Click reload to see latest changes.
  </div>

  <section class="hero hero--home" style={'background-image: url(' + heroImage + ')'}>
    <div class="hero__overlay"></div>
    <div class="hero__content container">
      <h1 class="hero__headline display">{heroHeadline}</h1>
      <p class="hero__tagline">Fides ✠ Ratio ✠ Cultura</p>
      <p class="hero__subtitle">{heroSubtitle}</p>
      <div class="hero__ctas">
        <a href={primaryCta.url || '#'} class="btn btn--subscribe">{primaryCta.text || 'Subscribe'}</a>
        {secondaryCta.text && (
          <a href={secondaryCta.url || '#'} class="btn btn--ghost">{secondaryCta.text}</a>
        )}
      </div>
    </div>
  </section>

  {videoId && (
    <section class="section section--tight">
      <div class="container" style="max-width:720px;text-align:center;">
        <div style="position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:4px;">
          <iframe
            src={'https://www.youtube.com/embed/' + videoId}
            style="position:absolute;top:0;left:0;width:100%;height:100%;border:0;"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
        {cms?.videoCaption && <p style="font-size:0.88rem;color:var(--color-gray);margin-top:12px;">{cms.videoCaption}</p>}
      </div>
    </section>
  )}

  <section class="section section--tight">
    <div class="container" style="text-align:center;padding:32px 20px;max-width:720px;">
      {cms?.quoteText && (
        <blockquote style="font-style:italic;font-size:1.15rem;color:var(--color-navy, #0e3352);line-height:1.7;margin:0;">
          "{cms.quoteText}"
        </blockquote>
      )}
      {cms?.quoteAttribution && (
        <p style="color:#b89a47;font-weight:600;margin-top:12px;font-size:0.9rem;">{cms.quoteAttribution}</p>
      )}
    </div>
  </section>

  {cms?.pillars && cms.pillars.length > 0 && (
    <section class="section">
      <div class="container" style="text-align:center;">
        <p style="color:#b89a47;font-weight:600;font-size:0.85rem;letter-spacing:0.1em;text-transform:uppercase;">{cms.pillarsLabel || 'What We Do'}</p>
        <h2 style="color:var(--color-navy, #0e3352);margin:8px 0 16px;">{cms.pillarsHeading || 'Formation, Courses, Publications'}</h2>
        {cms.pillarsDescription && <p style="max-width:640px;margin:0 auto 32px;color:#555;line-height:1.7;">{cms.pillarsDescription}</p>}
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:24px;">
          {cms.pillars.map((p: any) => (
            <div style="text-align:center;">
              {p.image && <img src={p.image} alt={p.imageAlt || p.title} style="width:100%;height:200px;object-fit:cover;border-radius:4px;" />}
              <h3 style="margin:12px 0 8px;color:var(--color-navy, #0e3352);">{p.title}</h3>
              <p style="color:#555;font-size:0.92rem;line-height:1.6;">{p.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container" style="text-align:center;padding:24px 20px;">
      <p style="font-style:italic;color:#999;">Events, endorsements, library, and giving sections render from live data and are not previewed here.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .preview-banner {
    background: #b89a47;
    color: #0e3352;
    text-align: center;
    padding: 10px 16px;
    font-family: system-ui, sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    position: sticky;
    top: 0;
    z-index: 9999;
  }
  .hero--home {
    min-height: 520px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-size: cover;
    background-position: center;
    position: relative;
    text-align: center;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(14,51,82,0.7), rgba(14,51,82,0.85));
  }
  .hero__content { position: relative; z-index: 1; }
  .hero__headline { color: #f5efe5; font-size: 2.8rem; line-height: 1.15; margin-bottom: 8px; }
  .hero__tagline { color: #b89a47; font-size: 1rem; letter-spacing: 0.15em; margin-bottom: 12px; }
  .hero__subtitle { color: rgba(245,239,229,0.8); font-size: 1.05rem; max-width: 600px; margin: 0 auto 24px; line-height: 1.7; }
  .hero__ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn { display: inline-block; padding: 12px 28px; border-radius: 3px; font-weight: 600; text-decoration: none; font-size: 0.92rem; }
  .btn--subscribe { background: #b89a47; color: #0e3352; }
  .btn--ghost { border: 1px solid rgba(245,239,229,0.4); color: #f5efe5; background: transparent; }
  @media (max-width: 768px) {
    .hero--home { min-height: 400px; }
    .hero__headline { font-size: 2rem; }
  }
</style>
