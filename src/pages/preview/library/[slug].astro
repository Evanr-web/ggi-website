---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import { previewFetch } from '../../../lib/sanity';
import { renderPortableText } from '../../../lib/portable-text';

const { slug } = Astro.params;
const secret = Astro.url.searchParams.get('secret');

if (secret !== import.meta.env.SANITY_PREVIEW_SECRET) {
  return new Response('Unauthorized', { status: 401 });
}

const article = await previewFetch(
  `*[_type == "libraryItem" && slug.current == $slug][0]{
    title,
    category,
    publishDate,
    excerpt,
    "image": image.asset->url,
    "authorName": coalesce(author->name, "Gregory the Great Institute"),
    "authorPhoto": author->photo.asset->url,
    body[]{
      ...,
      _type == "image" => { "url": asset->url, "alt": alt }
    }
  }`,
  { slug }
);

if (!article) {
  return new Response('Article not found', { status: 404 });
}

const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const d = article.publishDate ? new Date(article.publishDate) : null;
const dateStr = d ? months[d.getMonth()] + ' ' + d.getDate() + ', ' + d.getFullYear() : 'Draft';
const pageTitle = 'Preview: ' + (article.title || 'Untitled');
const articleTitle = article.title || 'Untitled';
const articleCategory = article.category || 'Draft';
const base = import.meta.env.BASE_URL;
const authorImg = article.authorPhoto || (base + 'images/branding/ggi-seal.png');
const isDefaultImg = !article.authorPhoto;
const bodyHtml = renderPortableText(article.body);
const hasBody = bodyHtml.length > 0;
---

<BaseLayout title={pageTitle}>
  <div class="preview-banner">
    PREVIEW MODE — This is a draft. Click reload to see latest changes.
  </div>

  <article class="article">
    {article.image && (
      <div class="article__hero">
        <img src={article.image} alt={articleTitle} class="article__hero-img art-filter" />
      </div>
    )}
    <div class="article__container container">
      <div class="article__meta-bar">
        <span class="article__category">{articleCategory}</span>
      </div>
      <h1 class="article__title">{articleTitle}</h1>
      <div class="article__author-row">
        <img
          src={authorImg}
          alt={article.authorName}
          class={isDefaultImg ? 'article__author-img article__author-img--seal' : 'article__author-img'}
        />
        <div>
          <p class="article__author-name">{article.authorName}</p>
          <p class="article__author-meta">{dateStr}</p>
        </div>
      </div>
      {hasBody ? (
        <div class="article__body article__body--illuminated" set:html={bodyHtml} />
      ) : (
        <div class="article__body">
          {article.excerpt && <p>{article.excerpt}</p>}
          <p class="preview-placeholder">Start writing in the editor to see your content here.</p>
        </div>
      )}
      <div class="article__footer">
        <a href={base + 'library/'} class="back-link">Back to Library</a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .preview-banner {
    background: #b89a47;
    color: #0e3352;
    text-align: center;
    padding: 10px 16px;
    font-family: system-ui, sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    position: sticky;
    top: 0;
    z-index: 9999;
  }
  .preview-placeholder {
    font-style: italic;
    color: #999;
    margin-top: 24px;
  }
  .article__hero { width: 100%; height: 300px; overflow: hidden; }
  .article__hero-img { width: 100%; height: 100%; object-fit: cover; }
  .article__container { max-width: 680px; padding-top: 32px; padding-bottom: 48px; }
  .article__meta-bar { display: flex; gap: 16px; align-items: center; margin-bottom: 12px; }
  .article__category { font-family: var(--font-ui); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-gold); }
  .article__title { font-family: var(--font-display); font-size: 2rem; color: var(--color-navy); line-height: 1.2; margin-bottom: 16px; }
  .article__author-row { display: flex; align-items: center; gap: 12px; margin-bottom: 32px; padding-bottom: 24px; border-bottom: 1px solid rgba(90,90,110,0.1); }
  .article__author-img { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; flex-shrink: 0; }
  .article__author-img--seal { object-fit: contain; background: var(--color-linen); padding: 4px; }
  .article__author-name { font-family: var(--font-display); font-size: 0.95rem; font-weight: 600; color: var(--color-navy); line-height: 1.2; }
  .article__author-meta { font-family: var(--font-ui); font-size: 0.8rem; color: var(--color-gray); }
  .article__body :global(p) { font-family: var(--font-body); font-size: 1.05rem; line-height: 1.85; color: var(--color-gray); margin-bottom: 16px; }
  .article__body--illuminated :global(p:first-child)::first-letter {
    font-family: 'Goudy Initialen', var(--font-display);
    font-size: 3.8em; float: left; line-height: 0.75; padding-right: 8px; padding-top: 4px;
    color: var(--color-crimson); font-weight: normal; font-style: normal;
  }
  .article__body :global(h2) { font-family: var(--font-display); font-size: 1.3rem; color: var(--color-navy); margin-top: 32px; margin-bottom: 12px; }
  .article__body :global(blockquote) { border-left: 3px solid var(--color-gold); padding-left: 20px; margin: 24px 0; font-style: italic; color: var(--color-navy); }
  .article__footer { margin-top: 24px; padding-top: 24px; border-top: 1px solid rgba(90,90,110,0.1); }
  .back-link { font-family: var(--font-ui); font-size: 0.9rem; color: var(--color-gold); text-decoration: none; font-weight: 500; }
  .back-link:hover { color: var(--color-crimson); }
  @media (max-width: 768px) {
    .article__hero { height: 200px; }
    .article__title { font-size: 1.6rem; }
  }
</style>
