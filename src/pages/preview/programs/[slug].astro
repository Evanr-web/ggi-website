---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import { previewFetch } from '../../../lib/sanity';
import { renderPortableText } from '../../../lib/portable-text';

const { slug } = Astro.params;
const secret = Astro.url.searchParams.get('secret');

if (secret !== import.meta.env.SANITY_PREVIEW_SECRET) {
  return new Response('Unauthorized', { status: 401 });
}

const program = await previewFetch(
  `*[_type == "program" && slug.current == $slug][0]{
    title,
    template,
    tagline,
    description,
    "headerImage": headerImage.asset->url,
    body[]{
      ...,
      _type == "image" => { "url": asset->url, "alt": alt }
    }
  }`,
  { slug }
);

if (!program) {
  return new Response('Program not found', { status: 404 });
}

const bodyHtml = renderPortableText(program.body);
const hasBody = bodyHtml.length > 0;
const pageTitle = 'Preview: ' + (program.title || 'Untitled Program');
const programTitle = program.title || 'Untitled Program';
const tag = program.template ? program.template.charAt(0).toUpperCase() + program.template.slice(1) : 'Program';
---

<BaseLayout title={pageTitle}>
  <div class="preview-banner">
    PREVIEW MODE — This is a draft. Click reload to see latest changes.
  </div>

  {program.headerImage && (
    <div class="program-hero">
      <img src={program.headerImage} alt={programTitle} class="program-hero__img" />
    </div>
  )}

  <section class="section">
    <div class="container" style="max-width:680px;">
      <span class="label text-gold" style="display:block;margin-bottom:8px;">{tag}</span>
      <h1 class="program-title">{programTitle}</h1>
      {program.tagline && (
        <p class="program-tagline">{program.tagline}</p>
      )}
      {program.description && (
        <p class="program-desc">{program.description}</p>
      )}
      {hasBody ? (
        <div class="program-body article__body--illuminated" set:html={bodyHtml} />
      ) : (
        <p class="preview-placeholder">Add body content in the editor to see it here.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .preview-banner {
    background: #b89a47;
    color: #0e3352;
    text-align: center;
    padding: 10px 16px;
    font-family: system-ui, sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    position: sticky;
    top: 0;
    z-index: 9999;
  }
  .preview-placeholder { font-style: italic; color: #999; margin-top: 24px; }
  .program-hero { width: 100%; height: 300px; overflow: hidden; }
  .program-hero__img { width: 100%; height: 100%; object-fit: cover; }
  .program-title { font-family: var(--font-display); font-size: 2rem; color: var(--color-navy); line-height: 1.2; margin-bottom: 12px; }
  .program-tagline { font-family: var(--font-body); font-style: italic; color: var(--color-gray); margin-bottom: 24px; font-size: 1.05rem; }
  .program-desc { font-family: var(--font-body); font-size: 1.05rem; line-height: 1.85; color: var(--color-gray); margin-bottom: 24px; }
  .program-body :global(p) { font-family: var(--font-body); font-size: 1.05rem; line-height: 1.85; color: var(--color-gray); margin-bottom: 16px; }
  .program-body :global(h2) { font-family: var(--font-display); font-size: 1.3rem; color: var(--color-navy); margin-top: 32px; margin-bottom: 12px; }
</style>
