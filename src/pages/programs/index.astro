---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import { getProgramsOverview } from '../../lib/sanity';

// Fetch the programs overview singleton from Sanity
const overview = await getProgramsOverview();

// Filter to enabled cards only
const cards = (overview?.cards || []).filter((c: any) => c.enabled !== false);

// Fallback values if Sanity document doesn't exist yet
const heroImage = overview?.heroImage || `${import.meta.env.BASE_URL}images/art/Bodleian-Library-Oxford.jpg`;
const heroHeadline = overview?.heroHeadline || 'Formation, Courses & Community';
const heroQuote = overview?.heroQuote || '"Be who God meant you to be and you will set the world on fire."';
const heroAttribution = overview?.heroAttribution || '— St. Catherine of Siena';
const footerMessage = overview?.footerMessage || 'Every program is made possible by the faithful support of our Friends and Patrons.';
const footerLinkText = overview?.footerLinkText || 'Join them →';
const footerLinkUrl = overview?.footerLinkUrl || '/support/';
---

<BaseLayout title="Programs" description="Formation programs, courses, and community offerings from the Gregory the Great Institute.">

  <!-- Hero -->
  <section class="hero-compact section--dark">
    <div class="hero-compact__bg" style={`background-image: url(${heroImage})`}></div>
    <div class="hero-compact__overlay"></div>
    <div class="hero-compact__content container">
      <h1 data-pagefind-weight="10" class="display">{heroHeadline}</h1>
      {heroQuote && <p class="hero-compact__subtitle"><em>{heroQuote}</em></p>}
      {heroAttribution && <p class="hero-compact__attr">{heroAttribution}</p>}
    </div>
  </section>

  <!-- Program Cards -->
  <section class="section">
    <div class="container">

      {cards.map((card: any, i: number) => {
        const isReverse = i % 2 !== 0;
        const isLast = i === cards.length - 1;
        const imgClass = card.artFilter ? 'art-filter' : '';

        return (
          <>
            <div class={`program-card reveal${isReverse ? ' program-card--reverse' : ''}`}>
              <div class="program-card__image">
                <a href={card.ctaLink}>
                  <img
                    src={card.thumbnail}
                    alt={card.thumbnailAlt || card.title}
                    class={imgClass}
                  />
                </a>
              </div>
              <div class="program-card__body">
                {card.label && <p class="label text-gold">{card.label}</p>}
                <h2><a href={card.ctaLink}>{card.title}</a></h2>
                <p class="program-card__desc">{card.description}</p>
                {card.details && card.details.length > 0 && (
                  <dl class="program-card__details">
                    {card.details.map((d: any) => (
                      <>
                        <dt>{d.key}</dt>
                        <dd>{d.value}</dd>
                      </>
                    ))}
                  </dl>
                )}
                <Button href={card.ctaLink} variant="primary" size="small">{card.ctaText || 'Learn More'}</Button>
              </div>
            </div>
            {!isLast && <SectionDivider />}
          </>
        );
      })}

      {cards.length === 0 && (
        <p class="text-center" style="padding: 60px 0; color: var(--color-gray);">
          Programs coming soon. Check back for updates.
        </p>
      )}

    </div>
  </section>

  <!-- Made Possible By -->
  <section class="made-possible">
    <div class="container text-center">
      <p class="made-possible__text">
        {footerMessage}
        {' '}<a href={footerLinkUrl}>{footerLinkText}</a>
      </p>
    </div>
  </section>

</BaseLayout>

<style>
  .hero-compact {
    position: relative;
    min-height: 360px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-compact__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }

  .hero-compact__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(14, 51, 82, 0.72);
  }

  .hero-compact__content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    padding-block: 60px;
  }

  .hero-compact__content h1 {
    color: var(--color-text-on-dark);
    margin-bottom: 16px;
  }

  .hero-compact__subtitle {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: rgba(245, 239, 229, 0.85);
  }

  .hero-compact__attr {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-gold);
    margin-top: 4px;
  }

  /* Program Cards */
  .program-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-component);
    align-items: center;
    padding-bottom: 16px;
  }

  .program-card__image img {
    width: 100%;
    height: 300px;
    object-fit: cover;
    object-position: center center;
    border-radius: 3px;
  }

  .program-card__body h2 {
    margin: 8px 0 12px;
  }

  .program-card__body h2 a {
    color: inherit;
    text-decoration: none;
  }

  .program-card__body h2 a:hover {
    color: var(--color-gold);
  }

  .program-card__image a {
    display: block;
  }

  .program-card__desc {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-gray);
    margin-bottom: 20px;
  }

  .program-card__details {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 6px 16px;
    margin-bottom: 28px;
  }

  .program-card__details dt {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-navy);
  }

  .program-card__details dd {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-gray);
  }

  @media (max-width: 640px) {
    .program-card__image img {
      height: 200px;
    }
  }

  @media (min-width: 768px) {
    .program-card {
      grid-template-columns: 1fr 1.2fr;
    }
    .program-card--reverse {
      grid-template-columns: 1.2fr 1fr;
    }
    .program-card--reverse .program-card__image {
      order: 2;
    }
  }

  /* Made Possible */
  .made-possible {
    background-color: var(--color-linen);
    padding: 32px 0;
    border-top: 1px solid rgba(90, 90, 110, 0.08);
  }

  .made-possible__text {
    font-family: var(--font-body);
    font-size: 1rem;
    font-style: italic;
    color: var(--color-gray);
  }

  .made-possible__text a {
    color: var(--color-gold);
    text-decoration: none;
    font-style: normal;
    font-weight: 500;
  }

  .made-possible__text a:hover {
    color: var(--color-crimson);
  }
</style>
