---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';
import QuoteBlock from '../components/QuoteBlock.astro';
import SectionDivider from '../components/SectionDivider.astro';
import DarkSection from '../components/DarkSection.astro';
import EventCard from '../components/EventCard.astro';
import GivingTier from '../components/GivingTier.astro';
import EndorsementCard from '../components/EndorsementCard.astro';
---

<BaseLayout title="Inspiring Canadian Catholic Culture">

  <!-- ============================================
       Section 1: HERO
       ============================================ -->
  <section class="hero hero--home" style={`background-image: url(${import.meta.env.BASE_URL}images/art/school-of-athens.jpg)`}>
    <div class="hero__overlay"></div>
    <div class="hero__content container">
      <h1 class="hero__headline display">Inspiring Canadian Catholic Culture</h1>
      <p class="hero__tagline">Fides&ensp;•&ensp;Ratio<span class="hero__tagline-dot">&ensp;•&ensp;</span><br class="hero__tagline-break" />Cultura</p>
      <p class="hero__subtitle">Forming leaders. Teaching the tradition. Publishing research.</p>
      <div class="hero__ctas">
        <a href={`${import.meta.env.BASE_URL}magnalia/letter/`} class="btn btn--subscribe">Subscribe to the Magnalia Letter</a>
        <a href={`${import.meta.env.BASE_URL}programs/`} class="btn btn--ghost">Explore Our Programs</a>
      </div>
    </div>
  </section>

  <!-- ============================================
       Section 2: CARDINAL ENDORSEMENT
       ============================================ -->
  <section class="section section--tight">
    <div class="container">
      <QuoteBlock
        quote="A faith that does not become culture is not fully accepted, not entirely thought out, not faithfully lived."
        attribution="Pope St. John Paul II"
        variant="light"
      />
    </div>
  </section>

  <SectionDivider />

  <!-- ============================================
       Section 3: THREE PILLARS
       ============================================ -->
  <section class="section">
    <div class="container reveal">
      <div class="section-header">
        <p class="label text-gold">What We Do</p>
        <h2>Formation, Courses, Publications</h2>
        <p class="section-header__sub">
          Through courses, formation programs, and publications, the Gregory the Great Institute
          helps believers transform contemporary culture in the light of faith and reason.
        </p>
      </div>

      <div class="pillars">
        <a href={`${import.meta.env.BASE_URL}programs/`} class="pillar">
          <img src={`${import.meta.env.BASE_URL}images/art/Bodleian-Library-Oxford.jpg`} alt="Classical library" class="pillar__img" />
          <h3 class="pillar__title">Formation</h3>
          <p class="pillar__desc">Intensive Great Books seminars, music and leadership camps, and reading groups that form the whole person — mind, soul, and community.</p>
          <span class="pillar__link">View Programs →</span>
        </a>
        <a href={`${import.meta.env.BASE_URL}programs/masterclasses/`} class="pillar">
          <img src={`${import.meta.env.BASE_URL}images/art/vanitas-still-life-painting.jpg`} alt="Classical still life" class="pillar__img" />
          <h3 class="pillar__title">Courses</h3>
          <p class="pillar__desc">Short courses in the Philosophy of Aquinas, Virtuous Leadership, Christian Beauty and Art, and Classical Education for Teachers.</p>
          <span class="pillar__link">Browse Courses →</span>
        </a>
        <a href={`${import.meta.env.BASE_URL}magnalia/`} class="pillar">
          <img src={`${import.meta.env.BASE_URL}images/branding/Magnalia_Cover.jpg`} alt="Magnalia journal cover" class="pillar__img" />
          <h3 class="pillar__title">Publications</h3>
          <p class="pillar__desc">Magnalia — the journal of Catholic cultural renewal in Canada. 60 pages of letters, essays, and art in every issue.</p>
          <span class="pillar__link">Read Magnalia →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       Section 3b: VIDEO INTRO
       ============================================ -->
  <section class="section section--dark video-section">
    <div class="container">
      <div class="section-header">
        <p class="label text-gold">Watch</p>
        <h2 style="color: var(--color-text-on-dark);">Why Catholic Culture Matters</h2>
      </div>
      <div class="video-embed reveal reveal--scale">
        <iframe
          src="https://www.youtube.com/embed/Lhzqr8tMYsI"
          title="Why Catholic Culture Matters — Gregory the Great Institute"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- ============================================
       Section 4: MAGNALIA FEATURE
       ============================================ -->
  <section class="section section--linen magnalia-feature">
    <div class="container magnalia-feature__inner">
      <div class="magnalia-feature__cover reveal reveal--left">
        <img src={`${import.meta.env.BASE_URL}images/branding/Magnalia_Cover.jpg`} alt="Magnalia Journal — Issue One" class="magnalia-feature__img" />
      </div>
      <div class="magnalia-feature__text reveal reveal--right">
        <p class="label text-gold">Our Flagship Journal</p>
        <h2 class="magnalia-feature__title">Magnalia</h2>
        <p class="magnalia-feature__subtitle">The journal of Catholic cultural renewal in Canada</p>
        <p class="magnalia-feature__body">
          <em>Magnalia</em> — meaning <em>great and wonderful things</em> — brings together the best Catholic
          writing, scholarship, and art in Canada. Each 60-page issue features essays from leading Catholic
          thinkers, letters from the field, and beautiful visual art. Published twice yearly.
        </p>
        <div class="magnalia-feature__ctas">
          <Button href={`${import.meta.env.BASE_URL}magnalia/subscribe/`} variant="primary">Subscribe to Magnalia</Button>
          <a href={`${import.meta.env.BASE_URL}magnalia/`} class="magnalia-feature__sample">Read a Sample →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       Section 5: UPCOMING EVENTS
       ============================================ -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="label text-gold">Upcoming</p>
        <h2>Events & Programs</h2>
      </div>

      <div class="events-grid reveal">
        <EventCard
          title="Bringing Back Sunday — Renewing Culture Conference"
          month="Oct"
          day="2"
          date="2026-10-02"
          location="Mt Carmel Spirituality Centre"
          description="2nd Annual Renewing Culture Conference. Reflections on Josef Pieper's Leisure: The Basis of Culture."
          href={`${import.meta.env.BASE_URL}events/conference-2026/`}
          programTag="Conference"
        />
        <EventCard
          title="St. Gregory's Music & Leadership Camp"
          month="Jul"
          day="12"
          date="2026-07-12"
          location="Solara Water's Edge, Parkland County, AB"
          description="Four nights of fiddle, penny whistle, voice, games, prayer, and leadership for youth ages 12–18."
          href={`${import.meta.env.BASE_URL}events/music-camp-2026/`}
          programTag="Camp"
        />
        <EventCard
          title="Personal Finances 101"
          month="Apr"
          day="25"
          date="2026-04-25"
          location="Concordia University of Edmonton"
          description="Master your money, serve your vocation. Financial literacy as stewardship and Catholic formation."
          href={`${import.meta.env.BASE_URL}events/finances-101/`}
          programTag="Masterclass"
        />
      </div>

      <div class="section-footer" style="margin-bottom: -32px;">
        <Button href={`${import.meta.env.BASE_URL}events/`} variant="tertiary">View All Events →</Button>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- ============================================
       Section 6: ENDORSEMENTS
       ============================================ -->
  <section class="section" style="padding-top: 24px;">
    <div class="container">
      <div class="endorsements-grid reveal">
        <EndorsementCard
          quote="I have appreciated Dr. Ryan Topping's work for several years. I support the mission of the Gregory the Great Institute and look forward to seeing the good it will bring to the Church in Canada."
          name="Michael D. O'Brien"
          title="Canadian author and painter"
        />
        <EndorsementCard
          quote="It is creative minorities who determine the future, and in this regard the Catholic Church must understand that she is a creative minority that has a heritage of values that are not things of the past, but a very living and relevant reality."
          name="Pope Benedict XVI"
          title=""
        />
        <EndorsementCard
          quote="Religion without orthodoxy, without dogma, is as the heat of a corpse, true for a time but sure to fail."
          name="St. John Henry Newman"
          title="Doctor of the Church"
        />
      </div>
    </div>
  </section>

  <!-- ============================================
       Section 7: LATEST FROM THE LIBRARY
       ============================================ -->
  <section class="section section--linen">
    <div class="container">
      <div class="section-header">
        <p class="label text-gold">From the Library</p>
        <h2>The Latest</h2>
      </div>

      <div class="card-grid">
        <Card
          title="FINE Gathering in Ottawa and National Prayer Breakfast"
          description="Dr. Topping and Victor invited to FINE Gathering and National Prayer Breakfast by MP Shuv Majumbar."
          meta="Article · Apr 14, 2026"
          href={`${import.meta.env.BASE_URL}library/fine-gathering-ottawa/`}
          image="/images/art/Bodleian-Library-Oxford.jpg"
          imageAlt="Library interior"
        />
        <Card
          title="Medicine Forgets Its Vocation: Alberta Places Guardrails"
          description="On MAID and hospital chaplains counselling traumatized healthcare professionals."
          meta="Essay · Mar 20, 2026"
          href={`${import.meta.env.BASE_URL}library/medicine-forgets-vocation/`}
          image="/images/art/vanitas-still-life-painting.jpg"
          imageAlt="Vanitas still life"
        />
        <Card
          title="Master Your Money, Serve Your Vocation"
          description="64% of Canadians never learned money management. Financial literacy as stewardship."
          meta="Article · Apr 9, 2026"
          href={`${import.meta.env.BASE_URL}library/personal-finances/`}
          image="/images/art/St-Gregory-Great-painting-dove.jpg"
          imageAlt="St. Gregory the Great"
        />
      </div>

      <div class="section-footer">
        <Button href={`${import.meta.env.BASE_URL}library/`} variant="tertiary">View All Library →</Button>
      </div>
    </div>
  </section>

  <!-- ============================================
       Section 8: SUPPORT THE MISSION
       ============================================ -->
  <section class="section section--dark support-preview">
    <div class="container support-preview__inner">
      <div class="support-preview__text">
        <p class="label text-gold">Support the Mission</p>
        <h2>Build Catholic Intellectual Life in Canada</h2>
        <p class="support-preview__body">
          In its first year, the Institute published Magnalia and distributed to every Catholic bishop
          and seminary rector in Canada, ran formation programs in four provinces, hosted the inaugural
          Renewing Culture Conference, and built a community of over 1,500 people hungry for cultural
          renewal. We did this on a lean budget with a small team. With your help, we can do so much more.
        </p>
        <Button href={`${import.meta.env.BASE_URL}support/`} variant="primary">Become a Friend</Button>
      </div>
      <div class="support-preview__tiers">
        <a href={`${import.meta.env.BASE_URL}support/`} class="tier-preview">
          <p class="tier-preview__name">Friend of the Institute</p>
          <p class="tier-preview__price"><span class="tier-preview__amount">$10–49</span><span class="tier-preview__period">/month</span></p>
          <ul class="tier-preview__list">
            <li>Monthly prayer inclusion</li>
            <li>Magnalia Letter</li>
            <li>Early event registration</li>
          </ul>
        </a>
        <a href={`${import.meta.env.BASE_URL}support/`} class="tier-preview tier-preview--featured">
          <p class="tier-preview__badge">Recommended</p>
          <p class="tier-preview__name">Patron</p>
          <p class="tier-preview__price"><span class="tier-preview__amount">$50</span><span class="tier-preview__period">/month</span></p>
          <ul class="tier-preview__list">
            <li>Everything in Friend, plus:</li>
            <li>Magnalia subscription included</li>
            <li>Quarterly Q&A with Dr. Topping</li>
            <li>Named recognition</li>
          </ul>
        </a>
      </div>
    </div>
    <div class="container" style="text-align: center; margin-top: 24px;">
      <Button href={`${import.meta.env.BASE_URL}support/`} variant="tertiary">See All Giving Options →</Button>
    </div>
  </section>

  <!-- ============================================
       Section 9: NEWSLETTER SIGNUP
       ============================================ -->
  <section class="newsletter-section">
    <div class="container newsletter-section__inner">
      <h2 class="newsletter-section__title">Join the Magnalia Letter</h2>
      <p class="newsletter-section__desc">Free monthly essays, event invitations, and reading recommendations from the Institute.</p>
      <form class="newsletter-section__form" action="#" method="POST">
        <input type="text" name="firstName" placeholder="First name" class="newsletter-section__input" required aria-label="First name" />
        <input type="email" name="email" placeholder="Email address" class="newsletter-section__input" required aria-label="Email address" />
        <button type="submit" class="newsletter-section__btn">Subscribe</button>
      </form>
    </div>
  </section>

</BaseLayout>

<style>
  /* ---- Hero ---- */
  .hero--home {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: var(--color-navy);
  }

  .hero--home {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(14, 51, 82, 0.75) 0%,
      rgba(14, 51, 82, 0.6) 40%,
      rgba(14, 51, 82, 0.8) 100%
    );
    z-index: 2;
  }

  .hero__content {
    position: relative;
    z-index: 3;
    text-align: center;
    max-width: 800px;
    padding-block: 80px;
  }

  .hero__headline {
    color: var(--color-text-on-dark);
    margin-bottom: 12px;
  }

  .hero__tagline-break {
    display: none;
  }

  @media (max-width: 480px) {
    .hero__tagline-dot {
      display: none;
    }
    .hero__tagline-break {
      display: inline;
    }
  }

  .hero__tagline {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-style: normal;
    font-weight: 600;
    color: var(--color-gold);
    margin-bottom: 16px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.7), 0 4px 16px rgba(0, 0, 0, 0.4);
  }

  .hero__subtitle {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: rgba(245, 239, 229, 0.8);
    margin-bottom: 36px;
    line-height: 1.6;
  }

  .hero__ctas {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn--subscribe {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-navy);
    background-color: var(--color-gold);
    padding: 16px 40px;
    border: none;
    border-radius: 3px;
    text-decoration: none;
    letter-spacing: 0.02em;
    box-shadow: 0 4px 20px rgba(198, 160, 50, 0.35);
    transition: all var(--transition-fast);
  }

  .btn--subscribe:hover {
    background-color: #d4ad3a;
    box-shadow: 0 6px 28px rgba(198, 160, 50, 0.5);
    transform: translateY(-1px);
  }

  .btn--ghost {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-on-dark);
    background: transparent;
    padding: 14px 32px;
    border: 1.5px solid rgba(245, 239, 229, 0.3);
    border-radius: 3px;
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .btn--ghost:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  @media (max-width: 640px) {
    .hero--home {
      min-height: 85vh;
    }
    .hero__seal {
      width: 56px;
      height: 56px;
    }
    .hero__ctas {
      flex-direction: column;
      align-items: center;
    }
  }

  /* ---- Video Section ---- */
  .video-embed {
    position: relative;
    width: 100%;
    max-width: 800px;
    margin-inline: auto;
    aspect-ratio: 16 / 9;
    border-radius: 3px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .video-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* ---- Tight section (reduced whitespace) ---- */
  .section--tight {
    padding-block: 32px;
  }

  /* ---- Section Shared ---- */
  .section-header {
    text-align: center;
    margin-bottom: var(--space-component);
    max-width: 640px;
    margin-inline: auto;
  }

  .section-header h2 {
    margin-top: 8px;
    margin-bottom: 16px;
  }

  .section-header__sub {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-gray);
  }

  .section-footer {
    text-align: center;
    margin-top: var(--space-component);
  }

  .section--linen {
    background-color: var(--color-linen);
  }

  /* ---- Pillars ---- */
  .pillars {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .pillar {
    display: block;
    text-decoration: none;
    background-color: var(--color-linen);
    border: 1px solid rgba(90, 90, 110, 0.1);
    border-radius: 3px;
    overflow: hidden;
    transition: box-shadow var(--transition-base);
  }

  .pillar:hover {
    box-shadow: 0 4px 20px rgba(14, 51, 82, 0.08);
  }

  .pillar__img {
    width: 100%;
    height: 240px;
    object-fit: cover;
    object-position: top center;
  }

  .pillar__title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-navy);
    padding: 20px 24px 0;
  }

  .pillar__desc {
    font-family: var(--font-body);
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--color-gray);
    padding: 8px 24px 0;
  }

  .pillar__link {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-gold);
    padding: 16px 24px 24px;
  }

  @media (min-width: 640px) {
    .pillars {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ---- Magnalia Feature ---- */
  .magnalia-feature {
    overflow: hidden;
  }

  .magnalia-feature__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-component);
    align-items: center;
  }

  .magnalia-feature__cover {
    text-align: center;
  }

  .magnalia-feature__img {
    max-width: 320px;
    width: 100%;
    display: block;
    transform: rotate(-3deg);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
    border-radius: 3px;
    margin-inline: auto;
  }

  @media (max-width: 640px) {
    .magnalia-feature__img {
      max-width: 240px;
    }
    .magnalia-feature__text {
      padding-inline: 8px;
    }
  }

  .magnalia-feature__title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-navy);
    margin: 8px 0 8px;
  }

  .magnalia-feature__subtitle {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-style: italic;
    color: var(--color-gray);
    margin-bottom: 16px;
  }

  .magnalia-feature__body {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-gray);
    margin-bottom: 28px;
  }

  .magnalia-feature__ctas {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .magnalia-feature__sample {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-gray);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .magnalia-feature__sample:hover {
    color: var(--color-gold);
  }

  @media (min-width: 768px) {
    .magnalia-feature__inner {
      grid-template-columns: 1fr 1.3fr;
    }
  }

  /* ---- Events Grid ---- */
  .events-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 768px) {
    .events-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ---- Endorsements ---- */
  .endorsements-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 768px) {
    .endorsements-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ---- Card Grid ---- */
  .card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 640px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .card-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ---- Support Preview ---- */
  .support-preview__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-component);
    align-items: start;
  }

  .support-preview__text h2 {
    color: var(--color-text-on-dark);
    margin-top: 8px;
    margin-bottom: 16px;
  }

  .support-preview__body {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(245, 239, 229, 0.8);
    margin-bottom: 24px;
  }

  .support-preview__tiers {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .tier-preview {
    flex: 1;
    min-width: 200px;
    background: rgba(245, 239, 229, 0.04);
    border: 1px solid rgba(245, 239, 229, 0.1);
    border-radius: 3px;
    padding: 24px;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: border-color var(--transition-fast), transform var(--transition-fast);
    cursor: pointer;
  }

  .tier-preview:hover {
    border-color: var(--color-gold);
    transform: translateY(-2px);
  }

  .tier-preview--featured {
    border-color: var(--color-gold);
    position: relative;
  }

  .tier-preview__badge {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-navy);
    background-color: var(--color-gold);
    padding: 3px 10px;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 12px;
  }

  .tier-preview__name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text-on-dark);
    margin-bottom: 6px;
  }

  .tier-preview__amount {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-gold);
  }

  .tier-preview__period {
