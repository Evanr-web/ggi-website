---
/*  /resources/roadmap  —  Lead-magnet landing page (true landing page, no nav/footer)
    PDF delivered via ActiveCampaign automation after form submit.
    AC endpoint: /api/reading-guide  |  Tag: reading-guide (33)  |  List: newsletter (4)
*/
import '../../../styles/global.css';

const base = import.meta.env.BASE_URL;
const siteUrl = 'https://gregorythegreat.ca';
const title = 'The Roadmap to Renewal — Free Reading Guide';
const description = 'Get the free reading guide based on the 6 Models of Cultural Renewal. 20 titles curated by Dr. Ryan Topping to help you rebuild culture through faith and reason.';
const ogImage = `${siteUrl}${base}images/branding/ggi-og-default.jpg`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={`${siteUrl}${base}resources/roadmap/`} />
    <meta property="og:type" content="website" />

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title}</title>

    <!-- Cloudflare Turnstile -->
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  </head>

  <body class="lp">

    <!-- Logo -->
    <header class="lp-header">
      <a href={siteUrl}>
        <img src={`${base}images/branding/ggi-seal.png`} alt="Gregory the Great Institute" width="52" height="52" class="lp-seal" />
      </a>
    </header>

    <main>
      <!-- ═══════════════════════════════════════════
           HERO — Above the fold: mockup + form
           ═══════════════════════════════════════════ -->
      <section class="lp-hero">
        <div class="lp-hero__inner">

          <!-- Left: copy + benefits -->
          <div class="lp-hero__copy">
            <p class="lp-label">Free Reading Guide</p>
            <h1 class="lp-h1">The Roadmap<br />to Renewal</h1>
            <p class="lp-subtitle">A reading guide based on the 6 Models of Cultural Renewal</p>

            <p class="lp-intro">Dr.&nbsp;Ryan Topping's 6 Models of Cultural Renewal map six paths toward rebuilding culture through faith and reason. This reading guide pairs each model with essential titles — 20&nbsp;books across philosophy, theology, and spiritual formation.</p>

            <ul class="lp-benefits">
              <li><strong>20 titles organized by model</strong> — know where to start</li>
              <li><strong>Philosophy, theology, social thought, and spiritual formation</strong></li>
              <li><strong>A companion</strong> to the 6 Models of Cultural Renewal video series</li>
            </ul>
          </div>

          <!-- Right: mockup + form -->
          <div class="lp-hero__action">
            <img
              src={`${base}images/branding/reading-guide-preview.png`}
              alt="The Roadmap to Renewal — Reading Guide preview"
              class="lp-mockup"
            />

            <div class="lp-form-card" id="download">
              <h2 class="lp-form-title">Get the Free Reading Guide</h2>
              <p class="lp-form-desc">We'll email the guide straight to your inbox.</p>

              <form id="roadmap-form" class="lp-form" novalidate>
                <div class="lp-form-row">
                  <div class="lp-field">
                    <label for="firstName">First Name</label>
                    <input type="text" id="firstName" name="firstName" autocomplete="given-name" required />
                  </div>
                  <div class="lp-field">
                    <label for="lastName">Last Name</label>
                    <input type="text" id="lastName" name="lastName" autocomplete="family-name" />
                  </div>
                </div>

                <div class="lp-field">
                  <label for="email">Email Address <span class="req">*</span></label>
                  <input type="email" id="email" name="email" autocomplete="email" required />
                </div>

                <!-- Honeypot -->
                <div style="position:absolute;left:-9999px;" aria-hidden="true">
                  <input type="text" name="website" tabindex="-1" autocomplete="off" />
                </div>

                <!-- Turnstile -->
                <div class="cf-turnstile" data-sitekey="0x4AAAAAADm6eYaBvIIwZNRm" data-theme="light"></div>

                <button type="submit" class="lp-btn" id="submit-btn">
                  Get the Reading Guide
                </button>

                <p id="form-error" class="lp-msg lp-msg--err" style="display:none;"></p>
                <p class="lp-privacy">We respect your privacy. Unsubscribe anytime.</p>
              </form>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
           WHAT'S INSIDE — teaser, not full content
           ═══════════════════════════════════════════ -->
      <section class="lp-inside">
        <h2 class="lp-h2">What's Inside</h2>
        <p class="lp-inside-desc">
          Reading recommendations curated by Dr.&nbsp;Topping on each of the six models for cultural renewal.
        </p>

        <div class="lp-model-list">
          <div class="lp-model">
            <span class="lp-model-num">1</span>
            <strong>The Ignatian Model</strong>
          </div>
          <div class="lp-model">
            <span class="lp-model-num">2</span>
            <strong>The Dominican Model</strong>
          </div>
          <div class="lp-model">
            <span class="lp-model-num">3</span>
            <strong>The Franciscan Model</strong>
          </div>
          <div class="lp-model">
            <span class="lp-model-num">4</span>
            <strong>The Benedictine Model</strong>
          </div>
          <div class="lp-model">
            <span class="lp-model-num">5</span>
            <strong>The Constantinian Model</strong>
          </div>
          <div class="lp-model">
            <span class="lp-model-num">6</span>
            <strong>The Marian Model</strong>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
           SECOND CTA — repeat form anchor
           ═══════════════════════════════════════════ -->
      <section class="lp-cta2">
        <h2 class="lp-h2">Ready to Begin?</h2>
        <p>Get the free reading guide and start your roadmap to renewal.</p>
        <a href="#download" class="lp-btn lp-btn--outline">Get the Guide ↑</a>
      </section>
    </main>

    <!-- Minimal footer -->
    <footer class="lp-footer">
      <p>&copy; {new Date().getFullYear()} Gregory the Great Institute &nbsp;·&nbsp;
        <a href={siteUrl}>gregorythegreat.ca</a>
      </p>
    </footer>

    <!-- Form handler -->
    <script is:inline>
      document.getElementById('roadmap-form').addEventListener('submit', async function(e) {
        e.preventDefault();
        var btn = document.getElementById('submit-btn');
        var errEl = document.getElementById('form-error');
        errEl.style.display = 'none';
        btn.disabled = true;
        btn.textContent = 'Sending…';

        var fd = new FormData(this);
        var params = new URLSearchParams(window.location.search);
        var payload = {
          firstName: fd.get('firstName') || '',
          lastName: fd.get('lastName') || '',
          email: fd.get('email') || '',
          website: fd.get('website') || '',
          signup_page: '/resources/roadmap/',
          utm_source: params.get('utm_source') || '',
          utm_medium: params.get('utm_medium') || '',
          utm_campaign: params.get('utm_campaign') || '',
          utm_content: params.get('utm_content') || '',
        };

        var tsEl = document.querySelector('[name="cf-turnstile-response"]');
        if (tsEl) payload['cf-turnstile-response'] = tsEl.value;

        try {
          var res = await fetch('/api/reading-guide', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          var data = await res.json();
          if (res.ok && data.success) {
            window.location.href = '/resources/roadmap/thank-you/';
          } else {
            errEl.textContent = data.error || 'Something went wrong. Please try again.';
            errEl.style.display = 'block';
            btn.disabled = false;
            btn.textContent = 'Get the Reading Guide';
          }
        } catch (err) {
          errEl.textContent = 'Network error. Please try again.';
          errEl.style.display = 'block';
          btn.disabled = false;
          btn.textContent = 'Get the Reading Guide';
        }
      });
    </script>
  </body>
</html>

<style>
  /* ════════════════════════════════════════════
     Landing Page — High-Conversion Layout
     ════════════════════════════════════════════ */

  .lp {
    font-family: var(--font-body);
    background: var(--color-parchment);
    color: var(--color-ink);
    min-height: 100vh;
  }

  /* ── Header ── */
  .lp-header {
    text-align: center;
    padding: 20px 24px 0;
  }
  .lp-seal {
    border-radius: 50%;
    opacity: 0.9;
  }

  /* ── Hero ── */
  .lp-hero {
    padding: 32px 24px 56px;
  }
  .lp-hero__inner {
    max-width: 1060px;
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .lp-label {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 8px;
  }

  .lp-h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    font-weight: 700;
    color: var(--color-navy);
    line-height: 1.1;
    margin-bottom: 10px;
  }

  .lp-subtitle {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--color-crimson);
    margin-bottom: 28px;
  }

  .lp-benefits {
    list-style: none;
    padding: 0;
    margin-bottom: 24px;
  }
  .lp-benefits li {
    position: relative;
    padding-left: 24px;
    margin-bottom: 14px;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-gray);
  }
  .lp-benefits li::before {
    content: '✦';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--color-gold);
    font-size: 0.85rem;
  }
  .lp-benefits li strong {
    color: var(--color-navy);
  }

  .lp-intro {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-gray);
    margin-bottom: 20px;
  }

  /* ── Right column: mockup + form ── */
  .lp-hero__action {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .lp-mockup {
    max-width: 280px;
    width: 100%;
    height: auto;
    margin-bottom: -24px;
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 8px 24px rgba(14, 51, 82, 0.12));
  }

  .lp-form-card {
    background: white;
    border: 1px solid var(--color-ivory);
    border-radius: 12px;
    padding: 32px 28px 28px;
    width: 100%;
    max-width: 400px;
    position: relative;
    z-index: 2;
  }

  .lp-form-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--color-navy);
    text-align: center;
    margin-bottom: 6px;
  }

  .lp-form-desc {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--color-gray);
    text-align: center;
    margin-bottom: 20px;
  }

  .lp-form-row {
    display: flex;
    gap: 12px;
  }

  .lp-field {
    margin-bottom: 14px;
    flex: 1;
  }
  .lp-field label {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-navy);
    margin-bottom: 5px;
  }
  .req { color: var(--color-crimson); }

  .lp-field input {
    width: 100%;
    padding: 9px 12px;
    font-family: var(--font-body);
    font-size: 0.92rem;
    border: 1px solid var(--color-ivory);
    border-radius: 6px;
    background: var(--color-linen);
    color: var(--color-ink);
    transition: border-color var(--transition-fast);
  }
  .lp-field input:focus {
    outline: none;
    border-color: var(--color-gold);
    box-shadow: 0 0 0 3px rgba(184, 154, 71, 0.15);
  }

  .cf-turnstile {
    margin: 12px auto;
    display: flex;
    justify-content: center;
  }

  .lp-btn {
    display: block;
    width: 100%;
    padding: 13px 20px;
    font-family: var(--font-ui);
    font-size: 0.95rem;
    font-weight: 600;
    color: white;
    background: var(--color-navy);
    border: 2px solid var(--color-navy);
    border-radius: 6px;
    cursor: pointer;
    transition: background var(--transition-base), color var(--transition-base);
    text-align: center;
    text-decoration: none;
    margin-top: 6px;
  }
  .lp-btn:hover {
    background: var(--color-crimson);
    border-color: var(--color-crimson);
  }
  .lp-btn:disabled {
    opacity: 0.6;
    cursor: wait;
  }

  .lp-btn--outline {
    display: inline-block;
    width: auto;
    background: transparent;
    color: var(--color-navy);
    padding: 12px 32px;
  }
  .lp-btn--outline:hover {
    background: var(--color-navy);
    color: white;
  }

  .lp-msg {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    margin-top: 10px;
    text-align: center;
  }
  .lp-msg--err { color: var(--color-error); }

  .lp-privacy {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    color: var(--color-gray);
    text-align: center;
    margin-top: 10px;
    opacity: 0.65;
  }

  /* ── What's Inside ── */
  .lp-inside {
    background: var(--color-navy);
    padding: 56px 24px;
    text-align: center;
  }

  .lp-h2 {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 12px;
  }

  .lp-inside .lp-h2 {
    color: white;
  }

  .lp-inside-desc {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--color-ivory);
    margin-bottom: 36px;
  }

  .lp-model-list {
    max-width: 720px;
    margin-inline: auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    text-align: left;
  }

  .lp-model {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px;
    border: 1px solid rgba(184, 154, 71, 0.25);
    border-radius: 8px;
    transition: border-color var(--transition-base);
  }
  .lp-model:hover {
    border-color: var(--color-gold);
  }

  .lp-model-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--color-gold);
    color: var(--color-navy);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
  }

  .lp-model strong {
    display: block;
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: white;
    margin-bottom: 2px;
  }

  .lp-model span {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: var(--color-ivory);
    opacity: 0.8;
  }

  /* ── Second CTA ── */
  .lp-cta2 {
    text-align: center;
    padding: 0 24px 56px;
  }
  .lp-cta2 p {
    color: var(--color-gray);
    margin-bottom: 20px;
    font-size: 1rem;
  }

  /* ── Footer ── */
  .lp-footer {
    text-align: center;
    padding: 20px 24px;
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: var(--color-gray);
    border-top: 1px solid var(--color-ivory);
  }
  .lp-footer a {
    color: var(--color-navy);
    text-decoration: none;
  }
  .lp-footer a:hover {
    color: var(--color-crimson);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .lp-hero__inner {
      grid-template-columns: 1fr;
      gap: 32px;
      text-align: center;
    }
    .lp-benefits {
      text-align: left;
      max-width: 400px;
      margin-inline: auto;
      margin-bottom: 24px;
    }
    .lp-author {
      text-align: center;
    }
    .lp-mockup {
      max-width: 220px;
    }
    .lp-model-list {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .lp-form-row {
      flex-direction: column;
      gap: 0;
    }
    .lp-form-card {
      padding: 24px 20px 20px;
    }
    .lp-hero {
      padding: 20px 16px 40px;
    }
  }
</style>
