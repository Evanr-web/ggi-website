---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Page Not Found — Gregory the Great Institute">
  <section class="not-found">
    <div class="container not-found__inner">
      <p class="not-found__code">404</p>
      <h1 class="not-found__title">Page Not Found</h1>
      <p class="not-found__desc">The page you're looking for doesn't exist or has been moved.</p>
      <div class="not-found__actions">
        <Button href={`${import.meta.env.BASE_URL}`} variant="primary">Return Home</Button>
        <Button href={`${import.meta.env.BASE_URL}contact/`} variant="tertiary">Contact Us</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-section) 0;
  }

  .not-found__code {
    font-family: var(--font-display);
    font-size: 6rem;
    font-weight: 700;
    color: var(--color-gold);
    line-height: 1;
    margin-bottom: 8px;
    opacity: 0.4;
  }

  .not-found__title {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-navy);
    margin-bottom: 12px;
  }

  .not-found__desc {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-gray);
    margin-bottom: 32px;
    line-height: 1.6;
  }

  .not-found__actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
