---
import BaseLayout from '../../layouts/BaseLayout.astro';
import QuoteBlock from '../../components/QuoteBlock.astro';
import SectionDivider from '../../components/SectionDivider.astro';
---

<BaseLayout title="Mission & Vision" description="The Gregory the Great Institute equips Christians to renew culture in the light of faith and reason.">

  <!-- Hero -->
  <section class="hero-compact section--dark">
    <div class="hero-compact__bg" style={`background-image: url(${import.meta.env.BASE_URL}images/art/notre-dame-montreal.jpg)`}></div>
    <div class="hero-compact__overlay"></div>
    <div class="hero-compact__content container">
      <h1 data-pagefind-weight="10" class="display">Our Mission</h1>
      <p class="hero-compact__subtitle">To equip Christians to renew culture in the light of faith and reason.</p>
    </div>
  </section>

  <!-- Mission & Vision — Icon Cards -->
  <section class="section">
    <div class="container">
      <div class="mv-cards reveal-stagger">
        <div class="mv-card reveal">
          <img src={`${import.meta.env.BASE_URL}icons/torch.svg`} alt="" class="mv-card__icon-img" />
          <h2 class="mv-card__title">Our Mission</h2>
          <p class="mv-card__tagline">To equip Christians to renew culture.</p>
          <p class="mv-card__body">
            Through courses, formation programs, and publications, the Gregory the Great Institute helps
            believers transform contemporary culture in the light of faith and reason.
          </p>
        </div>
        <div class="mv-card reveal">
          <img src={`${import.meta.env.BASE_URL}icons/cathedral.svg`} alt="" class="mv-card__icon-img" />
          <h2 class="mv-card__title">Our Vision</h2>
          <p class="mv-card__tagline">A Catholic intellectual renaissance in Canada.</p>
          <p class="mv-card__body">
            A lay-led movement of formation, scholarship, and beauty — building institutions that serve
            the Church in Canada for generations.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Strip -->
  <section class="stats-strip">
    <div class="container stats-strip__inner reveal">
      <div class="stat">
        <span class="stat__number">1,500+</span>
        <span class="stat__label">Community Members</span>
      </div>
      <div class="stat">
        <span class="stat__number">Every</span>
        <span class="stat__label">Catholic Bishop in Canada Received Magnalia</span>
      </div>
      <div class="stat">
        <span class="stat__number">4</span>
        <span class="stat__label">Provinces with Programs</span>
      </div>
      <div class="stat">
        <span class="stat__number">60</span>
        <span class="stat__label">Pages per Issue of Magnalia</span>
      </div>
    </div>
  </section>

  <!-- Strategy Timeline -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="label text-gold">Where We've Been & Where We're Going</p>
        <h2>Our Strategy</h2>
      </div>

      <div class="timeline reveal">
        <div class="timeline__item">
          <div class="timeline__marker"></div>
          <div class="timeline__date">
            <span class="timeline__year">Jan 2025</span>
            <span class="timeline__phase label text-gold">Foundation</span>
          </div>
          <div class="timeline__content">
            <h3>Vision Cast</h3>
            <p>Gathered a team of committed Catholics, sought seed funding, and laid the groundwork for a new institution dedicated to cultural renewal.</p>
          </div>
        </div>

        <div class="timeline__item timeline__item--active">
          <div class="timeline__marker timeline__marker--active"></div>
          <div class="timeline__date">
            <span class="timeline__year">Jul 2025</span>
            <span class="timeline__phase label text-gold">Proof of Concept</span>
          </div>
          <div class="timeline__content">
            <h3>Building & Testing</h3>
            <p>Launched formation programs, courses, and publications. Magnalia reached every Catholic bishop and seminary rector in Canada. The Renewing Culture Conference brought speakers and seekers from across Western Canada. Book studies sprouted coast to coast.</p>
          </div>
        </div>

        <div class="timeline__item">
          <div class="timeline__marker"></div>
          <div class="timeline__date">
            <span class="timeline__year">Jul 2027</span>
            <span class="timeline__phase label text-gold">Major Launch</span>
          </div>
          <div class="timeline__content">
            <h3>Institutions for the Long Run</h3>
            <p>A trade school for Catholic men. Certificate and diploma programs in Christian leadership. A Canadian Catholic think-tank. The seeds planted now growing into institutions that will serve the Church for generations.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- Patron Saint -->
  <section class="section">
    <div class="container patron-section">
      <div class="patron-section__image">
        <img src={`${import.meta.env.BASE_URL}images/art/St-Gregory-Great-painting-dove.jpg`} alt="St. Gregory the Great"  class="art-filter" />
      </div>
      <div class="patron-section__text">
        <p class="label text-gold">Our Patron</p>
        <h2>St. Gregory the Great</h2>
        <p>
          St. Gregory the Great (d. 604) serves as our patron because he taught the West how to love God
          during times of upheaval. A pope, doctor of the Church, and father of the medieval papacy, Gregory
          reformed the liturgy, sent missionaries to England, wrote extensively on pastoral care, and laid
          the foundations of Christendom from the ruins of the Roman Empire.
        </p>
        <p>
          Gregory is the model builder of Catholic culture. At the Gregory the Great Institute we too hope
          to be builders of culture in Canada; we too hope to help strengthen islands of holiness where
          prayer, friendship, study, beauty and economic vitality can breathe together.
        </p>

      </div>
    </div>
  </section>

  <!-- Our Crest -->
  <section class="section section--dark crest-block">
    <div class="container">
      <div class="crest-block__inner reveal">
        <div class="crest-block__image">
          <img src={`${import.meta.env.BASE_URL}images/branding/ggi-seal.png`} alt="GGI Crest" class="crest-block__img" />
        </div>
        <div class="crest-block__text">
          <p class="label text-gold">Our Identity</p>
          <h2 class="heading-on-dark">Our Crest</h2>
          <ul class="crest-block__list">
            <li><strong>Dove</strong> — Vivifying power of God's Holy Spirit</li>
            <li><strong>Cross</strong> — Centrality of sacrifice by Christ and for Christ</li>
            <li><strong>IOIC</strong> — "To restore all things in Christ" (Ephesians 1:10)</li>
            <li><strong>Red Shield</strong> — Christendom's warriors and scholars</li>
            <li><strong>Book of Chant</strong> — Authentic culture as fruit of revealed worship</li>
            <li><strong>Wheat Sheaves</strong> — Eucharist, dignity of work, mission in Western Canada</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- Sub-page Navigation -->
  <section class="section section--linen">
    <div class="container">
      <div class="about-nav">
        <a href={`${import.meta.env.BASE_URL}about/leadership/`} class="about-nav__card">
          <h3>Leadership</h3>
          <p>Board, staff, fellows, and advisory board.</p>
          <span class="about-nav__arrow">→</span>
        </a>
        <a href={`${import.meta.env.BASE_URL}about/founding-director/`} class="about-nav__card">
          <h3>Founding Director</h3>
          <p>Dr. Ryan N.S. Topping — biography, publications, and media.</p>
          <span class="about-nav__arrow">→</span>
        </a>
        <a href={`${import.meta.env.BASE_URL}about/impact/`} class="about-nav__card">
          <h3>Impact Report</h3>
          <p>Key achievements and financial stewardship.</p>
          <span class="about-nav__arrow">→</span>
        </a>
        <a href={`${import.meta.env.BASE_URL}about/media/`} class="about-nav__card">
          <h3>Media & Press</h3>
          <p>Articles, interviews, videos, and press resources.</p>
          <span class="about-nav__arrow">→</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero-compact {
    position: relative;
    min-height: 360px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-compact__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }

  .hero-compact__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(14, 51, 82, 0.72);
  }

  .hero-compact__content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    padding-block: 60px;
  }

  .hero-compact__content h1 {
    color: var(--color-text-on-dark);
    margin-bottom: 12px;
  }

  .hero-compact__subtitle {
    font-family: var(--font-body);
    font-size: 1.15rem;
    color: rgba(245, 239, 229, 0.85);
    line-height: 1.6;
  }

  /* Mission/Vision Icon Cards */
  .mv-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    max-width: 900px;
    margin-inline: auto;
  }

  .mv-card {
    text-align: center;
    padding: 32px 28px;
    background-color: var(--color-linen);
    border: 1px solid rgba(90, 90, 110, 0.08);
    border-radius: 3px;
  }

  .mv-card__icon-img {
    width: 56px;
    height: 56px;
    margin-bottom: 16px;
    display: block;
    margin-inline: auto;
  }

  .mv-card__title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 6px;
  }

  .mv-card__tagline {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-style: italic;
    color: var(--color-gold);
    margin-bottom: 12px;
  }

  .mv-card__body {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-gray);
    max-width: 480px;
    margin-inline: auto;
  }

  @media (min-width: 640px) {
    .mv-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Stats Strip */
  .stats-strip {
    background-color: var(--color-navy);
    padding: 40px 0;
  }

  .stats-strip__inner {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    text-align: center;
  }

  .stat__number {
    display: block;
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-gold);
    line-height: 1.2;
  }

  .stat__label {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(245, 239, 229, 0.7);
    margin-top: 4px;
    letter-spacing: 0.02em;
  }

  @media (min-width: 640px) {
    .stats-strip__inner {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Strategy Timeline */
  .timeline {
    position: relative;
    max-width: 720px;
    margin-inline: auto;
    padding-left: 32px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background-color: rgba(198, 160, 50, 0.3);
  }

  .timeline__item {
    position: relative;
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 16px;
    padding-bottom: 36px;
  }

  .timeline__item:last-child {
    padding-bottom: 0;
  }

  .timeline__marker {
    position: absolute;
    left: -32px;
    top: 4px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background-color: var(--color-linen);
    border: 2px solid var(--color-gold);
    z-index: 1;
  }

  .timeline__marker--active {
    background-color: var(--color-gold);
    box-shadow: 0 0 0 4px rgba(198, 160, 50, 0.2);
  }

  .timeline__date {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .timeline__year {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-navy);
  }

  .timeline__content h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 6px;
  }

  .timeline__content p {
    font-family: var(--font-body);
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--color-gray);
  }

  @media (max-width: 640px) {
    .timeline__item {
      grid-template-columns: 1fr;
      gap: 4px;
    }
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-component);
  }

  .section-header h2 {
    margin-top: 8px;
  }

  /* Patron */
  .patron-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-component);
    align-items: start;
  }

  .patron-section__image img {
    width: 100%;
    max-width: 400px;
    border-radius: 3px;
  }

  .patron-section__text h2 {
    margin: 8px 0 12px;
  }

  .patron-section__text p {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-gray);
    margin-bottom: 12px;
  }

  /* Crest Block */
  .crest-block__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
    max-width: 860px;
    margin-inline: auto;
  }

  .crest-block__image {
    text-align: center;
  }

  .crest-block__img {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    border: 3px solid rgba(184, 154, 71, 0.3);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .crest-block__text h2 {
    margin: 8px 0 20px;
  }

  .crest-block__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .crest-block__list li {
    font-family: var(--font-body);
    font-size: 1rem;
    color: rgba(245, 239, 229, 0.85);
    line-height: 1.5;
    padding-left: 20px;
    position: relative;
  }

  .crest-block__list li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: var(--color-gold);
    font-size: 0.7rem;
    top: 4px;
  }

  .crest-block__list li strong {
    color: var(--color-gold);
  }

  @media (min-width: 768px) {
    .crest-block__inner {
      grid-template-columns: auto 1fr;
    }

    .crest-block__img {
      width: 240px;
      height: 240px;
    }
  }

  @media (min-width: 768px) {
    .patron-section {
      grid-template-columns: 1fr 1.5fr;
    }
  }

  /* About Nav */
  .about-nav {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .about-nav__card {
    display: block;
    background-color: var(--color-parchment);
    border: 1px solid rgba(90, 90, 110, 0.1);
    border-radius: 3px;
    padding: 24px;
    text-decoration: none;
    transition: box-shadow var(--transition-base);
    position: relative;
  }

  .about-nav__card:hover {
    box-shadow: 0 4px 16px rgba(14, 51, 82, 0.08);
  }

  .about-nav__card h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 4px;
  }

  .about-nav__card p {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-gray);
    line-height: 1.5;
  }

  .about-nav__arrow {
    position: absolute;
    right: 24px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.2rem;
    color: var(--color-gold);
  }

  @media (min-width: 640px) {
    .about-nav {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .about-nav {
      grid-template-columns: repeat(3, 1fr);
    }
    .about-nav__arrow {
      position: static;
      display: block;
      margin-top: 8px;
      transform: none;
    }
  }

  .section--linen {
    background-color: var(--color-linen);
  }
</style>
