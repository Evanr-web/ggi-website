<script is:inline>
  (function () {
    // Generic expand/collapse
    function wireToggle(btnSelector, panelId, openLabel, closeLabel) {
      var btn = document.querySelector(btnSelector);
      var panel = document.getElementById(panelId);
      if (!btn || !panel) return;
      btn.addEventListener('click', function () {
        var expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
        panel.hidden = expanded;
        btn.firstChild.textContent = expanded ? openLabel + ' ' : closeLabel + ' ';
      });
    }
    wireToggle('.video-more__toggle', 'video-more-grid', 'View More', 'View Less');
    wireToggle('.books-more__toggle', 'books-more-list', 'See All Books', 'Show Less');
  })();
</script>
