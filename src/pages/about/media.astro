---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import { getMediaPage } from '../../lib/sanity';
import { toHTML } from '@portabletext/to-html';

const base = import.meta.env.BASE_URL;
const media = await getMediaPage();

// Helper: extract YouTube embed ID from various URL formats
function ytId(url: string): string {
  if (!url) return '';
  try {
    const u = new URL(url);
    if (u.hostname.includes('youtu.be')) return u.pathname.slice(1);
    return u.searchParams.get('v') || '';
  } catch {
    return url; // fallback: treat as raw ID
  }
}

// Split videos into visible + expandable
const visibleCount = media?.videosVisibleCount ?? 3;
const allVideos = media?.videos ?? [];
const visibleVideos = allVideos.slice(0, visibleCount);
const expandableVideos = allVideos.slice(visibleCount);

// Split books into visible + expandable
const booksVisible = media?.booksVisibleCount ?? 5;
const allBooks = media?.books ?? [];
const visibleBooks = allBooks.slice(0, booksVisible);
const expandableBooks = allBooks.slice(booksVisible);

// Fallback hero image
const heroImg = media?.heroImage || `${base}images/art/school-of-athens.jpg`;
---

<BaseLayout title="Media & Press" description="Dr. Ryan Topping in the media — articles, interviews, videos, and press resources from the Gregory the Great Institute.">

  <!-- Hero -->
  <section class="hero-compact section--dark">
    <div class="hero-compact__bg" style={`background-image: url(${heroImg})`}></div>
    <div class="hero-compact__overlay"></div>
    <div class="hero-compact__content container">
      <h1 data-pagefind-weight="10" class="display">{media?.heroTitle || 'Media & Press'}</h1>
      <p class="hero-compact__subtitle">{media?.heroSubtitle || 'Articles, interviews, and press resources'}</p>
    </div>
  </section>

  <!-- ============================================
       Section 1: FEATURED VIDEO
       ============================================ -->
  {media?.featuredVideoUrl && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <p class="label text-gold">Watch</p>
          <h2>Featured</h2>
        </div>

        <div class="media-featured reveal">
          <div class="media-featured__video">
            <div class="video-embed">
              <iframe
                src={`https://www.youtube.com/embed/${ytId(media.featuredVideoUrl)}`}
                title={media.featuredVideoTitle || 'Featured Video'}
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
          </div>
          <div class="media-featured__text">
            {media.featuredVideoTitle && <h3>{media.featuredVideoTitle}</h3>}
            {media.featuredVideoDescription && <p>{media.featuredVideoDescription}</p>}
            {media.featuredVideoMeta && <p class="media-featured__meta">{media.featuredVideoMeta}</p>}
          </div>
        </div>
      </div>
    </section>
  )}

  {media?.featuredVideoUrl && <SectionDivider />}

  <!-- ============================================
       Section 2: VIDEO APPEARANCES
       ============================================ -->
  {visibleVideos.length > 0 && (
    <section class="section section--linen">
      <div class="container">
        <div class="section-header">
          <p class="label text-gold">{media?.videosLabel || 'Video'}</p>
          <h2>{media?.videosHeading || 'Interviews & Talks'}</h2>
        </div>

        <div class="video-grid reveal-stagger">
          {visibleVideos.map((v: any) => (
            <div class="video-card reveal">
              <div class="video-embed video-embed--card">
                <iframe
                  src={`https://www.youtube.com/embed/${ytId(v.youtubeUrl)}`}
                  title={v.title}
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                ></iframe>
              </div>
              <div class="video-card__info">
                <h3>{v.title}</h3>
                {v.meta && <p class="video-card__meta">{v.meta}</p>}
              </div>
            </div>
          ))}
        </div>

        {expandableVideos.length > 0 && (
          <div class="video-more">
            <button class="video-more__toggle" aria-expanded="false" aria-controls="video-more-grid">
              View More <span class="video-more__icon">▼</span>
            </button>
            <div class="video-more__panel" id="video-more-grid" hidden>
              <div class="video-grid">
                {expandableVideos.map((v: any) => (
                  <div class="video-card">
                    <div class="video-embed video-embed--card">
                      <iframe
                        src={`https://www.youtube.com/embed/${ytId(v.youtubeUrl)}`}
                        title={v.title}
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen
                        loading="lazy"
                      ></iframe>
                    </div>
                    <div class="video-card__info">
                      <h3>{v.title}</h3>
                      {v.meta && <p class="video-card__meta">{v.meta}</p>}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}

        {media?.videosNote && <p class="media-note">{media.videosNote}</p>}
      </div>
    </section>
  )}

  {visibleVideos.length > 0 && <SectionDivider />}

  <!-- ============================================
       Section 3: AS SEEN IN
       ============================================ -->
  {media?.outlets?.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <p class="label text-gold">{media?.outletsLabel || 'Appearances'}</p>
          <h2>{media?.outletsHeading || 'As Seen In'}</h2>
        </div>

        <div class="outlet-grid reveal">
          {media.outlets.map((o: any, i: number) => {
            const isLarge = i < 2;
            if (o.url) {
              return (
                <a href={o.url} target="_blank" rel="noopener" class={`outlet-tag outlet-tag--link${isLarge ? ' outlet-tag--large' : ''}`}>
                  {o.name}
                </a>
              );
            }
            return (
              <span class={`outlet-tag${isLarge ? ' outlet-tag--large' : ''}`}>{o.name}</span>
            );
          })}
        </div>
      </div>
    </section>
  )}

  {media?.outlets?.length > 0 && <SectionDivider />}

  <!-- ============================================
       Section 4: BOOKS
       ============================================ -->
  {visibleBooks.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <p class="label text-gold">{media?.booksLabel || 'Books'}</p>
          <h2>{media?.booksHeading || 'Selected Publications by Dr. Topping'}</h2>
        </div>

        <div class="books-grid reveal-stagger">
          {visibleBooks.map((b: any) => {
            const Tag = b.url ? 'a' : 'div';
            const linkProps = b.url ? { href: b.url, target: '_blank', rel: 'noopener' } : {};
            return (
              <a href={b.url || undefined} target={b.url ? '_blank' : undefined} rel={b.url ? 'noopener' : undefined} class={`book-item${b.url ? ' book-item--link' : ''} reveal`}>
                <div class="book-item__spine"></div>
                <div class="book-item__content">
                  <h3>{b.title}</h3>
                  {b.subtitle && <p class="book-item__subtitle">{b.subtitle}</p>}
                  {b.note && <p class="book-item__note">{b.note}</p>}
                </div>
              </a>
            );
          })}
        </div>

        {expandableBooks.length > 0 && (
          <div class="books-more">
            <button class="books-more__toggle" aria-expanded="false" aria-controls="books-more-list">
              See All Books <span class="books-more__icon">▼</span>
            </button>
            <div class="books-more__panel" id="books-more-list" hidden>
              <div class="books-grid">
                {expandableBooks.map((b: any) => (
                  <a href={b.url || undefined} target={b.url ? '_blank' : undefined} rel={b.url ? 'noopener' : undefined} class={`book-item${b.url ? ' book-item--link' : ''}`}>
                    <div class="book-item__spine"></div>
                    <div class="book-item__content">
                      <h3>{b.title}</h3>
                      {b.subtitle && <p class="book-item__subtitle">{b.subtitle}</p>}
                      {b.note && <p class="book-item__note">{b.note}</p>}
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        )}

        {media?.booksTotalCount && (
          <p class="books-count">Author of <strong>{media.booksTotalCount} books</strong> {media.booksCountNote || ''}</p>
        )}
      </div>
    </section>
  )}

  {visibleBooks.length > 0 && <SectionDivider />}

  <!-- ============================================
       Section 5: PRESS KIT
       ============================================ -->
  <section class="section section--linen">
    <div class="container">
      <div class="section-header">
        <p class="label text-gold">{media?.pressKitLabel || 'For Journalists & Partners'}</p>
        <h2>{media?.pressKitHeading || 'Press Kit'}</h2>
      </div>

      <div class="press-kit">
        <!-- Boilerplate -->
        {media?.pressKitBoilerplate && (
          <div class="press-kit__section reveal">
            <h3>{media.pressKitBoilerplateTitle || 'About the Gregory the Great Institute'}</h3>
            <div class="press-kit__boilerplate">
              <Fragment set:html={toHTML(media.pressKitBoilerplate)} />
            </div>
          </div>
        )}

        <!-- Key Facts -->
        {media?.keyFacts?.length > 0 && (
          <div class="press-kit__section reveal">
            <h3>Key Facts</h3>
            <ul class="press-kit__facts">
              {media.keyFacts.map((f: any) => (
                <li>
                  <strong>{f.label}:</strong>{' '}
                  {f.url ? <a href={f.url}>{f.value}</a> : f.value}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Downloads -->
        {media?.downloads?.length > 0 && (
          <div class="press-kit__section reveal">
            <h3>Downloads</h3>
            <div class="press-kit__downloads">
              {media.downloads.map((d: any) => {
                const href = d.fileUrl || d.externalUrl;
                return href ? (
                  <a href={href} download={d.fileUrl ? true : undefined} target={d.externalUrl ? '_blank' : undefined} rel={d.externalUrl ? 'noopener' : undefined} class="download-item">
                    <span class="download-item__icon">⬇</span>
                    <div>
                      <span class="download-item__name">{d.name}</span>
                      {d.meta && <span class="download-item__meta">{d.meta}</span>}
                    </div>
                  </a>
                ) : null;
              })}
            </div>
          </div>
        )}

        <!-- Brand Colors -->
        {media?.brandColors?.length > 0 && (
          <div class="press-kit__section reveal">
            <h3>Brand</h3>
            <div class="brand-colors">
              {media.brandColors.map((c: any) => (
                <div class={`brand-swatch${c.light ? ' brand-swatch--light' : ''}`} style={`background-color: ${c.hex};`}>
                  <span class="brand-swatch__label">{c.name}</span>
                  <span class="brand-swatch__hex">{c.hex}</span>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- ============================================
       Section 6: SPEAKING & CONTACT
       ============================================ -->
  <section class="section">
    <div class="container media-cta">
      <div class="media-cta__inner reveal">
        <img
          src={media?.speakerPhoto || `${base}images/people/Ryan-Topping-headshot.jpg`}
          alt={media?.speakingHeading || 'Dr. Ryan Topping'}
          class="media-cta__photo"
        />
        <div class="media-cta__text">
          <p class="label text-gold">{media?.speakingLabel || 'Speaking & Media'}</p>
          <h2>{media?.speakingHeading || 'Invite Dr. Topping'}</h2>
          {media?.speakingDescription && <p>{media.speakingDescription}</p>}
          {media?.speakingTopics && (
            <p class="media-cta__topics">
              <strong>Topics include:</strong> {media.speakingTopics}
            </p>
          )}
          <div class="media-cta__buttons">
            <Button href={media?.speakingButtonUrl || `${base}contact/`} variant="primary">
              {media?.speakingButtonText || 'Request a Speaking Engagement'}
            </Button>
            {media?.speakingEmail && (
              <a href={`mailto:${media.speakingEmail}`} class="media-cta__email">{media.speakingEmail}</a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Back to About -->
  <section class="section section--linen" style="padding-block: 32px;">
    <div class="container" style="text-align: center;">
      <Button href={`${base}about/`} variant="secondary">← Back to About</Button>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero-compact {
    position: relative;
    min-height: 360px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-compact__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }

  .hero-compact__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(14, 51, 82, 0.75);
  }

  .hero-compact__content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    padding-block: 60px;
  }

  .hero-compact__content h1 {
    color: var(--color-text-on-dark);
    margin-bottom: 12px;
  }

  .hero-compact__subtitle {
    font-family: var(--font-body);
    font-size: 1.15rem;
    color: rgba(245, 239, 229, 0.85);
  }

  /* Section header */
  .section-header {
    text-align: center;
    margin-bottom: var(--space-component);
  }

  .section-header h2 {
    margin-top: 8px;
  }

  .section--linen {
    background-color: var(--color-linen);
  }

  /* Featured Video */
  .media-featured {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
    align-items: center;
    max-width: 900px;
    margin-inline: auto;
  }

  .video-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 3px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
  }

  .video-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .media-featured__text h3 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 8px;
  }

  .media-featured__text p {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-gray);
  }

  .media-featured__meta {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-gold);
    margin-top: 8px;
  }

  @media (min-width: 768px) {
    .media-featured {
      grid-template-columns: 1.4fr 1fr;
    }
  }

  /* Video Grid */
  .video-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    max-width: 900px;
    margin-inline: auto;
  }

  .video-card {
    background-color: var(--color-parchment);
    border: 1px solid rgba(90, 90, 110, 0.08);
    border-radius: 3px;
    overflow: hidden;
  }

  .video-embed--card {
    box-shadow: none;
    border-radius: 0;
  }

  .video-card__info {
    padding: 16px 20px;
  }

  .video-card__info h3 {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 4px;
  }

  .video-card__meta {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: var(--color-gold);
  }

  @media (min-width: 640px) {
    .video-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .video-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .media-note {
    text-align: center;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-style: italic;
    color: var(--color-gray);
    margin-top: 24px;
  }

  /* View More toggle */
  .video-more {
    text-align: center;
    margin-top: 28px;
  }

  .video-more__toggle {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-gold);
    background: none;
    border: 1px solid var(--color-gold);
    border-radius: 3px;
    padding: 10px 28px;
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s;
  }

  .video-more__toggle:hover {
    background-color: var(--color-gold);
    color: var(--color-parchment, #f5efe5);
  }

  .video-more__icon {
    display: inline-block;
    font-size: 0.7rem;
    margin-left: 6px;
    transition: transform 0.2s;
  }

  .video-more__toggle[aria-expanded="true"] .video-more__icon {
    transform: rotate(180deg);
  }

  .video-more__panel {
    margin-top: 24px;
  }

  /* Outlet Grid (As Seen In) */
  .outlet-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    max-width: 700px;
    margin-inline: auto;
  }

  .outlet-tag {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    padding: 12px 28px;
    background-color: var(--color-parchment);
    border: 1px solid var(--color-gold);
    border-radius: 3px;
    color: var(--color-navy);
  }

  .outlet-tag--large {
    font-size: 1.1rem;
    padding: 14px 32px;
  }

  a.outlet-tag--link {
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.15s, background-color 0.15s, transform 0.15s;
  }

  a.outlet-tag--link:hover {
    background-color: rgba(184, 154, 71, 0.12);
    transform: translateY(-2px);
  }

  /* Books */
  .books-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 640px;
    margin-inline: auto;
  }

  .book-item {
    display: flex;
    background-color: var(--color-linen);
    border: 1px solid rgba(90, 90, 110, 0.08);
    border-radius: 3px;
    overflow: hidden;
  }

  .book-item__spine {
    width: 6px;
    flex-shrink: 0;
    background-color: var(--color-crimson);
  }

  .book-item__content {
    padding: 16px 20px;
  }

  .book-item h3 {
    font-family: var(--font-display);
    font-size: 1.02rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 2px;
  }

  .book-item__subtitle {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-style: italic;
    color: var(--color-gray);
    line-height: 1.4;
  }

  .book-item__note {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-gold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 4px;
  }

  a.book-item--link {
    text-decoration: none;
    transition: border-color 0.15s, transform 0.15s;
  }

  a.book-item--link:hover {
    border-color: var(--color-gold);
    transform: translateX(4px);
  }

  /* See All Books toggle */
  .books-more {
    text-align: center;
    margin-top: 20px;
  }

  .books-more__toggle {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-gold);
    background: none;
    border: 1px solid var(--color-gold);
    border-radius: 3px;
    padding: 10px 28px;
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s;
  }

  .books-more__toggle:hover {
    background-color: var(--color-gold);
    color: var(--color-parchment, #f5efe5);
  }

  .books-more__icon {
    display: inline-block;
    font-size: 0.7rem;
    margin-left: 6px;
    transition: transform 0.2s;
  }

  .books-more__toggle[aria-expanded="true"] .books-more__icon {
    transform: rotate(180deg);
  }

  .books-more__panel {
    margin-top: 16px;
  }

  .books-count {
    text-align: center;
    margin-top: 20px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-gray);
  }

  /* Press Kit */
  .press-kit {
    max-width: 760px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .press-kit__section h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(184, 154, 71, 0.2);
  }

  .press-kit__boilerplate p,
  .press-kit__boilerplate :global(p) {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--color-gray);
    margin-bottom: 12px;
  }

  .press-kit__facts {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .press-kit__facts li {
    font-family: var(--font-body);
    font-size: 0.92rem;
    color: var(--color-gray);
    line-height: 1.5;
  }

  .press-kit__facts a {
    color: var(--color-gold);
    text-decoration: none;
  }

  /* Downloads */
  .press-kit__downloads {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .download-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 18px;
    background-color: var(--color-parchment);
    border: 1px solid rgba(90, 90, 110, 0.1);
    border-radius: 3px;
    text-decoration: none;
    transition: border-color var(--transition-base);
  }

  .download-item:hover {
    border-color: var(--color-gold);
  }

  .download-item__icon {
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .download-item__name {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-navy);
  }

  .download-item__meta {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--color-gray);
  }

  @media (min-width: 640px) {
    .press-kit__downloads {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Brand Colors */
  .brand-colors {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .brand-swatch {
    width: 100px;
    height: 80px;
    border-radius: 3px;
