---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import SectionDivider from '../../components/SectionDivider.astro';
---

<BaseLayout title="Impact Report" description="Annual impact report of the Gregory the Great Institute — key achievements, financial stewardship, and organizational growth.">

  <!-- Hero -->
  <section class="section--dark" style="padding: 60px 0; text-align: center;">
    <div class="container">
      <p class="label text-gold">Transparency & Stewardship</p>
      <h1 class="display" style="color: var(--color-text-on-dark); margin-top: 8px;">Impact Report</h1>
      <p style="font-family: var(--font-body); font-size: 1.05rem; color: rgba(245,239,229,0.8); margin-top: 8px;">How your support is building Catholic culture in Canada.</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="section">
    <div class="container impact-intro">
      <p>
        Our Annual Impact Report highlights key achievements, financial stewardship, and organizational
        growth over the past year. We invite you to download the full report to learn more about our
        mission in action.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats-strip">
    <div class="container stats-strip__inner reveal">
      <div class="stat">
        <span class="stat__number">1,500+</span>
        <span class="stat__label">Community Members</span>
      </div>
      <div class="stat">
        <span class="stat__number">4</span>
        <span class="stat__label">Provinces Reached</span>
      </div>
      <div class="stat">
        <span class="stat__number">6</span>
        <span class="stat__label">Active Programs</span>
      </div>
      <div class="stat">
        <span class="stat__number">11</span>
        <span class="stat__label">Books Published by Director</span>
      </div>
    </div>
  </section>

  <!-- Report Highlights -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="label text-gold">2025 Report</p>
        <h2>Year in Review</h2>
      </div>
      <div class="highlights-grid">
        <div class="highlight-card">
          <div class="highlight-card__icon">📖</div>
          <h3>Formation</h3>
          <p>Book studies launched across multiple provinces, with over 76 registered participants in the inaugural series.</p>
        </div>
        <div class="highlight-card">
          <div class="highlight-card__icon">🎓</div>
          <h3>Courses</h3>
          <p>Masterclasses and the Faith and Reason Seminar brought the Great Tradition to leaders across Western Canada.</p>
        </div>
        <div class="highlight-card">
          <div class="highlight-card__icon">📰</div>
          <h3>Publications</h3>
          <p><em>Magnalia</em> journal reached every Catholic bishop and seminary rector in Canada — 60 pages of essays, letters, and art.</p>
        </div>
        <div class="highlight-card">
          <div class="highlight-card__icon">🎵</div>
          <h3>Youth Programs</h3>
          <p>St. Gregory's Music and Leadership Camp welcomed young Canadians for formation in sacred and folk music traditions.</p>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- Download CTA -->
  <section class="section section--linen" style="text-align: center;">
    <div class="container">
      <h2>Download the Full Report</h2>
      <p style="max-width: 560px; margin-inline: auto; font-family: var(--font-body); font-size: 1rem; line-height: 1.7; color: var(--color-gray); margin-bottom: 24px;">
        The 2025 Annual Impact Report is now available. See the full picture of what God is doing through
        the Gregory the Great Institute.
      </p>
      <div class="cta-buttons">
        <Button href="#" variant="primary">Download the Report</Button>
        <Button href={`${import.meta.env.BASE_URL}about/`} variant="secondary">← Back to About</Button>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Intro */
  .impact-intro {
    max-width: 700px;
    margin-inline: auto;
    text-align: center;
  }

  .impact-intro p {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--color-gray);
  }

  /* Stats */
  .stats-strip {
    background-color: var(--color-navy);
    padding: 40px 0;
  }

  .stats-strip__inner {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    text-align: center;
  }

  .stat__number {
    display: block;
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-gold);
    line-height: 1.2;
  }

  .stat__label {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(245, 239, 229, 0.7);
    margin-top: 4px;
    letter-spacing: 0.02em;
  }

  @media (min-width: 640px) {
    .stats-strip__inner {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Section header */
  .section-header {
    text-align: center;
    margin-bottom: var(--space-component);
  }

  .section-header h2 {
    margin-top: 8px;
  }

  /* Highlights */
  .highlights-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    max-width: 900px;
    margin-inline: auto;
  }

  .highlight-card {
    padding: 28px 24px;
    background-color: var(--color-linen);
    border: 1px solid rgba(90, 90, 110, 0.08);
    border-radius: 3px;
    text-align: center;
  }

  .highlight-card__icon {
    font-size: 2rem;
    margin-bottom: 12px;
  }

  .highlight-card h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 8px;
  }

  .highlight-card p {
    font-family: var(--font-body);
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--color-gray);
  }

  @media (min-width: 640px) {
    .highlights-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* CTA */
  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  .section--linen {
    background-color: var(--color-linen);
  }
</style>
