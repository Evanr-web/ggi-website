---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import SectionDivider from '../../components/SectionDivider.astro';
---

<BaseLayout title="Impact Report" description="Annual impact report of the Gregory the Great Institute — key achievements, financial stewardship, and organizational growth.">

  <!-- Hero -->
  <section class="section--dark" style="padding: 60px 0; text-align: center;">
    <div class="container">
      <p class="label text-gold">Transparency & Stewardship</p>
      <h1 class="display" style="color: var(--color-text-on-dark); margin-top: 8px;">Impact Report</h1>
      <p style="font-family: var(--font-body); font-size: 1.05rem; color: rgba(245,239,229,0.8); margin-top: 8px;">How your support is building Catholic culture in Canada.</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="section">
    <div class="container impact-intro reveal">
      <p>
        Our Annual Impact Report highlights key achievements, financial stewardship, and organizational
        growth over the past year. We invite you to download the full report to learn more about our
        mission in action.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats-strip">
    <div class="container stats-strip__inner reveal">
      <div class="stat">
        <span class="stat__number">1,500+</span>
        <span class="stat__label">Community Members</span>
      </div>
      <div class="stat">
        <span class="stat__number">4</span>
        <span class="stat__label">Provinces Reached</span>
      </div>
      <div class="stat">
        <span class="stat__number">6</span>
        <span class="stat__label">Active Programs</span>
      </div>
      <div class="stat">
        <span class="stat__number">11</span>
        <span class="stat__label">Books Published by Director</span>
      </div>
    </div>
  </section>

  <!-- Report Highlights -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="label text-gold">2025 Report</p>
        <h2>Year in Review</h2>
      </div>
      <div class="highlights-grid reveal-stagger">
        <div class="highlight-card reveal">
          <div class="highlight-card__accent"></div>
          <div class="highlight-card__body">
            <p class="label text-gold">Formation</p>
            <h3>Book Studies</h3>
            <p>Launched across multiple provinces, with over 76 registered participants in the inaugural series.</p>
          </div>
        </div>
        <div class="highlight-card reveal">
          <div class="highlight-card__accent"></div>
          <div class="highlight-card__body">
            <p class="label text-gold">Courses</p>
            <h3>Masterclasses & Seminars</h3>
            <p>The Faith and Reason Seminar brought the Great Tradition to leaders across Western Canada.</p>
          </div>
        </div>
        <div class="highlight-card reveal">
          <div class="highlight-card__accent"></div>
          <div class="highlight-card__body">
            <p class="label text-gold">Publications</p>
            <h3>Magnalia Journal</h3>
            <p>Reached every Catholic bishop and seminary rector in Canada — 60 pages of essays, letters, and art.</p>
          </div>
        </div>
        <div class="highlight-card reveal">
          <div class="highlight-card__accent"></div>
          <div class="highlight-card__body">
            <p class="label text-gold">Youth</p>
            <h3>Music & Leadership Camp</h3>
            <p>St. Gregory's Camp welcomed young Canadians for formation in sacred and folk music traditions.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- Download CTA -->
  <section class="section section--linen" style="text-align: center;">
    <div class="container">
      <h2>Download the Full Report</h2>
      <p style="max-width: 560px; margin-inline: auto; font-family: var(--font-body); font-size: 1rem; line-height: 1.7; color: var(--color-gray); margin-bottom: 24px;">
        The 2025 Annual Impact Report is now available. See the full picture of what God is doing through
        the Gregory the Great Institute.
      </p>
      <div class="cta-buttons">
        <a href="https://adbcbf1f-fcf5-4099-8aa0-1d9b99602ff4.filesusr.com/ugd/437a61_b4dc2d74f545432ab3b84d43635c636c.pdf" target="_blank" rel="noopener" class="btn-download">Download the Report</a>
      </div>
    </div>
  </section>

  <!-- What's Next — Conversion Block -->
  <section class="section">
    <div class="container next-section">
      <div class="next-header reveal">
        <p class="label text-gold">What Comes Next</p>
        <h2>Year Two Is Being Built Right Now</h2>
        <p class="next-lead">
          Everything you just read happened in twelve months with a small team and a lean budget.
          With your support, Year Two brings a second issue of Magnalia, expanded Book Studies coast
          to coast, the Renewing Culture Conference, new masterclasses, and the groundwork for a
          Catholic think-tank. The question is not whether the mission is working. It's whether
          enough people will join it.
        </p>
      </div>

      <div class="next-paths reveal-stagger">
        <a href={`${import.meta.env.BASE_URL}support/friend/`} class="next-card reveal">
          <p class="label text-gold">$15+/month</p>
          <h3>Become a Friend</h3>
          <p class="next-card__desc">
            Monthly prayer inclusion, digital Magnalia, early event access, and named recognition.
            The foundation for anyone who believes Catholic culture in Canada is worth rebuilding.
          </p>
          <span class="next-card__action">Join as a Friend →</span>
        </a>
        <a href={`${import.meta.env.BASE_URL}magnalia/patron/`} class="next-card next-card--featured reveal">
          <p class="label text-gold">$50+/month · $600+/year</p>
          <h3>Become a Patron</h3>
          <p class="next-card__desc">
            The backbone of the Institute. Print Magnalia subscription, annual gathering
            with Dr. Topping, named recognition in Magnalia, and a signed book.
          </p>
          <span class="next-card__action">Join as a Patron →</span>
        </a>
        <a href={`${import.meta.env.BASE_URL}support/leadership/`} class="next-card reveal">
          <p class="label text-gold">$5,000+/year</p>
          <h3>Join the Leadership Circle</h3>
          <p class="next-card__desc">
            An annual one-on-one conversation with Dr. Topping. Strategic partnership in building
            Catholic intellectual infrastructure — the think-tank, trade school, and certificate programs.
          </p>
          <span class="next-card__action">Request a Conversation →</span>
        </a>
      </div>

      <div class="next-footer reveal">
        <Button href={`${import.meta.env.BASE_URL}about/`} variant="secondary">← Back to About</Button>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Intro */
  .impact-intro {
    max-width: 700px;
    margin-inline: auto;
    text-align: center;
  }

  .impact-intro p {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--color-gray);
  }

  /* Stats */
  .stats-strip {
    background-color: var(--color-navy);
    padding: 40px 0;
  }

  .stats-strip__inner {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    text-align: center;
  }

  .stat__number {
    display: block;
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-gold);
    line-height: 1.2;
  }

  .stat__label {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(245, 239, 229, 0.7);
    margin-top: 4px;
    letter-spacing: 0.02em;
  }

  @media (min-width: 640px) {
    .stats-strip__inner {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Section header */
  .section-header {
    text-align: center;
    margin-bottom: var(--space-component);
  }

  .section-header h2 {
    margin-top: 8px;
  }

  /* Highlights */
  .highlights-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    max-width: 900px;
    margin-inline: auto;
  }

  .highlight-card {
    display: flex;
    background-color: var(--color-parchment);
    border: 1px solid rgba(90, 90, 110, 0.08);
    border-radius: 3px;
    overflow: hidden;
  }

  .highlight-card__accent {
    width: 5px;
    flex-shrink: 0;
    background-color: var(--color-gold);
  }

  .highlight-card__body {
    padding: 24px 20px;
  }

  .highlight-card h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-navy);
    margin: 6px 0 8px;
  }

  .highlight-card p:not(.label) {
    font-family: var(--font-body);
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--color-gray);
  }

  @media (min-width: 640px) {
    .highlights-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* CTA */
  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  .btn-download {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-parchment);
    background-color: var(--color-crimson);
    padding: 14px 32px;
    border-radius: 3px;
    text-decoration: none;
    transition: background-color var(--transition-fast);
  }

  .btn-download:hover {
    background-color: #6b2124;
    color: var(--color-parchment);
  }

  /* What's Next */
  .next-section {
    max-width: 960px;
    margin-inline: auto;
  }

  .next-header {
    text-align: center;
    max-width: 680px;
    margin-inline: auto;
    margin-bottom: var(--space-component);
  }

  .next-header h2 {
    margin: 8px 0 16px;
  }

  .next-lead {
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: 1.8;
    color: var(--color-gray);
  }

  .next-paths {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-bottom: 32px;
  }

  .next-card {
    display: block;
    text-decoration: none;
    padding: 28px 24px;
    background-color: var(--color-linen);
    border: 1px solid rgba(90, 90, 110, 0.1);
    border-radius: 3px;
    transition: border-color var(--transition-base), transform var(--transition-base), box-shadow var(--transition-base);
  }

  .next-card:hover {
    border-color: var(--color-gold);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(14, 51, 82, 0.08);
  }

  .next-card--featured {
    border: 2px solid var(--color-gold);
    background-color: white;
  }

  .next-card h3 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-navy);
    margin: 6px 0 10px;
  }

  .next-card__desc {
    font-family: var(--font-body);
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--color-gray);
    margin-bottom: 12px;
  }

  .next-card__action {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-gold);
  }

  @media (min-width: 768px) {
    .next-paths {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .next-footer {
    text-align: center;
  }

  .section--linen {
    background-color: var(--color-linen);
  }
</style>
