---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionDivider from '../../components/SectionDivider.astro';
---

<BaseLayout title="Leadership" description="Board of directors, staff, fellows, and advisory board of the Gregory the Great Institute.">

  <!-- Hero -->
  <section class="section--dark leadership-hero">
    <div class="container text-center">
      <h1 data-pagefind-weight="10" class="display heading-on-dark">Leadership</h1>
      <p class="leadership-hero__subtitle">The people building the Institute</p>
    </div>
  </section>

  <!-- Patron -->
  <section class="section">
    <div class="container">
      <div class="patron-featured patron-featured--centered">
        <img src={`${import.meta.env.BASE_URL}images/people/thomas-collins.jpg`} alt="Cardinal Thomas Collins" class="patron-featured__photo patron-featured__photo--large" />
        <p class="label text-gold">Patron</p>
        <h2>His Eminence Thomas Cardinal Collins</h2>
        <p class="patron-featured__bio">
          Cardinal Collins serves as Patron of the Gregory the Great Institute, lending his support and
          encouragement to the mission of Catholic cultural renewal in Canada.
        </p>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- Staff -->
  <section class="section">
    <div class="container">
      <h2 class="leadership-section__heading">Staff</h2>
      <div class="people-grid people-grid--staff">
        <div class="person-card person-card--large">
          <img src={`${import.meta.env.BASE_URL}images/people/Ryan-Topping-headshot.jpg`} alt="Dr. Ryan Topping" class="person-card__photo" />
          <h3>Dr. Ryan N.S. Topping</h3>
          <p class="person-card__role">Founding Executive Director</p>
          <div class="person-card__bio-expandable">
            <p class="person-card__bio">
              Dr. Topping is the founding Executive Director of the Gregory the Great Institute, a non-profit organization devoted to promoting cultural renewal in Canada. He is the author of over 10 books on Catholic education and culture. He holds a doctorate from the University of Oxford and is a recipient of the Queen Elizabeth II Platinum Jubilee Medal.
            </p>
            <input type="checkbox" id="topping-expand" class="expand-toggle" />
            <div class="expand-content">
              <p class="person-card__bio">
                In his professorial career he taught in the US and helped establish or lead three Catholic Studies programs in Canada, including while serving as Academic Dean. He has worked as a consultant to both provincial and federal elected officials. Dr. Topping and his wife have 10 children and are a founding family of Campion Classical Academy in Alberta. His most recent book is <em>Thinking as Though God Exists: Newman on Evangelizing the 'Nones'.</em> His YouTube Series launches during Easter 2026.
              </p>
            </div>
            <label for="topping-expand" class="expand-btn">Read more ↓</label>
          </div>
          <a href="mailto:rtopping@gregorythegreat.ca" class="person-card__email">rtopping@gregorythegreat.ca</a>
          <a href={`${import.meta.env.BASE_URL}about/founding-director/`} class="person-card__link">View full profile →</a>
        </div>
        <div class="person-card person-card--large">
          <img src={`${import.meta.env.BASE_URL}images/people/Catherine-Renneberg-headshot.jpg`} alt="Catherine Renneberg" class="person-card__photo" />
          <h3>Catherine Renneberg</h3>
          <p class="person-card__role">Director of Programs</p>
          <p class="person-card__bio">M.Div. from Newman Theological College. Serves on the Board of St. Therese Institute (Saskatchewan). Experience in church ministry across Western Canada.</p>
          <a href="mailto:crenneberg@gregorythegreat.ca" class="person-card__email">crenneberg@gregorythegreat.ca</a>
        </div>
        <div class="person-card person-card--large">
          <img src={`${import.meta.env.BASE_URL}images/people/Victor-Carpay-headshot.jpg`} alt="Victor Carpay" class="person-card__photo" />
          <h3>Victor Carpay</h3>
          <p class="person-card__role">Communications & Development</p>
          <p class="person-card__bio">Lifelong Albertan passionate about renewing culture through faith and reason. BA in Catholic Studies from Newman Theological College. Experience in sales, business, and political activism.</p>
          <a href="mailto:vcarpay@gregorythegreat.ca" class="person-card__email">vcarpay@gregorythegreat.ca</a>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- Board -->
  <section class="section section--linen">
    <div class="container">
      <h2 class="leadership-section__heading">Board of Directors</h2>
      <div class="board-chair">
        <img src={`${import.meta.env.BASE_URL}images/people/Ryan-Topping-headshot.jpg`} alt="Dr. Ryan Topping" class="board-chair__photo" />
        <h3>Dr. Ryan N.S. Topping</h3>
        <p class="person-card__role">Chair</p>
      </div>
      <div class="people-grid people-grid--board">
        <div class="person-card person-card--chair-desktop">
          <img src={`${import.meta.env.BASE_URL}images/people/Ryan-Topping-headshot.jpg`} alt="Dr. Ryan Topping" class="person-card__photo" />
          <h3>Dr. Ryan N.S. Topping</h3>
          <p class="person-card__role">Chair</p>
        </div>
        <div class="person-card">
          <img src={`${import.meta.env.BASE_URL}images/people/Brian-Holdsworth-headshot.jpg`} alt="Brian Holdsworth" class="person-card__photo" />
          <h3>Brian Holdsworth</h3>
          <p class="person-card__role">Director</p>
        </div>
        <div class="person-card">
          <img src={`${import.meta.env.BASE_URL}images/people/Celene-Sidloski-headshot.jpg`} alt="Dr. Celene Sidloski" class="person-card__photo" />
          <h3>Dr. Celene Sidloski</h3>
          <p class="person-card__role">Director</p>
        </div>
        <div class="person-card">
          <img src={`${import.meta.env.BASE_URL}images/people/Catherine-Renneberg-headshot.jpg`} alt="Catherine Renneberg" class="person-card__photo" />
          <h3>Catherine Renneberg</h3>
          <p class="person-card__role">Director</p>
        </div>
        <div class="person-card">
          <img src={`${import.meta.env.BASE_URL}images/people/Caleb-Ropp-headshot.jpg`} alt="Caleb Ropp" class="person-card__photo" style="object-position: center center;" />
          <h3>Caleb Ropp</h3>
          <p class="person-card__role">Director</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Fellows -->
  <section class="section">
    <div class="container">
      <h2 class="leadership-section__heading">Fellows</h2>
      <div class="people-grid people-grid--large">
        <div class="person-card person-card--large">
          <img src={`${import.meta.env.BASE_URL}images/people/Joe-Woodard-headshot.jpg`} alt="Dr. Joe Woodard" class="person-card__photo" />
          <h3>Dr. Joe Woodard</h3>
          <p class="person-card__role">Fellow · Calgary</p>
          <p class="person-card__bio">Ethics, bioethics, and Catholic social thought.</p>
        </div>
        <div class="person-card person-card--large">
          <img src={`${import.meta.env.BASE_URL}images/people/Celene-Sidloski-headshot.jpg`} alt="Dr. Celene Sidloski" class="person-card__photo" />
          <h3>Dr. Celene Sidloski</h3>
          <p class="person-card__role">Fellow · Saskatoon</p>
          <p class="person-card__bio">Classical education and Canadian Catholic intellectual life.</p>
        </div>
        <div class="person-card person-card--large">
          <img src={`${import.meta.env.BASE_URL}images/people/Mark-Ingham-headshot.jpg`} alt="Mark Ingham" class="person-card__photo" />
          <h3>Mark Ingham, PhD Cand.</h3>
          <p class="person-card__role">Fellow · Barry's Bay</p>
          <p class="person-card__bio">Vocations research and Canadian Catholic demographics.</p>
        </div>
        <div class="person-card person-card--large">
          <img src={`${import.meta.env.BASE_URL}images/people/Fr-Michael-Bombak-headshot.jpg`} alt="Fr. Michael Bombak" class="person-card__photo" />
          <h3>Fr. Michael Bombak</h3>
          <p class="person-card__role">Fellow · Toronto</p>
          <p class="person-card__bio">Theology, priesthood, and cultural renewal.</p>
        </div>
      </div>
      <p class="text-center leadership-fellows-link">
        <a href={`${import.meta.env.BASE_URL}magnalia/contributors/`} class="back-link">Our Fellows also contribute to Magnalia →</a>
      </p>
    </div>
  </section>

  <SectionDivider />

  <!-- Advisory Board -->
  <section class="section section--linen">
    <div class="container">
      <h2 class="leadership-section__heading">Advisory Board</h2>
      <div class="advisory-list">
        <div class="advisory-item">
          <img src={`${import.meta.env.BASE_URL}images/people/Jeff-Lockert-headshot.jpg`} alt="Jeff Lockert" class="advisory-item__photo" />
          <div>
            <h3>Jeff Lockert</h3>
            <p>President, CCO Canada</p>
          </div>
        </div>
        <div class="advisory-item">
          <img src={`${import.meta.env.BASE_URL}images/people/Andrew-Bennett-headshot.jpg`} alt="Fr Dcn Andrew Bennett" class="advisory-item__photo" />
          <div>
            <h3>Fr Dcn Andrew Bennett</h3>
            <p>Cardus · Formerly Canadian Ambassador for Religious Freedom</p>
          </div>
        </div>
        <div class="advisory-item">
          <img src={`${import.meta.env.BASE_URL}images/people/Keith-Cassidy-headshot.jpg`} alt="Dr. Keith Cassidy" class="advisory-item__photo" />
          <div>
            <h3>Dr. Keith Cassidy</h3>
            <p>Past President and Chair of the Board, Seat of Wisdom College</p>
          </div>
        </div>
        <div class="advisory-item">
          <img src={`${import.meta.env.BASE_URL}images/people/Alane-Boudreau-headshot.jpg`} alt="Alane Boudreau" class="advisory-item__photo" />
          <div>
            <h3>Alane Boudreau</h3>
            <p>Founding Board Member, St John Choir Schola, Calgary</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Subcommittees -->
  <section class="section">
    <div class="container">
      <h2 class="leadership-section__heading">Board Subcommittees</h2>
      <div class="committees">
        <div class="committee">
          <h3>Fundraising Committee</h3>
          <ul>
            <li><strong>Chair:</strong> Caleb Ropp</li>
            <li><strong>Vice-Chair:</strong> Evan Ropp</li>
            <li><strong>Secretary:</strong> Jesse Underwood</li>
            <li>Kyle King, Annie Engler, Thierry Karikurubu</li>
          </ul>
        </div>
        <div class="committee">
          <h3>Programs Committee</h3>
          <ul>
            <li><strong>Chair:</strong> Dr. Celene Sidloski</li>
            <li><strong>Vice-Chair:</strong> Ian Mahood</li>
            <li><strong>Secretary:</strong> Nicholas Kunysz</li>
            <li>Patrick Schiller, Peter Csillag</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Leadership Hero */
  .leadership-hero { padding: 60px 0; }
  .leadership-hero__subtitle {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: rgba(245, 239, 229, 0.8);
    margin-top: 8px;
  }
  .leadership-section__heading { margin-bottom: 24px; }
  .leadership-fellows-link { margin-top: 24px; }

  /* People Grid */
  .people-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .people-grid.people-grid--staff {
    grid-template-columns: 1fr;
  }

  .person-card {
    text-align: center;
    padding: 20px 12px;
  }

  .person-card--large {
    text-align: center;
    padding: 28px;
    background-color: var(--color-linen);
    border: 1px solid rgba(90, 90, 110, 0.08);
    border-radius: 3px;
  }

  .person-card__photo {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    margin-bottom: 12px;
    display: block;
    margin-inline: auto;
  }

  .person-card--large .person-card__photo {
    width: 96px;
    height: 96px;
  }

  .person-card__photo--placeholder {
    background-color: var(--color-ivory);
    display: block;
    margin-inline: auto;
  }

  .person-card h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 2px;
  }

  .person-card__role {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-gold);
    margin-bottom: 8px;
  }

  .person-card__bio {
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--color-gray);
    line-height: 1.5;
    margin-bottom: 8px;
  }

  /* Expandable bio */
  .person-card__bio-expandable {
    margin-bottom: 8px;
  }

  .expand-toggle {
    display: none;
  }

  .expand-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .expand-toggle:checked ~ .expand-content {
    max-height: 500px;
  }

  .expand-toggle:checked ~ .expand-btn {
    display: none;
  }

  .expand-btn {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-gold);
    cursor: pointer;
    margin-top: 4px;
    transition: color var(--transition-fast);
  }

  .expand-btn:hover {
    color: var(--color-crimson);
  }

  .person-card__email {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: var(--color-gold);
    text-decoration: none;
    display: block;
    margin-bottom: 4px;
  }

  .person-card__link {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: var(--color-gold);
    text-decoration: none;
    display: block;
  }

  .board-chair {
    text-align: center;
    margin-bottom: 24px;
    display: none;
  }

  .board-chair__photo {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    margin: 0 auto 8px;
    display: block;
  }

  .board-chair h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 2px;
  }

  .person-card--chair-desktop {
    display: block;
  }

  @media (max-width: 639px) {
    .board-chair {
      display: block;
    }
    .person-card--chair-desktop {
      display: none;
    }
  }

  @media (max-width: 639px) {
    .people-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 640px) {
    .people-grid.people-grid--staff {
      grid-template-columns: repeat(3, 1fr);
    }
    .people-grid--large {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .people-grid {
      grid-template-columns: repeat(4, 1fr);
    }
    .people-grid--board {
      grid-template-columns: repeat(5, 1fr);
    }
    .people-grid.people-grid--staff {
      grid-template-columns: repeat(3, 1fr);
    }
    .people-grid--large {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Patron Featured */
  .patron-featured {
    display: flex;
    gap: 24px;
    align-items: center;
    flex-wrap: wrap;
  }

  .patron-featured--centered {
    flex-direction: column;
    text-align: center;
    max-width: 560px;
    margin-inline: auto;
    gap: 4px;
  }

  .patron-featured__photo {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .patron-featured__photo--large {
    width: 160px;
    height: 160px;
    margin-bottom: 12px;
    box-shadow: 0 4px 20px rgba(14, 51, 82, 0.12);
  }

  .patron-featured h2 {
    margin: 4px 0 8px;
  }

  .patron-featured__bio {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-gray);
    line-height: 1.6;
  }

  /* Advisory */
  .advisory-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .advisory-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(90, 90, 110, 0.08);
  }

  .advisory-item__photo {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    flex-shrink: 0;
  }

  .advisory-item h3 {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 2px;
  }

  .advisory-item p {
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--color-gray);
  }

  @media (min-width: 640px) {
    .advisory-list {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px 32px;
    }
  }

  /* Committees */
  .committees {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .committee h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--color-navy);
    margin-bottom: 12px;
  }

  .committee ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .committee li {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-gray);
  }

  @media (min-width: 640px) {
    .committees {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .section--linen {
    background-color: var(--color-linen);
  }
</style>
