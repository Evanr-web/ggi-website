---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import { getLibraryArticles, imageUrl } from '../../lib/sanity';

const base = import.meta.env.BASE_URL;

// Try Sanity first
let sanityArticles: any[] = [];
try { sanityArticles = await getLibraryArticles() || []; } catch (e) { /* fallback */ }

// Map Sanity articles to our format
const cmsEntries = sanityArticles
  .filter((a: any) => !a._id.startsWith('drafts.') && a.enabled !== false)  // exclude drafts and disabled items
  .map((a: any) => {
  const d = a.publishDate ? new Date(a.publishDate) : null;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return {
    title: a.title,
    author: a.author || 'Gregory the Great Institute',
    category: a.category || 'Resource',
    date: d ? `${months[d.getMonth()]} ${d.getFullYear()}` : '',
    image: imageUrl(a.image, 400) || '',
    excerpt: a.excerpt || '',
    href: a.slug?.current || '',
    featured: a.featured === true,
  };
});

const fallbackEntries = [
  { title: "FINE Gathering in Ottawa and National Prayer Breakfast", author: "Victor Carpay", category: "News", date: "Apr 2026", image: `${base}images/art/parliament-hill-ottawa.jpg`, excerpt: "Dr. Topping and Victor were invited to the FINE Gathering coordinated by CCO and the National Prayer Breakfast by MP Shuv Majumbar (Calgary Heritage).", href: "fine-gathering-ottawa", featured: false },
  { title: "Master Your Money, Serve Your Vocation: Personal Finances 101", author: "Jesse Underwood", category: "News", date: "Apr 2026", image: `${base}images/events/finances-placeholder.jpg`, excerpt: "64% of Canadians never learned money management. Financial literacy as stewardship and vocation — a preview of our upcoming masterclass.", href: "personal-finances", featured: false },
  { title: "Medicine Forgets Its Vocation: Alberta Places Guardrails", author: "Dr. Joseph Woodard", category: "Essay", date: "Mar 2026", image: `${base}images/art/raphael-resurrection.jpg`, excerpt: "When hospital chaplains find themselves counselling traumatized healthcare professionals, something has gone badly wrong with the practice of medicine.", href: "medicine-forgets-vocation", featured: true },
  { title: "5 Ways to Celebrate Easter as a Family", author: "Catherine Renneberg", category: "Resource", date: "Jan 2026", image: `${base}images/art/caravaggio-supper-emmaus.jpg`, excerpt: "Practical ideas for families looking to deepen their celebration of the Paschal season at home.", href: "easter-family", featured: false },
  { title: "The Abolition of Man Study Guide", author: "Gregory the Great Institute", category: "Resource", date: "Dec 2025", image: `${base}images/art/gozzoli-triumph-aquinas.jpg`, excerpt: "A downloadable study guide for C.S. Lewis's The Abolition of Man, designed for use in reading groups and classrooms.", href: "abolition-of-man-guide", featured: false },
  { title: "Christmas Book Recommendations 2025", author: "Gregory the Great Institute", category: "Resource", date: "Dec 2025", image: `${base}images/art/roestraten-still-life-books.jpg`, excerpt: "Our annual curated list of books worth giving — and reading — this Christmas season.", href: "christmas-books-2025", featured: false },
];

// Use CMS data if available, otherwise fallback
const allEntries = cmsEntries.length > 0 ? cmsEntries : fallbackEntries;

// Featured articles come first, then the rest in date order
// Default: if nothing is explicitly featured, the newest article gets featured
const hasFeatured = allEntries.some((e: any) => e.featured);
const entries = hasFeatured
  ? [...allEntries.filter((e: any) => e.featured), ...allEntries.filter((e: any) => !e.featured)]
  : allEntries;  // first item becomes featured by default in template

const categories = ["All", "News", "Essays", "Videos", "Resources"];
---

<BaseLayout title="Library" description="Essays, videos, and resources for the renewal of Catholic culture in Canada.">

  <!-- Hero -->
  <section class="library-hero section--dark">
    <div class="library-hero__bg" style={`background-image: url(${import.meta.env.BASE_URL}images/art/admont-abbey-library.jpg)`}></div>
    <div class="library-hero__overlay"></div>
    <div class="library-hero__content container text-center">
      <h1 data-pagefind-weight="10" class="display heading-on-dark">Library</h1>
      <p style="font-family: var(--font-body); font-size: 1.05rem; color: rgba(245,239,229,0.8); max-width: 600px; margin-inline: auto; margin-top: 12px; line-height: 1.7;">
        Essays, videos, and resources for the renewal of Catholic culture in Canada.
      </p>
    </div>
  </section>

  <!-- Filter Bar -->
  <section class="filter-section">
    <div class="container">
      <div class="filter-bar">
        {categories.map((cat, i) => (
          <button class={`filter-btn${i === 0 ? ' filter-btn--active' : ''}`} data-filter={cat.toLowerCase()}>{cat}</button>
        ))}
        <a href={`${base}rss.xml`} class="filter-rss" title="Subscribe via RSS">RSS ↗</a>
      </div>
    </div>
  </section>

  <!-- Editorial Layout: Alternating Featured + Grid -->
  <section class="section">
    <div class="container" id="library-grid">
      {entries.map((entry: any, i: number) => {
        const entryUrl = `${import.meta.env.BASE_URL}library/${entry.href}/`;
        // Featured: explicitly marked, or first article as default
        const isFeature = entry.featured || (!hasFeatured && i === 0);
        // Alternate direction for visual variety on 2nd+ featured
        const featuredSoFar = entries.slice(0, i).filter((e: any) => e.featured || (!hasFeatured && entries.indexOf(e) === 0)).length;
        const isReverse = isFeature && featuredSoFar % 2 === 1;

        return isFeature ? (
          <div class={`lib-feature ${isReverse ? 'lib-feature--reverse' : ''} library-card reveal`} data-category={entry.category.toLowerCase()}>
            <a href={entryUrl} class="lib-feature__image">
              <img src={entry.image} alt="" class="art-filter" loading={i === 0 ? 'eager' : 'lazy'} />
            </a>
            <div class="lib-feature__body">
              <span class="label text-gold">{entry.category} · {entry.date}</span>
              <h2><a href={entryUrl}>{entry.title}</a></h2>
              <p class="lib-feature__meta">By {entry.author}</p>
              <p class="lib-feature__excerpt">{entry.excerpt}</p>
              <a href={entryUrl} class="lib-feature__read">Read →</a>
            </div>
          </div>
        ) : (
          <div class="lib-card library-card reveal" data-category={entry.category.toLowerCase()}>
            <a href={entryUrl} class="lib-card__inner">
              <div class="lib-card__image">
                <img src={entry.image} alt="" loading="lazy" />
              </div>
              <div class="lib-card__body">
                <span class="lib-card__meta label">{entry.category} · {entry.date}</span>
                <h3>{entry.title}</h3>
                <p class="lib-card__excerpt">{entry.excerpt}</p>
              </div>
            </a>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Newsletter -->
  <section class="section section--linen text-center">
    <div class="container container--xs">
      <h2 class="cta-heading">Get essays like these in your inbox</h2>
      <p class="cta-desc">Subscribe to our newsletter — Institute news, event invitations, and program updates.</p>
      <form class="newsletter-inline" data-ac-endpoint="/api/subscribe" data-ac-success="You're subscribed!" method="POST">
        <input type="email" name="email" placeholder="Email address" required aria-label="Email address" />
        <div class="cf-turnstile" data-sitekey="0x4AAAAAADm6eYaBvIIwZNRm" data-size="compact"></div>
        <button type="submit">Subscribe</button>
      </form>
    </div>
  </section>

</BaseLayout>

<style>
  /* Library Hero */
  .library-hero {
    position: relative;
    overflow: hidden;
    min-height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .library-hero__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 40%;
  }

  .library-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(15, 18, 30, 0.55) 0%,
      rgba(15, 18, 30, 0.5) 50%,
      rgba(15, 18, 30, 0.7) 100%
    );
  }

  .library-hero__content {
    position: relative;
    z-index: 2;
    padding-block: 60px;
  }

  /* Ensure hidden attribute works on cards (overrides display: grid/inline-block) */
  .library-card[hidden] {
    display: none !important;
  }

  /* === Featured Article (full-width, image + text side by side) === */
  .lib-feature {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: center;
    margin-bottom: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(90, 90, 110, 0.08);
  }

  .lib-feature__image {
    display: block;
    overflow: hidden;
    border-radius: 3px;
  }

  .lib-feature__image img {
    width: 100%;
    height: 320px;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .lib-feature:hover .lib-feature__image img {
    transform: scale(1.03);
  }

  .lib-feature__body h2 {
    margin: 8px 0 8px;
    line-height: 1.25;
  }

  .lib-feature__body h2 a {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .lib-feature:hover h2 a {
    color: var(--color-gold);
  }

  .lib-feature__meta {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    color: var(--color-gray);
    margin-bottom: 12px;
  }

  .lib-feature__excerpt {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-gray);
    margin-bottom: 16px;
  }

  .lib-feature__read {
    font-family: var(--font-ui);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-gold);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .lib-feature__read:hover {
    color: var(--color-crimson);
  }

  @media (min-width: 768px) {
    .lib-feature {
      grid-template-columns: 1.1fr 1fr;
    }

    .lib-feature--reverse {
      grid-template-columns: 1fr 1.1fr;
    }

    .lib-feature--reverse .lib-feature__image {
      order: 2;
    }

    .lib-feature__image img {
      height: 360px;
    }
  }

  /* === Grid Cards (smaller, 2-3 per row between features) === */
  .lib-card {
    margin-bottom: 24px;
    display: inline-block;
    width: 100%;
  }

  .lib-card__inner {
    display: block;
    text-decoration: none;
    color: inherit;
    background: var(--color-linen);
    border: 1px solid rgba(90, 90, 110, 0.1);
    border-radius: 3px;
    overflow: hidden;
    transition: box-shadow var(--transition-base), border-color var(--transition-base);
  }

  .lib-card__inner:hover {
    border-color: var(--color-gold);
    box-shadow: 0 4px 20px rgba(14, 51, 82, 0.08);
  }

  .lib-card__image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .lib-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .lib-card__inner:hover .lib-card__image img {
    transform: scale(1.03);
  }

  .lib-card__body {
    padding: 20px 24px 24px;
  }

  .lib-card__meta {
    color: var(--color-gray);
    margin-bottom: 6px;
  }

  .lib-card__body h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-navy);
    line-height: 1.3;
    margin-bottom: 10px;
    transition: color var(--transition-fast);
  }

  .lib-card__inner:hover h3 {
    color: var(--color-gold);
  }

  .lib-card__excerpt {
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-gray);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Filter Bar */
  .filter-section {
    border-bottom: 1px solid rgba(90, 90, 110, 0.1);
    padding: 16px 0;
  }

  .filter-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .filter-btn {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 500;
    padding: 6px 16px;
    border: 1px solid rgba(90, 90, 110, 0.15);
    border-radius: 3px;
    background: transparent;
    color: var(--color-gray);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .filter-btn:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  .filter-btn--active {
    background-color: var(--color-navy);
    color: var(--color-text-on-dark);
    border-color: var(--color-navy);
  }

  .filter-rss {
    margin-left: auto;
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: var(--color-gray);
    text-decoration: none;
  }

  .filter-rss:hover {
    color: var(--color-gold);
  }

  /* Library container: features span full width, cards flow into grid rows */
  #library-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  .lib-feature {
    grid-column: 1 / -1;
  }

  @media (min-width: 640px) {
    #library-grid {
      grid-template-columns: repeat(2, 1fr);
      column-gap: 24px;
    }
  }

  @media (min-width: 1024px) {
    #library-grid {
      grid-template-columns: repeat(3, 1fr);
      column-gap: 28px;
    }
  }

  /* Newsletter inline */
  .newsletter-inline {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .newsletter-inline input {
    font-family: var(--font-ui);
    font-size: 0.88rem;
    padding: 12px 16px;
    border: 1px solid rgba(90, 90, 110, 0.2);
    border-radius: 3px;
    background-color: var(--color-parchment);
    color: var(--color-ink);
    outline: none;
    min-width: 220px;
  }

  .newsletter-inline input:focus {
    border-color: var(--color-gold);
  }

  .newsletter-inline button {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 12px 24px;
    background-color: var(--color-gold);
    color: var(--color-navy);
    border: none;
    border-radius: 3px;
    cursor: pointer;
  }

  .section--linen {
    background-color: var(--color-linen);
  }

  .library-card[hidden] {
    display: none;
  }
</style>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.library-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('filter-btn--active'));
      btn.classList.add('filter-btn--active');

      const filter = btn.dataset.filter;
      const filterMap: Record<string, string> = { essays: 'essay', videos: 'video', resources: 'resource', news: 'news' };
      const match = filterMap[filter] || null;

      cards.forEach(card => {
        if (filter === 'all' || (card as HTMLElement).dataset.category === match) {
          (card as HTMLElement).hidden = false;
        } else {
          (card as HTMLElement).hidden = true;
        }
      });
    });
  });
</script>
