---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import { getLibraryArticles } from '../../lib/sanity';

const base = import.meta.env.BASE_URL;

// Try Sanity first
let sanityArticles: any[] = [];
try { sanityArticles = await getLibraryArticles() || []; } catch (e) { /* fallback */ }

// Map Sanity articles to our format
const cmsEntries = sanityArticles.map((a: any) => {
  const d = a.publishDate ? new Date(a.publishDate) : null;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return {
    title: a.title,
    author: a.author || 'Gregory the Great Institute',
    category: a.category || 'Resource',
    date: d ? `${months[d.getMonth()]} ${d.getFullYear()}` : '',
    image: a.image || '',
    excerpt: a.excerpt || '',
    href: a.slug?.current || '',
  };
});

const fallbackEntries = [
  // Real articles from GGI Latest
  { title: "FINE Gathering in Ottawa and National Prayer Breakfast", author: "Victor Carpay", category: "News", date: "Apr 2026", image: `${base}images/art/parliament-hill-ottawa.jpg`, excerpt: "Dr. Topping and Victor were invited to the FINE Gathering coordinated by CCO and the National Prayer Breakfast by MP Shuv Majumbar (Calgary Heritage).", href: "fine-gathering-ottawa" },
  { title: "Master Your Money, Serve Your Vocation: Personal Finances 101", author: "Jesse Underwood", category: "News", date: "Apr 2026", image: `${base}images/events/finances-placeholder.jpg`, excerpt: "64% of Canadians never learned money management. Financial literacy as stewardship and vocation — a preview of our upcoming masterclass.", href: "personal-finances" },
  { title: "Medicine Forgets Its Vocation: Alberta Places Guardrails", author: "Dr. Joseph Woodard", category: "Essay", date: "Mar 2026", image: `${base}images/art/raphael-resurrection.jpg`, excerpt: "When hospital chaplains find themselves counselling traumatized healthcare professionals, something has gone badly wrong with the practice of medicine.", href: "medicine-forgets-vocation" },
  // Real resources from GGI Publications
  { title: "5 Ways to Celebrate Easter as a Family", author: "Catherine Renneberg", category: "Resource", date: "Jan 2026", image: `${base}images/art/caravaggio-supper-emmaus.jpg`, excerpt: "Practical ideas for families looking to deepen their celebration of the Paschal season at home.", href: "easter-family" },
  { title: "The Abolition of Man Study Guide", author: "Gregory the Great Institute", category: "Resource", date: "Dec 2025", image: `${base}images/art/gozzoli-triumph-aquinas.jpg`, excerpt: "A downloadable study guide for C.S. Lewis's The Abolition of Man, designed for use in reading groups and classrooms.", href: "abolition-of-man-guide" },
  { title: "Christmas Book Recommendations 2025", author: "Gregory the Great Institute", category: "Resource", date: "Dec 2025", image: `${base}images/art/roestraten-still-life-books.jpg`, excerpt: "Our annual curated list of books worth giving — and reading — this Christmas season.", href: "christmas-books-2025" },
];

// Use CMS data if available, otherwise fallback
const entries = cmsEntries.length > 0 ? cmsEntries : fallbackEntries;

const categories = ["All", "News", "Essays", "Videos", "Resources"];
---

<BaseLayout title="Library" description="Essays, videos, and resources for the renewal of Catholic culture in Canada.">

  <!-- Hero -->
  <section class="library-hero section--dark">
    <div class="library-hero__bg" style={`background-image: url(${import.meta.env.BASE_URL}images/art/admont-abbey-library.jpg)`}></div>
    <div class="library-hero__overlay"></div>
    <div class="library-hero__content container text-center">
      <h1 data-pagefind-weight="10" class="display heading-on-dark">Library</h1>
      <p style="font-family: var(--font-body); font-size: 1.05rem; color: rgba(245,239,229,0.8); max-width: 600px; margin-inline: auto; margin-top: 12px; line-height: 1.7;">
        Essays, videos, and resources for the renewal of Catholic culture in Canada.
      </p>
    </div>
  </section>

  <!-- Featured -->
  <section class="section">
    <div class="container">
      <a href={`${import.meta.env.BASE_URL}library/${entries[2].href}/`} class="featured-essay">
        <div class="featured-essay__image">
          <img src={`${import.meta.env.BASE_URL}images/art/raphael-resurrection.jpg`} alt="Resurrection of Christ by Raphael" class="art-filter" />
        </div>
        <div class="featured-essay__body">
          <span class="label text-gold">Featured Essay</span>
          <h2>{entries[2].title}</h2>
          <p class="featured-essay__meta">By {entries[2].author} · {entries[2].date}</p>
          <p class="featured-essay__excerpt">{entries[2].excerpt}</p>
          <span class="featured-essay__link">Read →</span>
        </div>
      </a>
    </div>
  </section>

  <!-- Filter Bar -->
  <section class="filter-section">
    <div class="container">
      <div class="filter-bar">
        {categories.map((cat, i) => (
          <button class={`filter-btn${i === 0 ? ' filter-btn--active' : ''}`} data-filter={cat.toLowerCase()}>{cat}</button>
        ))}
        <a href={`${base}rss.xml`} class="filter-rss" title="Subscribe via RSS">RSS ↗</a>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="section">
    <div class="container">
      <div class="library-grid" id="library-grid">
        {entries.map((entry) => (
          <div class="library-card" data-category={entry.category.toLowerCase()}>
            <Card
              title={entry.title}
              description={entry.excerpt}
              meta={`${entry.category} · ${entry.date}`}
              href={`${import.meta.env.BASE_URL}library/${entry.href}/`}
              image={entry.image}
              imageAlt=""
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="section section--linen text-center">
    <div class="container container--xs">
      <h2 class="cta-heading">Get essays like these in your inbox</h2>
      <p class="cta-desc">Subscribe to the Magnalia Letter — free monthly essays, event invitations, and reading recommendations.</p>
      <form class="newsletter-inline" data-ac-endpoint="/api/subscribe" data-ac-success="You're subscribed!" method="POST">
        <input type="email" name="email" placeholder="Email address" required aria-label="Email address" />
        <button type="submit">Subscribe</button>
      </form>
    </div>
  </section>

</BaseLayout>

<style>
  /* Library Hero */
  .library-hero {
    position: relative;
    overflow: hidden;
    min-height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .library-hero__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 40%;
  }

  .library-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(15, 18, 30, 0.55) 0%,
      rgba(15, 18, 30, 0.5) 50%,
      rgba(15, 18, 30, 0.7) 100%
    );
  }

  .library-hero__content {
    position: relative;
    z-index: 2;
    padding-block: 60px;
  }

  /* Featured Essay */
  .featured-essay {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-component);
    align-items: center;
    text-decoration: none;
    color: inherit;
    transition: opacity var(--transition-fast);
  }

  .featured-essay:hover h2 {
    color: var(--color-gold);
  }

  .featured-essay__link {
    font-family: var(--font-ui);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-gold);
    transition: color var(--transition-fast);
  }

  .featured-essay:hover .featured-essay__link {
    color: var(--color-crimson);
  }

  .featured-essay__image img {
    width: 100%;
    height: 300px;
    object-fit: cover;
    border-radius: 3px;
  }

  .featured-essay__body h2 {
    margin: 8px 0 8px;
  }

  .featured-essay__meta {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    color: var(--color-gray);
    margin-bottom: 12px;
  }

  .featured-essay__excerpt {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-gray);
    margin-bottom: 16px;
  }

  @media (min-width: 768px) {
    .featured-essay {
      grid-template-columns: 1fr 1.2fr;
    }
  }

  /* Filter Bar */
  .filter-section {
    border-bottom: 1px solid rgba(90, 90, 110, 0.1);
    padding: 16px 0;
  }

  .filter-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .filter-btn {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 500;
    padding: 6px 16px;
    border: 1px solid rgba(90, 90, 110, 0.15);
    border-radius: 3px;
    background: transparent;
    color: var(--color-gray);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .filter-btn:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  .filter-btn--active {
    background-color: var(--color-navy);
    color: var(--color-text-on-dark);
    border-color: var(--color-navy);
  }

  .filter-rss {
    margin-left: auto;
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: var(--color-gray);
    text-decoration: none;
  }

  .filter-rss:hover {
    color: var(--color-gold);
  }

  /* Library Grid */
  .library-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 640px) {
    .library-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .library-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Newsletter inline */
  .newsletter-inline {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .newsletter-inline input {
    font-family: var(--font-ui);
    font-size: 0.88rem;
    padding: 12px 16px;
    border: 1px solid rgba(90, 90, 110, 0.2);
    border-radius: 3px;
    background-color: var(--color-parchment);
    color: var(--color-ink);
    outline: none;
    min-width: 220px;
  }

  .newsletter-inline input:focus {
    border-color: var(--color-gold);
  }

  .newsletter-inline button {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 12px 24px;
    background-color: var(--color-gold);
    color: var(--color-navy);
    border: none;
    border-radius: 3px;
    cursor: pointer;
  }

  .section--linen {
    background-color: var(--color-linen);
  }

  .library-card[hidden] {
    display: none;
  }
</style>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.library-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('filter-btn--active'));
      btn.classList.add('filter-btn--active');

      const filter = btn.dataset.filter;
      const filterMap: Record<string, string> = { essays: 'essay', videos: 'video', resources: 'resource', news: 'news' };
      const match = filterMap[filter] || null;

      cards.forEach(card => {
        if (filter === 'all' || (card as HTMLElement).dataset.category === match) {
          (card as HTMLElement).hidden = false;
        } else {
          (card as HTMLElement).hidden = true;
        }
      });
    });
  });
</script>
