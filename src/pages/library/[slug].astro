---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getLibraryArticle, getLibraryArticles } from '../../lib/sanity';
import { toHTML } from '@portabletext/to-html';

export async function getStaticPaths() {
  const articles = await getLibraryArticles();

  return (articles || [])
    .filter((a: any) => a.slug?.current)
    .map((a: any) => ({
      params: { slug: a.slug.current },
    }));
}

const { slug } = Astro.params;
const article = await getLibraryArticle(slug as string);

if (!article) {
  return Astro.redirect('/404');
}

const base = import.meta.env.BASE_URL;

// Format date
const pubDate = article.publishDate ? new Date(article.publishDate) : null;
const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const dateStr = pubDate ? `${months[pubDate.getMonth()]} ${pubDate.getDate()}, ${pubDate.getFullYear()}` : '';

// Get author name — could be a reference or inline
const authorName = article.authorName || (typeof article.author === 'string' ? article.author : 'Gregory the Great Institute');
const authorPhoto = article.authorImage || '';

// Get image URL
const imageUrl = article.featuredImage?.asset?.url || article.image || '';

// Category
const category = article.category || 'News';

// Render body from Portable Text
const bodyHtml = article.body ? toHTML(article.body, {
  components: {
    types: {
      image: ({value}: any) => `<figure class="article__figure"><img src="${value.url || value.asset?.url || ''}" alt="" class="article__inline-img" loading="lazy" /></figure>`,
    },
    block: {
      blockquote: ({children}: any) => `<blockquote class="article__pullquote"><p>${children}</p></blockquote>`,
      h2: ({children}: any) => `<h2>${children}</h2>`,
      h3: ({children}: any) => `<h3>${children}</h3>`,
    },
  },
}) : '';

// Estimate read time
const wordCount = article.body?.reduce((acc: number, block: any) => {
  if (block._type === 'block' && block.children) {
    return acc + block.children.reduce((a: number, c: any) => a + (c.text?.split(/\s+/).length || 0), 0);
  }
  return acc;
}, 0) || 0;
const readTime = `${Math.max(1, Math.ceil(wordCount / 250))} min read`;
---

<ArticleLayout
  title={article.title}
  description={article.excerpt || ''}
  author={authorName}
  date={dateStr}
  category={category}
  readTime={readTime}
  image={imageUrl}
  imageAlt={article.title}
  authorImage={authorPhoto || undefined}
>
  <Fragment set:html={bodyHtml} />
  {article.downloadFile?.asset?.url && (
    <div class="article__download">
      <a href={article.downloadFile.asset.url} download class="article__download-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        Download Resource
      </a>
    </div>
  )}
</ArticleLayout>

<style>
  .article__download {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid rgba(90, 90, 110, 0.1);
    text-align: center;
  }
  .article__download-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    padding: 14px 32px;
    background-color: var(--color-crimson);
    color: var(--color-parchment);
    border-radius: 3px;
    text-decoration: none;
    transition: background-color var(--transition-fast);
  }
  .article__download-btn:hover {
    background-color: #6b2124;
  }
</style>
