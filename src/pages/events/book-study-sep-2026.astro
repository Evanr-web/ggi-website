---
import EventLayout from '../../layouts/EventLayout.astro';
import CanadaGroupMap from '../../components/CanadaGroupMap.astro';
import BookStudyForm from '../../components/BookStudyForm.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import { getReadingGroups } from '../../lib/sanity';
const base = import.meta.env.BASE_URL;

const sanityGroups = await getReadingGroups();
---

<EventLayout
  title="Book Study — Leisure: The Basis of Culture"
  description="Read Josef Pieper's masterwork on contemplation and culture. Free Inklings Club book study groups across Canada, September 2026."
  date="2026-09-01"
  location="Locations across Canada"
  image="/images/events/leisure-bruegel-harvesters.jpg"
  artFilter={true}
  imageAlt="The Harvesters by Pieter Bruegel the Elder, 1565"
  imagePosition="center 95%"
  tag="Book Study · Inklings Club"
  cost="Free"
  ctaText="Find a Group Below"
  ctaHref="#join-form"
>
  <p>
    Josef Pieper's masterwork on why <strong>contemplation — not productivity — is the foundation
    of civilization</strong>. This study prepares readers for the October Renewing Culture Conference,
    which takes up Pieper's vision in depth.
  </p>

  <h2>How It Works</h2>
  <ul>
    <li>Join a local reading group in your city, or follow along online</li>
    <li>Study guides and discussion questions provided by the Institute</li>
    <li>Webinar sessions with fellow readers across Canada</li>
    <li>Discounts on the book for participants</li>
  </ul>

  <p>
    Local groups across Canada, plus online. Study guides and discussion questions provided.
    This study prepares readers for the October Renewing Culture Conference.
  </p>

  <SectionDivider />

  <!-- Find a Group -->
  <div class="bs-event-groups">
    <div class="section-header--flush">
      <p class="label text-gold">Find a Group</p>
      <h2>Inklings Clubs Across Canada</h2>
      <p class="subtitle">
        Join an existing group near you — or start one in your city.
      </p>
    </div>
    <CanadaGroupMap sanityGroups={sanityGroups} />
  </div>

  <SectionDivider />

  <!-- Join Form -->
  <div class="bs-event-form" id="join-form">
    <div class="section-header--tight">
      <p class="label text-gold">Get Connected</p>
      <h2 id="form-title">Join This Book Study</h2>
      <p class="subtitle--sm">
        Tell us a bit about yourself and we'll connect you with a group — or help you start one.
      </p>
    </div>
    <BookStudyForm />
  </div>
</EventLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cityData: Record<string, string[]> = {
      BC: ['Vancouver', 'Kelowna'],
      AB: ['Edmonton', 'St. Albert', 'Sherwood Park', 'Spruce Grove', 'Fort McMurray', 'Red Deer', 'Lethbridge', 'Calgary'],
      SK: ['Saskatoon', 'Regina'],
      MB: ['Winnipeg'],
      ON: ['Toronto', 'Ottawa'],
      QC: ['Montreal'],
      NB: [],
      NS: ['Halifax'],
      PE: [],
      NL: ["St. John's"],
      other: []
    };

    const provinceSelect = document.getElementById('bs-province') as HTMLSelectElement;
    const citySelect = document.getElementById('bs-city') as HTMLSelectElement;
    const otherCityField = document.getElementById('other-city-field');
    const interestSelect = document.getElementById('bs-interest') as HTMLSelectElement;
    const hostCountField = document.getElementById('host-count-field');

    provinceSelect?.addEventListener('change', () => {
      const prov = provinceSelect.value;
      const cities = cityData[prov] || [];
      citySelect.innerHTML = '';
      citySelect.disabled = false;

      if (cities.length > 0) {
        const placeholder = document.createElement('option');
        placeholder.value = '';
        placeholder.disabled = true;
        placeholder.selected = true;
        placeholder.textContent = 'Select city';
        citySelect.appendChild(placeholder);

        cities.forEach(city => {
          const opt = document.createElement('option');
          opt.value = city;
          opt.textContent = city;
          citySelect.appendChild(opt);
        });

        const otherOpt = document.createElement('option');
        otherOpt.value = 'other';
        otherOpt.textContent = 'Other / not listed';
        citySelect.appendChild(otherOpt);
      } else {
        const opt = document.createElement('option');
        opt.value = 'other';
        opt.textContent = 'Enter your city below';
        opt.selected = true;
        citySelect.appendChild(opt);
      }

      citySelect.dispatchEvent(new Event('change'));
    });

    citySelect?.addEventListener('change', () => {
      if (otherCityField) {
        otherCityField.style.display = citySelect.value === 'other' ? 'flex' : 'none';
      }
    });

    interestSelect?.addEventListener('change', () => {
      if (hostCountField) {
        hostCountField.style.display = interestSelect.value === 'host' ? 'block' : 'none';
      }
    });

    document.querySelectorAll('.bs-pin--cluster[data-province]').forEach(pin => {
      pin.addEventListener('click', () => {
        const prov = pin.getAttribute('data-province');
        const accordion = document.querySelector(`.bs-accordion[data-province="${prov}"]`) as HTMLDetailsElement;
        if (accordion) {
          accordion.open = true;
          accordion.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      });
    });

    document.querySelectorAll('.bs-city__join').forEach(btn => {
      btn.addEventListener('click', () => {
        const prov = btn.getAttribute('data-province');
        const city = btn.getAttribute('data-city');

        if (prov && provinceSelect) {
          provinceSelect.value = prov;
          provinceSelect.dispatchEvent(new Event('change'));
          setTimeout(() => {
            if (city && citySelect) {
              citySelect.value = city;
              citySelect.dispatchEvent(new Event('change'));
            }
          }, 50);
        }

        if (interestSelect) {
          interestSelect.value = 'join';
          interestSelect.dispatchEvent(new Event('change'));
        }

        document.getElementById('join-form')?.scrollIntoView({ behavior: 'smooth' });
      });
    });
  });
</script>

<style>
  .bs-event-groups {
    margin-top: 48px;
    padding-top: 32px;
  }

  .bs-event-form {
    margin-top: 32px;
    padding-top: 16px;
    max-width: 640px;
    margin-inline: auto;
  }

  .section-header--flush {
    text-align: center;
    margin-bottom: 32px;
  }

  .section-header--flush h2 {
    margin-top: 8px;
  }

  .section-header--tight {
    text-align: center;
    margin-bottom: 28px;
  }

  .section-header--tight h2 {
    margin-top: 8px;
    margin-bottom: 8px;
  }

  .subtitle {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-gray);
    max-width: 560px;
    margin-inline: auto;
  }

  .subtitle--sm {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-gray);
    max-width: 480px;
    margin-inline: auto;
  }
</style>
