---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventCard from '../../components/EventCard.astro';
import { getEvents } from '../../lib/sanity';

const base = import.meta.env.BASE_URL;

// Try Sanity first
let sanityEvents: any[] = [];
try { sanityEvents = await getEvents() || []; } catch (e) { /* fallback */ }

const cmsEvents = sanityEvents.map((e: any) => {
  const d = new Date(e.startDate);
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return {
    title: e.title,
    month: months[d.getMonth()],
    day: String(d.getDate()),
    date: e.startDate,
    location: e.location || '',
    description: e.shortDescription || '',
    href: `${base}events/${e.slug?.current}/`,
    programTag: e.template ? e.template.charAt(0).toUpperCase() + e.template.slice(1) : '',
    thumbnail: e.headerImage || '',
    thumbnailAlt: e.title,
  };
});

// Same fallback events as main events page
const fallbackEvents = [
  {
    title: "2026 Book Study — Searching for and Maintaining Peace",
    month: "Feb", day: "1", date: "2026-02-01",
    location: "Locations across Canada",
    description: "Fr. Jacques Philippe's beloved guide to interior peace. Join a local reading group or follow along online.",
    href: `${base}events/book-study-feb-2026/`,
    programTag: "Book Study",
    thumbnail: "/images/events/book-study-placeholder.jpg",
    thumbnailAlt: "Leather-bound books"
  },
  {
    title: "GGI at Provincial Prayer Breakfast",
    month: "Mar", day: "18", date: "2026-03-18",
    location: "Edmonton, AB",
    description: "The GGI team attended the annual Premier's Prayer Breakfast in Alberta.",
    href: `${base}events/prayer-breakfast-2026/`,
    programTag: "Community",
    thumbnail: "/images/events/prayer-breakfast-placeholder.jpg",
    thumbnailAlt: "Candles"
  },
  {
    title: "Personal Finances 101",
    month: "Apr", day: "25", date: "2026-04-25",
    location: "Concordia University of Edmonton",
    description: "Master your money, serve your vocation. Financial literacy as stewardship and Catholic formation. Led by Jesse Underwood.",
    href: `${base}events/finances-101/`,
    programTag: "Masterclass",
    thumbnail: "/images/events/finances-placeholder.jpg",
    thumbnailAlt: "The Moneylender and His Wife"
  },
  {
    title: "2026 Book Study — Animal Farm",
    month: "May", day: "1", date: "2026-05-01",
    location: "Locations across Canada",
    description: "George Orwell's classic political fable, read through the lens of Catholic social teaching.",
    href: `${base}events/book-study-may-2026/`,
    programTag: "Book Study",
    thumbnail: "/images/events/animal-farm-morland.jpg",
    thumbnailAlt: "Pigs by George Morland"
  },
  {
    title: "St. Gregory's Music & Leadership Camp",
    month: "Jul", day: "12", date: "2026-07-12",
    location: "Solara Water's Edge, Parkland County, AB",
    description: "Four nights of fiddle, penny whistle, voice, games, prayer, and leadership for youth ages 12–18. $350/child, family discounts available.",
    href: `${base}events/music-camp-2026/`,
    programTag: "Camp",
    thumbnail: "/images/events/music-camp-hero-outdoor.jpeg",
    thumbnailAlt: "Youth at music camp outdoors"
  },
  {
    title: "2026 Book Study — Leisure: The Basis of Culture",
    month: "Sep", day: "1", date: "2026-09-01",
    location: "Locations across Canada",
    description: "Josef Pieper's masterwork on why contemplation — not productivity — is the foundation of civilization.",
    href: `${base}events/book-study-sep-2026/`,
    programTag: "Book Study",
    thumbnail: "/images/events/leisure-bruegel-harvesters.jpg",
    thumbnailAlt: "The Harvesters by Pieter Bruegel the Elder"
  },
  {
    title: "Bringing Back Sunday — Renewing Culture Conference",
    month: "Oct", day: "2", date: "2026-10-02",
    location: "Mt Carmel Spirituality Centre",
    description: "2nd Annual Renewing Culture Conference. Two days of speakers, seminars, prayer, and fellowship reflecting on Pieper's Leisure.",
    href: `${base}events/conference-2026/`,
    programTag: "Conference",
    thumbnail: "/images/events/2026-renewing-culture-conference-art.jpg",
    thumbnailAlt: "Adoration of the Mystic Lamb"
  },
  {
    title: "1st Annual Renewing Culture Conference",
    month: "Oct", day: "4", date: "2025-10-04",
    location: "Newman Theological College",
    description: "Inaugural conference featuring Dr. Ryan Topping and guests. Socratic seminars on Newman, Chesterton, and the renewal of Catholic culture.",
    href: `${base}events/conference-2025/`,
    programTag: "Conference",
    thumbnail: "/images/events/2026-renewing-culture-conference-art.jpg",
    thumbnailAlt: "Conference art"
  },
];

const events = cmsEvents.length > 0 ? cmsEvents : fallbackEvents;

// Show only past events, sorted newest first
const today = new Date().toISOString().split('T')[0];
const pastEvents = events.filter(e => e.date < today).sort((a, b) => b.date.localeCompare(a.date));

// Group by year
const byYear: Record<string, typeof pastEvents> = {};
for (const e of pastEvents) {
  const year = e.date.slice(0, 4);
  if (!byYear[year]) byYear[year] = [];
  byYear[year].push(e);
}
const years = Object.keys(byYear).sort((a, b) => b.localeCompare(a)); // newest first
---

<BaseLayout title="Event Archive" description="Past events from the Gregory the Great Institute.">

  <section class="hero-compact section--dark">
    <div class="container" style="text-align: center; padding-block: 60px;">
      <h1 data-pagefind-weight="10" class="display" style="color: var(--color-text-on-dark);">Event Archive</h1>
      <p style="font-family: var(--font-body); font-size: 1.05rem; color: rgba(245,239,229,0.8); max-width: 600px; margin-inline: auto; margin-top: 12px; line-height: 1.7;">
        A record of conferences, courses, and gatherings past.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="back-link-wrap">
        <a href={`${base}events/`} class="back-link">← Back to Events</a>
      </p>

      {years.map(year => (
        <div class="archive-year">
          <h2 class="archive-year__heading">{year}</h2>
          <div class="events-list events-list--past">
            {byYear[year].map(e => (
              <EventCard
                title={e.title}
                month={e.month}
                day={e.day}
                date={e.date}
                location={e.location}
                description={e.description}
                href={e.href}
                programTag={e.programTag}
                thumbnail={e.thumbnail}
                thumbnailAlt={e.thumbnailAlt}
                past={true}
              />
            ))}
          </div>
        </div>
      ))}

      {pastEvents.length === 0 && (
        <p style="text-align: center; color: var(--color-gray); font-family: var(--font-body);">No past events yet.</p>
      )}
    </div>
  </section>

</BaseLayout>

<style>
  .back-link-wrap {
    margin-bottom: 32px;
  }

  .back-link {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-gold);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-crimson);
  }

  .archive-year {
    margin-bottom: 48px;
  }

  .archive-year__heading {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-navy);
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--color-gold);
  }

  .events-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .events-list--past :global(.event-card) {
    opacity: 0.7;
  }

  .events-list--past :global(.event-card:hover) {
    opacity: 1;
  }
</style>
