---
import EventLayout from '../../layouts/EventLayout.astro';
import Testimonials from '../../components/Testimonials.astro';
const base = import.meta.env.BASE_URL;

// Sample testimonials for preview — replace with real quotes or wire to Sanity
const sampleTestimonials = [
  { quote: "My daughter came home singing hymns and folk songs all day. She's already asking when she can go back.", attribution: "Parent, 2025 Camp" },
  { quote: "I learned more about prayer in four days than I had in years. The music was the doorway.", attribution: "Camper, age 16" },
  { quote: "The combination of sacred music, outdoor life, and genuine friendship — it's exactly what our kids need.", attribution: "Parent, Edmonton" },
];
---

<EventLayout
  title="St. Gregory's Music & Leadership Camp"
  date="2026-07-12"
  endDate="2026-07-16"
  location="Solara Water's Edge, Parkland County, AB"
  image="/images/events/music-camp-hero-outdoor.jpeg"
  imageAlt="Youth at music camp outdoors"
  tag="Youth Formation"
  cost="$350/child (family discounts available)"
  ctaText="Register Your Child"
  ctaHref={`${base}contact/`}
>
  <p>
    A four-night residential camp for youth ages 12–18. Instruction in <strong>fiddle, penny whistle,
    and voice</strong>, exploring sacred and folk music traditions. Daily prayer, leadership sessions,
    games, and community. Inspired by the von Trapp family singers' camp.
  </p>

  <h2>What Campers Will Experience</h2>
  <ul>
    <li>Daily music instruction in fiddle, penny whistle, and voice</li>
    <li>Sacred and folk music traditions from the Catholic heritage</li>
    <li>Leadership development sessions</li>
    <li>Daily prayer and spiritual formation</li>
    <li>Games, outdoor activities, and community building</li>
    <li>End-of-camp concert for families</li>
  </ul>

  <h2>Leader-in-Training Stream</h2>
  <p>
    Youth ages 16–18 can apply for the Leader-in-Training stream, developing mentorship
    and teaching skills alongside the regular camp program.
  </p>

  <p>
    Open to youth ages 12–18. Four nights, residential format.
  </p>

  <Testimonials testimonials={sampleTestimonials} heading="What Families Are Saying" />

</EventLayout>
