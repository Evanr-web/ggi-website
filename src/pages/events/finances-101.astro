---
import EventLayout from '../../layouts/EventLayout.astro';
const base = import.meta.env.BASE_URL;
---

<EventLayout
  title="Personal Finances 101"
  date="2026-04-25"
  location="Concordia University of Edmonton"
  image="/images/events/finances-placeholder.jpg"
  imageAlt="The Moneylender and His Wife by Quentin Matsys, 1514"
  imagePosition="center 35%"
  tag="Masterclass"
  ctaText="Register"
  ctaHref={`${base}contact/`}
>
  <p>
    Master your money, serve your vocation. This masterclass treats <strong>financial literacy
    as stewardship and Catholic formation</strong> — not just budgeting tips, but a vision
    of money ordered to the good life.
  </p>

  <p>Led by <strong>Jesse Underwood</strong>.</p>

  <h2>What You'll Learn</h2>
  <ul>
    <li>Catholic principles of stewardship and financial responsibility</li>
    <li>Practical budgeting and saving strategies</li>
    <li>Understanding debt, investment, and generosity</li>
    <li>Ordering your finances to support your vocation</li>
  </ul>

  <p>
    All welcome — especially young adults and families. Half-day format.
  </p>
</EventLayout>
