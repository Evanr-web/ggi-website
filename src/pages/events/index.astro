---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventCard from '../../components/EventCard.astro';
import { getEvents, imageUrl } from '../../lib/sanity';

const base = import.meta.env.BASE_URL;

// Try Sanity first
let sanityEvents: any[] = [];
try { sanityEvents = await getEvents() || []; } catch (e) { /* fallback */ }

// Map Sanity events to our format (skip events with no date)
const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const events = sanityEvents
  .filter((e: any) => e.startDate) // skip events without dates
  .map((e: any) => {
    const dateOnly = e.startDate.includes('T') ? e.startDate.split('T')[0] : e.startDate;
    const d = new Date(dateOnly + 'T12:00:00');
    return {
      title: e.title,
      month: months[d.getMonth()],
      day: String(d.getDate()),
      year: String(d.getFullYear()),
      date: dateOnly,
      location: e.location || '',
      description: e.shortDescription || '',
      href: `${base}events/${e.slug?.current}/`,
      programTag: e.template ? e.template.charAt(0).toUpperCase() + e.template.slice(1) : '',
      thumbnail: imageUrl(e.headerImage, 400) || '',
      thumbnailAlt: e.title,
    };
  });

// Auto-split based on today's date
const today = new Date().toISOString().split('T')[0]; // YYYY-MM-DD
const thirtyDaysAgo = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];

const upcoming = events.filter(e => e.date >= today).sort((a, b) => a.date.localeCompare(b.date));
const recentPast = events.filter(e => e.date < today && e.date >= thirtyDaysAgo).sort((a, b) => b.date.localeCompare(a.date));
const olderPast = events.filter(e => e.date < thirtyDaysAgo).sort((a, b) => b.date.localeCompare(a.date));
const hasArchive = olderPast.length > 0;
---

<BaseLayout title="Events" description="Upcoming conferences, courses, book studies, and community gatherings across Canada.">

  <!-- Hero -->
  <section class="hero-compact section--dark">
    <div class="container" style="text-align: center; padding-block: 60px;">
      <h1 data-pagefind-weight="10" class="display" style="color: var(--color-text-on-dark);">Events</h1>
      <p style="font-family: var(--font-body); font-size: 1.05rem; color: rgba(245,239,229,0.8); max-width: 600px; margin-inline: auto; margin-top: 12px; line-height: 1.7;">
        Join us across Canada for conferences, courses, book studies, and community gatherings.
      </p>
    </div>
  </section>

  {upcoming.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 style="margin-bottom: 24px;">Upcoming</h2>
        <div class="events-list">
          {upcoming.map(e => (
            <EventCard
              title={e.title}
              month={e.month}
              day={e.day}
              year={e.year}
              date={e.date}
              location={e.location}
              description={e.description}
              href={e.href}
              programTag={e.programTag}
              thumbnail={e.thumbnail}
              thumbnailAlt={e.thumbnailAlt}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {recentPast.length > 0 && (
    <section class="section section--linen">
      <div class="container">
        <h2 style="margin-bottom: 24px;">Recent Events</h2>
        <div class="events-list events-list--past">
          {recentPast.map(e => (
            <EventCard
              title={e.title}
              month={e.month}
              day={e.day}
              year={e.year}
              date={e.date}
              location={e.location}
              description={e.description}
              href={e.href}
              programTag={e.programTag}
              thumbnail={e.thumbnail}
              thumbnailAlt={e.thumbnailAlt}
              past={true}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {hasArchive && (
    <section class="section" style="padding-block: 32px;">
      <div class="container" style="text-align: center;">
        <a href={`${base}events/archive/`} class="archive-link">
          View Event Archive ({olderPast.length} past event{olderPast.length !== 1 ? 's' : ''}) →
        </a>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .events-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .events-list--past :global(.event-card) {
    opacity: 0.7;
  }

  .events-list--past :global(.event-card:hover) {
    opacity: 1;
  }

  .archive-link {
    font-family: var(--font-ui);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-gold);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .archive-link:hover {
    color: var(--color-crimson);
  }
</style>
