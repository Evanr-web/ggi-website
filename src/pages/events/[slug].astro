---
import EventLayout from '../../layouts/EventLayout.astro';
import EventRegistration from '../../components/EventRegistration.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import CanadaGroupMap from '../../components/CanadaGroupMap.astro';
import BookStudyForm from '../../components/BookStudyForm.astro';
import { getEvents, getEvent, getReadingGroups } from '../../lib/sanity';
import { renderPortableText } from '../../lib/portable-text';

export async function getStaticPaths() {
  // Slugs that have their own dedicated .astro files — exclude from dynamic generation
  const hardcodedSlugs: string[] = [];
  const events = await getEvents();
  return events
    .filter((e: any) => {
      const s = typeof e.slug === 'string' ? e.slug : e.slug?.current;
      return s && !hardcodedSlugs.includes(s);
    })
    .map((e: any) => ({
      params: { slug: typeof e.slug === 'string' ? e.slug : e.slug?.current },
    }));
}

const { slug } = Astro.params;
const event = await getEvent(slug!);

if (!event) {
  return Astro.redirect('/events/');
}

const bodyHtml = event.body ? renderPortableText(event.body) : '';
const hasBody = bodyHtml.length > 0;

// Book study template data
const isBookStudy = event.template === 'book-study';
const sanityGroups = isBookStudy ? await getReadingGroups() : [];

// Derive display values
const tag = (event.programTag || event.template)
  ? (event.programTag || (event.template ? event.template.charAt(0).toUpperCase() + event.template.slice(1) : 'Event'))
  : 'Event';

const isPast = event.status === 'past';

// CTA logic
let ctaStatus: 'active' | 'closed' | 'notify' = 'active';
let ctaText = event.ctaLabel || '';
let ctaHref = event.registrationUrl || '';

if (isPast) {
  ctaStatus = 'closed';
  ctaText = '';
} else if (event.ctaStatus === 'closed' || event.registrationStatus === 'closed') {
  ctaStatus = 'closed';
  ctaText = ctaText || 'Registration Closed';
} else if (event.ctaStatus === 'notify' || event.registrationStatus === 'coming-soon') {
  ctaStatus = 'notify';
  ctaText = ctaText || 'Get Notified';
} else if (ctaText && ctaHref) {
  ctaStatus = 'active';
} else {
  // No CTA configured
  ctaText = '';
  ctaHref = '';
}
---

<EventLayout
  title={event.title}
  description={event.shortDescription || event.description || ''}
  date={event.startDate ? event.startDate.split('T')[0] : ''}
  endDate={event.endDate ? event.endDate.split('T')[0] : undefined}
  location={event.location || ''}
  locationAddress={event.locationAddress}
  showMap={!!event.locationAddress}
  cost={event.cost}
  image={event.headerImage}
  imageAlt={event.title}
  imagePosition={event.imagePosition}
  artFilter={!!event.artFilter}
  tag={tag}
  past={isPast}
  ctaText={ctaText || undefined}
  ctaHref={ctaHref || undefined}
  ctaStatus={ctaStatus}
>
  {hasBody ? (
    <Fragment set:html={bodyHtml} />
  ) : (
    <p>Details coming soon.</p>
  )}

  {event.registrationStatus && event.registrationStatus !== 'closed' && (
    <EventRegistration
      status={event.registrationStatus}
      zeffyFormUrl={event.zeffyFormUrl}
      notifyTag={event.notifyTag}
      eventTitle={event.title}
    />
  )}

  {isBookStudy && (
    <>
      <SectionDivider />
      <div class="bs-event-groups">
        <div class="section-header--flush">
          <p class="label text-gold">Find a Group</p>
          <h2>Inklings Clubs Across Canada</h2>
          <p class="subtitle">
            Join an existing group near you — or start one in your city.
          </p>
        </div>
        <CanadaGroupMap sanityGroups={sanityGroups} />
      </div>

      <SectionDivider />

      <div class="bs-event-form" id="join-form">
        <div class="section-header--tight">
          <p class="label text-gold">Get Connected</p>
          <h2 id="form-title">Join This Book Study</h2>
          <p class="subtitle--sm">
            Tell us a bit about yourself and we'll connect you with a group — or help you start one.
          </p>
        </div>
        <BookStudyForm />
      </div>
    </>
  )}
</EventLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cityData: Record<string, string[]> = {
      BC: ['Vancouver', 'Kelowna'],
      AB: ['Edmonton', 'St. Albert', 'Sherwood Park', 'Spruce Grove', 'Fort McMurray', 'Red Deer', 'Lethbridge', 'Calgary'],
      SK: ['Saskatoon', 'Regina'],
      MB: ['Winnipeg'],
      ON: ['Toronto', 'Ottawa'],
      QC: ['Montreal'],
      NB: [],
      NS: ['Halifax'],
      PE: [],
      NL: ["St. John's"],
      other: []
    };

    const provinceSelect = document.getElementById('bs-province') as HTMLSelectElement;
    const citySelect = document.getElementById('bs-city') as HTMLSelectElement;
    const otherCityField = document.getElementById('other-city-field');
    const interestSelect = document.getElementById('bs-interest') as HTMLSelectElement;
    const hostCountField = document.getElementById('host-count-field');

    provinceSelect?.addEventListener('change', () => {
      const prov = provinceSelect.value;
      const cities = cityData[prov] || [];
      citySelect.innerHTML = '';
      citySelect.disabled = false;

      if (cities.length > 0) {
        const placeholder = document.createElement('option');
        placeholder.value = '';
        placeholder.disabled = true;
        placeholder.selected = true;
        placeholder.textContent = 'Select city';
        citySelect.appendChild(placeholder);

        cities.forEach(city => {
          const opt = document.createElement('option');
          opt.value = city;
          opt.textContent = city;
          citySelect.appendChild(opt);
        });

        const otherOpt = document.createElement('option');
        otherOpt.value = 'other';
        otherOpt.textContent = 'Other / not listed';
        citySelect.appendChild(otherOpt);
      } else {
        const opt = document.createElement('option');
        opt.value = 'other';
        opt.textContent = 'Enter your city below';
        opt.selected = true;
        citySelect.appendChild(opt);
      }

      citySelect.dispatchEvent(new Event('change'));
    });

    citySelect?.addEventListener('change', () => {
      if (otherCityField) {
        otherCityField.style.display = citySelect.value === 'other' ? 'flex' : 'none';
      }
    });

    interestSelect?.addEventListener('change', () => {
      if (hostCountField) {
        hostCountField.style.display = interestSelect.value === 'host' ? 'block' : 'none';
      }
    });

    document.querySelectorAll('.bs-pin--cluster[data-province]').forEach(pin => {
      pin.addEventListener('click', () => {
        const prov = pin.getAttribute('data-province');
        const accordion = document.querySelector(`.bs-accordion[data-province="${prov}"]`) as HTMLDetailsElement;
        if (accordion) {
          accordion.open = true;
          accordion.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      });
    });

    document.querySelectorAll('.bs-city__join').forEach(btn => {
      btn.addEventListener('click', () => {
        const prov = btn.getAttribute('data-province');
        const city = btn.getAttribute('data-city');

        if (prov && provinceSelect) {
          provinceSelect.value = prov;
          provinceSelect.dispatchEvent(new Event('change'));
          setTimeout(() => {
            if (city && citySelect) {
              citySelect.value = city;
              citySelect.dispatchEvent(new Event('change'));
            }
          }, 50);
        }

        if (interestSelect) {
          interestSelect.value = 'join';
          interestSelect.dispatchEvent(new Event('change'));
        }

        document.getElementById('join-form')?.scrollIntoView({ behavior: 'smooth' });
      });
    });
  });
</script>

<style>
  .bs-event-groups {
    margin-top: 48px;
    padding-top: 32px;
  }

  .bs-event-form {
    margin-top: 32px;
    padding-top: 16px;
    max-width: 640px;
    margin-inline: auto;
  }

  .section-header--flush {
    text-align: center;
    margin-bottom: 32px;
  }

  .section-header--flush h2 {
    margin-top: 8px;
  }

  .section-header--tight {
    text-align: center;
    margin-bottom: 28px;
  }

  .section-header--tight h2 {
    margin-top: 8px;
    margin-bottom: 8px;
  }

  .subtitle {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-gray);
    max-width: 560px;
    margin-inline: auto;
  }

  .subtitle--sm {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-gray);
    max-width: 480px;
    margin-inline: auto;
  }
</style>
