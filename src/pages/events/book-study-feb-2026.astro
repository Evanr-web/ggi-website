<EventLayout
  title="Book Study — Searching for and Maintaining Peace"
  description="Join an Inklings Club to read Fr. Jacques Philippe's guide to interior peace. Free book study groups across Canada, February 2026."
  date="2026-02-01"
  location="Locations across Canada"
  image="/images/art/la-tour-magdalene-smoking-flame.jpg"
  artFilter={true}
