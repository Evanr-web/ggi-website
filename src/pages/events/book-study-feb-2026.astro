---
import EventLayout from '../../layouts/EventLayout.astro';
import Button from '../../components/Button.astro';
const base = import.meta.env.BASE_URL;
---

<EventLayout
  title="Book Study — Searching for and Maintaining Peace"
  date="2026-02-01"
  location="Locations across Canada"
  image="/images/events/book-study-placeholder.jpg"
  imageAlt="Leather-bound books"
  tag="Book Study · Inklings Club"
>
  <p>
    Fr. Jacques Philippe's beloved guide to interior peace — a short, profound book on
    how to find and keep peace of heart in the midst of life's trials. One of the most
    widely read spiritual books of the past generation.
  </p>

  <h2>How It Works</h2>
  <ul>
    <li>Join a local reading group in your city, or follow along online</li>
    <li>Study guides and discussion questions provided by the Institute</li>
    <li>Webinar sessions with fellow readers across Canada</li>
    <li>Discounts on the book for participants</li>
  </ul>

  <h2>Details</h2>
  <ul>
    <li><strong>Book:</strong> <em>Searching for and Maintaining Peace</em> by Fr. Jacques Philippe</li>
    <li><strong>When:</strong> February 2026</li>
    <li><strong>Where:</strong> Local groups across Canada + online</li>
    <li><strong>Cost:</strong> Free</li>
  </ul>

  <Button href={`${base}programs/book-studies/`} variant="primary">Learn About Book Studies</Button>
</EventLayout>
