---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import SectionDivider from '../../components/SectionDivider.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Issue One — Magnalia" description="Full table of contents for Magnalia Issue One, Winter 2026.">

  <section class="section">
    <div class="container toc-page">
      <div class="toc-page__header">
        <img src={`${base}images/branding/Magnalia_Cover.jpg`} alt="Magnalia Issue One cover" class="toc-page__cover" />
        <div>
          <p class="label text-gold">Winter 2026 · 60 Pages</p>
          <h1 data-pagefind-weight="10">Magnalia — Issue One</h1>
          <p class="toc-page__subtitle">The inaugural issue of the journal of Catholic cultural renewal in Canada.</p>
          <Button href={`${base}magnalia/subscribe/`} variant="primary" size="small">Subscribe to Magnalia</Button>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider />

  <section class="section section--tight">
    <div class="container toc-page">
      <h2>Table of Contents</h2>

      <div class="toc-section">
        <h3 class="toc-section__label">Features</h3>
        <div class="toc-entry">
          <span class="toc-entry__page">4</span>
          <span class="toc-entry__title">Editor's Welcome</span>
        </div>
        <div class="toc-entry">
          <span class="toc-entry__page">5</span>
          <span class="toc-entry__title">Letters to the Editor</span>
        </div>
        <div class="toc-entry">
          <span class="toc-entry__page">10</span>
          <span class="toc-entry__title">Opinions</span>
        </div>
        <div class="toc-entry">
          <span class="toc-entry__page">21</span>
          <span class="toc-entry__title">Interview</span>
        </div>
      </div>

      <div class="toc-section">
        <h3 class="toc-section__label">Articles</h3>
        <div class="toc-entry">
          <span class="toc-entry__page">24</span>
          <div>
            <span class="toc-entry__title">C.S. Lewis and the Fathers</span>
            <span class="toc-entry__author">Ryan Scruggs</span>
            <p class="toc-entry__desc">What the Inklings' most famous convert learned from the Church Fathers — and what modern readers can still discover there.</p>
          </div>
        </div>
        <div class="toc-entry">
          <span class="toc-entry__page">32</span>
          <div>
            <span class="toc-entry__title">Heart Speaks to Heart</span>
            <span class="toc-entry__author">Thomas Cardinal Collins</span>
            <p class="toc-entry__desc">The Archbishop Emeritus of Toronto on Newman's motto, the life of the mind, and the renewal of Catholic culture in Canada.</p>
          </div>
        </div>
        <div class="toc-entry">
          <span class="toc-entry__page">40</span>
          <div>
            <span class="toc-entry__title">Irrigating the New Deserts</span>
            <span class="toc-entry__author">Dr. Ryan N.S. Topping</span>
            <p class="toc-entry__desc">The case for Catholic institution-building in an age of cultural drought — and a roadmap for how to begin.</p>
          </div>
        </div>
        <div class="toc-entry">
          <span class="toc-entry__page">46</span>
          <div>
            <span class="toc-entry__title">The Nursery Rhyme Metaphysic</span>
            <span class="toc-entry__author">Dr. Celene Sidloski</span>
            <p class="toc-entry__desc">How the imaginative world of childhood verse encodes deep truths about reality — and why it matters for classical education.</p>
          </div>
        </div>
        <div class="toc-entry">
          <span class="toc-entry__page">51</span>
          <div>
            <span class="toc-entry__title">AI and the Future of Humanity</span>
            <span class="toc-entry__author">Dr. Gerard McLarney</span>
            <p class="toc-entry__desc">A Catholic philosopher confronts the promises and perils of artificial intelligence for human dignity and the common good.</p>
          </div>
        </div>
        <div class="toc-entry">
          <span class="toc-entry__page">57</span>
          <div>
            <span class="toc-entry__title">The Great Tradition</span>
            <p class="toc-entry__desc">A curated reading list and guide to the texts that shaped Western Christian civilization.</p>
          </div>
        </div>
        <div class="toc-entry">
          <span class="toc-entry__page">59</span>
          <div>
            <span class="toc-entry__title">Northern Lights</span>
            <p class="toc-entry__desc">Dispatches, reviews, and cultural commentary from across Canada.</p>
          </div>
        </div>
      </div>

      <div class="toc-cta">
        <p>Magnalia is available by subscription. Each issue is 60 pages of the best Catholic writing in Canada.</p>
        <Button href={`${base}magnalia/subscribe/`} variant="primary">Subscribe Now</Button>
      </div>
    </div>
  </section>

  <section class="section" style="text-align: center;">
    <div class="container">
      <a href={`${base}magnalia/`} class="back-link">← Back to Magnalia</a>
    </div>
  </section>
</BaseLayout>

<style>
  .toc-page {
    max-width: 720px;
    margin-inline: auto;
  }

  .toc-page__header {
    display: flex;
    gap: 32px;
    align-items: center;
  }

  .toc-page__cover {
    width: 180px;
    border-radius: 3px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
    transform: rotate(-2deg);
    flex-shrink: 0;
  }

  .toc-page__header h1 {
    font-size: 2rem;
    color: var(--color-navy);
    margin: 8px 0 8px;
  }

  .toc-page__subtitle {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-gray);
    margin-bottom: 16px;
    line-height: 1.6;
  }

  .toc-section {
    margin-top: 32px;
  }

  .toc-section__label {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(90, 90, 110, 0.1);
    margin-bottom: 16px;
  }

  .toc-entry {
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(90, 90, 110, 0.06);
  }

  .toc-entry__page {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--color-gray);
    min-width: 24px;
    text-align: right;
    flex-shrink: 0;
  }

  .toc-entry__title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-navy);
    display: block;
  }

  .toc-entry__author {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--color-gold);
    font-weight: 500;
    display: block;
    margin-top: 2px;
  }

  .toc-entry__desc {
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--color-gray);
    line-height: 1.5;
    margin-top: 4px;
  }

  .toc-cta {
    text-align: center;
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid rgba(90, 90, 110, 0.1);
  }

  .toc-cta p {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-gray);
    margin-bottom: 16px;
  }

  .back-link {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-gold);
    text-decoration: none;
    font-weight: 500;
  }

  .back-link:hover {
    color: var(--color-crimson);
  }

  @media (max-width: 640px) {
    .toc-page__header {
      flex-direction: column;
      text-align: center;
    }
    .toc-page__cover {
      width: 140px;
    }
    .toc-page__header h1 {
      font-size: 1.5rem;
    }
  }
</style>
