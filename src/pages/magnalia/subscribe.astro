---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import SectionDivider from '../../components/SectionDivider.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Subscribe to Magnalia — Gregory the Great Institute" description="Subscribe to Magnalia, the journal of Catholic cultural renewal in Canada.">

  <section class="section" style="padding-bottom: 24px;">
    <div class="container subscribe-page">
      <div class="subscribe-page__header">
        <img src={`${base}images/branding/Magnalia_Cover.jpg`} alt="Magnalia Journal cover" class="subscribe-page__cover" />
        <div>
          <p class="label text-gold">Subscribe</p>
          <h1>Read Magnalia</h1>
          <p class="subscribe-page__intro">
            60 pages of the best Catholic writing in Canada, delivered to your door twice yearly.
            Essays, letters, interviews, reviews, and art from leading Catholic thinkers.
          </p>
        </div>
      </div>

      <div class="subscribe-tiers">
        <div class="subscribe-tier">
          <h3>Single Copy</h3>
          <p class="subscribe-tier__price">$45</p>
          <p class="subscribe-tier__desc">Try a single issue. No commitment.</p>
          <Button href={`${base}contact/`} variant="secondary" size="small">Order a Copy</Button>
        </div>

        <div class="subscribe-tier subscribe-tier--featured">
          <p class="subscribe-tier__badge label">Most Popular</p>
          <h3>Annual Subscription</h3>
          <p class="subscribe-tier__price">$80<span class="subscribe-tier__period">/year</span></p>
          <p class="subscribe-tier__desc">Two issues per year, delivered to your door. The standard for Friends of Magnalia.</p>
          <Button href={`${base}contact/`} variant="primary" size="small">Subscribe</Button>
        </div>

        <div class="subscribe-tier">
          <h3>Magnalia Patron</h3>
          <p class="subscribe-tier__price">$600<span class="subscribe-tier__period">/year</span></p>
          <p class="subscribe-tier__desc">Subscription + named recognition + Patron Conversations + signed book + annual one-on-one with Dr. Topping.</p>
          <Button href={`${base}magnalia/patron/`} variant="secondary" size="small">Learn More</Button>
        </div>
      </div>

      <div class="subscribe-special">
        <p><strong>Students & Seminarians: 50% off</strong> any subscription. Select "Student/Seminarian" at checkout.</p>
      </div>
    </div>
  </section>

  <div style="padding-inline: var(--space-component);">
    <SectionDivider />
  </div>

  <section class="section" id="institutional" style="padding-top: 24px;">
    <div class="container subscribe-page">
      <div class="institutional-box">
        <img src={`${base}images/branding/magnalia-stack.png`} alt="Stack of Magnalia journals" class="institutional-stack" />
        <div class="institutional-text">
          <h2>For Parishes, Seminaries & Institutions</h2>
          <p>
            Put Magnalia in the hands of your community. Single copies are available at the standard rate.
            Ordering for a parish, seminary, or library? Bulk pricing makes it easy to distribute widely.
          </p>
          <p class="institutional-pricing"><strong>Single copy:</strong> $45 &nbsp;·&nbsp; <strong>Bulk (10+):</strong> $30/copy</p>
          <Button href={`${base}contact/`} variant="primary">Place a Bulk Order</Button>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="text-align: center; padding-top: 24px;">
    <div class="container" style="max-width: 500px;">
      <h2 style="margin-bottom: 12px;">Not Ready to Subscribe?</h2>
      <p style="font-family: var(--font-body); color: var(--color-gray); margin-bottom: 20px; line-height: 1.6;">
        Sign up for the free Magnalia Letter — monthly essays, event invitations, and reading recommendations.
      </p>
      <Button href={`${base}magnalia/letter/`} variant="secondary" size="small">Subscribe to the Free Letter</Button>
    </div>
  </section>

  <section class="section--footnote">
    <div class="container" style="text-align: center;">
      <a href={`${base}magnalia/`} class="back-link">← Back to Magnalia</a>
    </div>
  </section>
</BaseLayout>

<style>
  .subscribe-page {
    max-width: 800px;
    margin-inline: auto;
  }

  .subscribe-page__header {
    display: flex;
    gap: 32px;
    align-items: center;
    margin-bottom: 40px;
  }

  .subscribe-page__cover {
    width: 180px;
    border-radius: 3px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
    transform: rotate(-2deg);
    flex-shrink: 0;
  }

  .subscribe-page__header h1 {
    font-size: 2.4rem;
    color: var(--color-navy);
    margin: 8px 0 16px;
  }

  .subscribe-page__intro {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-gray);
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    .subscribe-page__header {
      flex-direction: column;
      text-align: center;
    }
    .subscribe-page__cover {
      width: 140px;
    }
    .subscribe-page__header h1 {
      font-size: 1.8rem;
    }
  }

  .subscribe-tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 24px;
  }

  .subscribe-tier {
    background-color: var(--color-linen);
    border: 1px solid rgba(90, 90, 110, 0.1);
    border-radius: 3px;
    padding: 28px;
    text-align: center;
  }

  .subscribe-tier--featured {
    border: 2px solid var(--color-gold);
    position: relative;
  }

  .subscribe-tier__badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--color-gold);
    color: var(--color-navy);
    padding: 3px 12px;
    border-radius: 2px;
    font-size: 0.65rem;
    white-space: nowrap;
  }

  .subscribe-tier h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--color-navy);
    margin-bottom: 8px;
  }

  .subscribe-tier__price {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 8px;
  }

  .subscribe-tier__period {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--color-gray);
  }

  .subscribe-tier__desc {
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--color-gray);
    line-height: 1.5;
    margin-bottom: 16px;
  }

  .subscribe-special {
    text-align: center;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-gray);
  }

  .subscribe-special p {
    margin-bottom: 4px;
  }

  .institutional-stack {
    width: 220px;
    margin-bottom: 20px;
  }

  .institutional-box {
    background-color: white;
    border: 1px solid rgba(90, 90, 110, 0.1);
    border-radius: 3px;
    padding: 40px;
    display: flex;
    gap: 32px;
    align-items: center;
  }

  .institutional-box > :not(.institutional-stack) {
    text-align: left;
  }

  @media (max-width: 640px) {
    .institutional-box {
      flex-direction: column;
      text-align: center;
    }
    .institutional-box > :not(.institutional-stack) {
      text-align: center;
    }
    .institutional-stack {
      width: 160px;
    }
  }

  .institutional-box h2 {
    margin-bottom: 12px;
  }

  .institutional-box > p {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-gray);
    line-height: 1.6;
  }

  .institutional-pricing {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-ink);
    margin: 20px 0 24px;
    text-align: center;
  }

  .back-link {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-gold);
    text-decoration: none;
    font-weight: 500;
  }

  .back-link:hover { color: var(--color-crimson); }

  @media (max-width: 640px) {
    .subscribe-tiers {
      grid-template-columns: 1fr;
    }
    .subscribe-page__header h1 {
      font-size: 1.8rem;
    }
  }
</style>
