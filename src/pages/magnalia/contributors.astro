---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import { getMagnaliaContributors } from '../../lib/sanity';
const base = import.meta.env.BASE_URL;

let contributors: any[] = [];
try { contributors = await getMagnaliaContributors() || []; } catch (e) { /* fallback */ }
---

<BaseLayout title="Contributors — Magnalia" description="Meet the writers and thinkers behind Magnalia.">

  <section class="section">
    <div class="container contributors-page">
      <div class="contributors-page__header">
        <p class="label text-gold">Who Writes Magnalia</p>
        <h1 data-pagefind-weight="10">Our Contributors</h1>
        <p class="contributors-page__intro">
          Magnalia brings together leading Catholic thinkers, scholars, and writers from across Canada.
          Each contributor brings deep expertise and a commitment to Catholic cultural renewal.
        </p>
      </div>

      <div class="contributors-list">
        {contributors.map((person: any) => (
          <div class="contributor">
            {person.photo && <img src={person.photo} alt={person.name} class="contributor__photo" />}
            <div class="contributor__info">
              <h3>{person.name}</h3>
              {person.role && <p class="contributor__credentials">{person.credentials ? `${person.role} · ${person.credentials}` : person.role}</p>}
              {(person.contributorBio || person.shortBio) && <p class="contributor__bio">{person.contributorBio || person.shortBio}</p>}
            </div>
          </div>
        ))}
      </div>

      <div class="contributors-cta">
        <h2>Write for Magnalia</h2>
        <p>
          We welcome pitches from Catholic writers, scholars, and thinkers across Canada.
          Magnalia publishes original essays, book reviews, letters, and interviews.
        </p>
        <Button href={`${base}contact/`} variant="secondary" size="small">Submit a Pitch</Button>
      </div>

      <div style="text-align: center; margin-top: 40px;">
        <a href={`${base}magnalia/`} class="back-link">← Back to Magnalia</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contributors-page {
    max-width: 720px;
    margin-inline: auto;
  }

  .contributors-page__header {
    text-align: center;
    margin-bottom: 40px;
  }

  .contributors-page__header h1 {
    font-size: 2.2rem;
    color: var(--color-navy);
    margin: 8px 0 16px;
  }

  .contributors-page__intro {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-gray);
    line-height: 1.7;
    max-width: 560px;
    margin-inline: auto;
  }

  .contributors-list {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .contributor {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .contributor__photo {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .contributor__info h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--color-navy);
    margin-bottom: 2px;
  }

  .contributor__credentials {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-gold);
    font-weight: 500;
    margin-bottom: 8px;
  }

  .contributor__bio {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-gray);
    line-height: 1.6;
  }

  .contributors-cta {
    text-align: center;
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid rgba(90, 90, 110, 0.1);
  }

  .contributors-cta h2 {
    margin-bottom: 12px;
  }

  .contributors-cta p {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-gray);
    margin-bottom: 16px;
    line-height: 1.6;
  }

  .back-link {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-gold);
    text-decoration: none;
    font-weight: 500;
  }

  .back-link:hover { color: var(--color-crimson); }

  @media (max-width: 480px) {
    .contributor {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
