---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Donate — Gregory the Great Institute" description="Support Catholic intellectual life in Canada.">

  <section class="section">
    <div class="container donate-page">
      <div class="donate-page__icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-gold);"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </div>
      <h1>Online Giving Coming Soon</h1>
      <p class="donate-page__body">
        We're finalizing our secure online payment system. In the meantime, we'd love to hear from you — reach out and we'll get you set up personally.
      </p>
      <Button href={`${base}contact/`} variant="primary">Contact Us to Give</Button>
      <p class="donate-page__email">
        Or email us directly at <a href="mailto:info@gregorythegreat.ca">info@gregorythegreat.ca</a>
      </p>

      <div class="donate-page__tiers">
        <p class="donate-page__tiers-label label text-gold">Giving Levels</p>
        <div class="donate-page__tier">
          <strong>Friend of the Institute</strong>
          <span>$10–49/month</span>
        </div>
        <div class="donate-page__tier">
          <strong>Patron</strong>
          <span>$50/month ($600/year)</span>
        </div>
        <div class="donate-page__tier">
          <strong>Underwriter</strong>
          <span>$208/month ($2,500/year)</span>
        </div>
        <div class="donate-page__tier">
          <strong>Leadership Circle</strong>
          <span>$5,000+/year</span>
        </div>
        <div class="donate-page__tier">
          <strong>One-Time Gift</strong>
          <span>Any amount</span>
        </div>
      </div>

      <a href={`${base}support/`} class="back-link">← Back to Support</a>
    </div>
  </section>
</BaseLayout>

<style>
  .donate-page {
    max-width: 520px;
    margin-inline: auto;
    text-align: center;
  }

  .donate-page__icon {
    margin-bottom: 16px;
  }

  .donate-page h1 {
    font-size: 2rem;
    color: var(--color-navy);
    margin-bottom: 16px;
  }

  .donate-page__body {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-gray);
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .donate-page__email {
    font-family: var(--font-ui);
    font-size: 0.88rem;
    color: var(--color-gray);
    margin-top: 12px;
  }

  .donate-page__email a {
    color: var(--color-gold);
    text-decoration: none;
  }

  .donate-page__email a:hover {
    color: var(--color-crimson);
  }

  .donate-page__tiers {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid rgba(90, 90, 110, 0.1);
    text-align: left;
  }

  .donate-page__tiers-label {
    margin-bottom: 16px;
  }

  .donate-page__tier {
    display: flex;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid rgba(90, 90, 110, 0.06);
    font-family: var(--font-body);
    font-size: 0.95rem;
  }

  .donate-page__tier strong {
    color: var(--color-navy);
  }

  .donate-page__tier span {
    color: var(--color-gray);
  }

  .back-link {
    display: inline-block;
    margin-top: 32px;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-gold);
    text-decoration: none;
    font-weight: 500;
  }

  .back-link:hover { color: var(--color-crimson); }
</style>
