---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Donate — Gregory the Great Institute" description="Support Catholic intellectual life in Canada.">

  <section class="section">
    <div class="container donate-page">
      <div class="donate-page__icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-gold);"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </div>
      <h1 data-pagefind-weight="10">Support the Mission</h1>
      <p class="donate-page__body">
        Your generosity equips Christians to renew culture in the light of faith and reason — through formation programs, the Magnalia Journal, book studies, and our annual conference.
      </p>

      <div class="donate-page__tiers">
        <p class="donate-page__tiers-label label text-gold">Giving Levels</p>
        <div class="donate-page__tier">
          <strong>Friend of the Institute</strong>
          <span>$15+/month</span>
        </div>
        <div class="donate-page__tier">
          <strong>Patron</strong>
          <span>$50+/month ($600+/year)</span>
        </div>
        <div class="donate-page__tier">
          <strong>Leadership Circle</strong>
          <span>$5,000+/year</span>
        </div>
        <div class="donate-page__tier">
          <strong>One-Time Gift</strong>
          <span>Any amount</span>
        </div>
      </div>

      <!-- Zeffy Donation Embed -->
      <div class="donate-page__embed">
        <div data-zeffy-embed data-form-url="/embed/donation-form/support-the-gregory-the-great-institute"></div>
        <div data-zeffy-embed-fallback style="display:none;">
          <div style="position:relative;overflow:hidden;height:450px;width:100%;">
            <iframe
              title="Donation form powered by Zeffy"
              style="position:absolute;border:0;top:0;left:0;bottom:0;right:0;width:100%;height:100%"
              data-zeffy-embed-src="https://www.zeffy.com/embed/donation-form/support-the-gregory-the-great-institute"
              allowpaymentrequest
              allowTransparency="true"
            ></iframe>
          </div>
        </div>
        <script
          src="https://www.zeffy.com/embed/v2/zeffy-embed.js"
          onerror="document.querySelectorAll('[data-zeffy-embed-fallback]').forEach(function(el){el.style.display='block';el.querySelectorAll('iframe[data-zeffy-embed-src]').forEach(function(f){f.src=f.getAttribute('data-zeffy-embed-src');});});">
        </script>
      </div>

      <p class="donate-page__email">
        Prefer to give another way? Email us at <a href="mailto:info@gregorythegreat.ca">info@gregorythegreat.ca</a>
      </p>

      <p class="donate-page__note">
        Tax-deductible donations processed through Catholic Voices Canada. Charitable registration pending.
      </p>

      <a href={`${base}support/`} class="back-link">← Back to Support</a>
    </div>
  </section>
</BaseLayout>

<style>
  .donate-page {
    max-width: 640px;
    margin-inline: auto;
    text-align: center;
  }

  .donate-page__icon {
    margin-bottom: 16px;
  }

  .donate-page h1 {
    font-size: 2rem;
    color: var(--color-navy);
    margin-bottom: 16px;
  }

  .donate-page__body {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-gray);
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .donate-page__tiers {
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(90, 90, 110, 0.1);
    text-align: left;
    margin-bottom: 32px;
  }

  .donate-page__tiers-label {
    margin-bottom: 16px;
  }

  .donate-page__tier {
    display: flex;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid rgba(90, 90, 110, 0.06);
    font-family: var(--font-body);
    font-size: 0.95rem;
  }

  .donate-page__tier strong {
    color: var(--color-navy);
  }

  .donate-page__tier span {
    color: var(--color-gray);
  }

  .donate-page__embed {
    margin: 0 auto 32px;
    max-width: 100%;
  }

  .donate-page__email {
    font-family: var(--font-ui);
    font-size: 0.88rem;
    color: var(--color-gray);
    margin-top: 12px;
  }

  .donate-page__email a {
    color: var(--color-gold);
    text-decoration: none;
  }

  .donate-page__email a:hover {
    color: var(--color-crimson);
  }

  .donate-page__note {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: var(--color-gray);
    font-style: italic;
    margin-top: 8px;
  }

  .back-link {
    display: inline-block;
    margin-top: 32px;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-gold);
    text-decoration: none;
    font-weight: 500;
  }

  .back-link:hover { color: var(--color-crimson); }
</style>
