---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import SectionDivider from '../../components/SectionDivider.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Ambassadors — Gregory the Great Institute" description="Bring Catholic cultural renewal to your city. Become a GGI Ambassador and host events, share resources, and grow the community where you are.">

  <!-- Hero -->
  <section class="hero-amb section--dark">
    <div class="hero-amb__bg" style={`background-image: url(${base}images/art/school-of-athens.jpg)`}></div>
    <div class="hero-amb__overlay"></div>
    <div class="hero-amb__content container">
      <p class="label text-gold">Support the Mission</p>
      <h1 data-pagefind-weight="10" class="display">Become an Ambassador</h1>
      <p class="hero-amb__subtitle">Bring Catholic cultural renewal to your city.</p>
    </div>
  </section>

  <!-- Vision -->
  <section class="section">
    <div class="container amb-intro reveal">
      <p class="amb-intro__lead">
        The Gregory the Great Institute is built in Edmonton, but it belongs to the whole Church in Canada.
        <strong>Ambassadors are the distributed presence of the Institute</strong> — committed supporters
        who extend our reach into their own communities.
      </p>
      <p>
        You don't need a theology degree or a fundraising background. You need a conviction that Catholic
        intellectual life in Canada is worth rebuilding, and a willingness to open a few doors in your city.
      </p>
    </div>
  </section>

  <SectionDivider />

  <!-- What Ambassadors Do -->
  <section class="section section--linen">
    <div class="container">
      <div class="section-header">
        <p class="label text-gold">What You'll Do</p>
        <h2>Three Ways to Serve</h2>
      </div>
      <div class="roles-grid reveal-stagger">
        <div class="role-card reveal">
          <div class="role-card__accent"></div>
          <div class="role-card__body">
            <h3>Host</h3>
            <p>
              Organize a wine-and-cheese evening, a living room book study launch, or a screening
              of a Reasonable Passions lecture in your parish or home. We provide the materials,
              invitations, and follow-up support — you provide the space and the community.
            </p>
          </div>
        </div>
        <div class="role-card reveal">
          <div class="role-card__accent"></div>
          <div class="role-card__body">
            <h3>Share</h3>
            <p>
              Forward the Magnalia Letter to friends. Share Library articles with your parish priest.
              Recommend a Book Study to your homeschool co-op. Post about the Conference on social media.
              The simplest acts of sharing are the Institute's most powerful growth engine.
            </p>
          </div>
        </div>
        <div class="role-card reveal">
          <div class="role-card__accent"></div>
          <div class="role-card__body">
            <h3>Introduce</h3>
            <p>
              Know someone who should know about GGI? A parish priest, a Catholic school principal,
              a business leader, a young professional searching for intellectual depth? Make the
              introduction. We'll take it from there.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What GGI Provides -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="label text-gold">What You'll Receive</p>
        <h2>We Support You</h2>
      </div>
      <div class="support-grid reveal-stagger">
        <div class="support-item reveal">
          <strong>Event Kit</strong>
          <p>Printed invitations, Magnalia sample copies, and a hosting guide for your first event.</p>
        </div>
        <div class="support-item reveal">
          <strong>Digital Resources</strong>
          <p>Shareable graphics, email templates, and a personal referral link to track your impact.</p>
        </div>
        <div class="support-item reveal">
          <strong>Direct Line</strong>
          <p>Personal access to Victor Carpay for coordination, questions, and event planning support.</p>
        </div>
        <div class="support-item reveal">
          <strong>Recognition</strong>
          <p>Named as a GGI Ambassador on the website and in Magnalia. Annual Ambassador gathering at the Conference.</p>
        </div>
        <div class="support-item reveal">
          <strong>Complimentary Magnalia</strong>
          <p>Print subscription included for all active Ambassadors — plus extra copies for distribution at your events.</p>
        </div>
        <div class="support-item reveal">
          <strong>Quarterly Briefing</strong>
          <p>Quarterly call with Dr. Topping and fellow Ambassadors — hear what's coming, share what's working.</p>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- Who Should Apply -->
  <section class="section section--linen">
    <div class="container who-section reveal">
      <div class="section-header">
        <p class="label text-gold">Is This You?</p>
        <h2>Ambassadors Are</h2>
      </div>
      <div class="who-grid">
        <div class="who-item">
          <p><strong>Parish leaders</strong> who see the hunger for intellectual formation in their community</p>
        </div>
        <div class="who-item">
          <p><strong>Homeschool parents</strong> connected to families who would thrive in Book Studies and at the Conference</p>
        </div>
        <div class="who-item">
          <p><strong>Catholic professionals</strong> whose networks include mission-aligned people of means</p>
        </div>
        <div class="who-item">
          <p><strong>Young adults</strong> who discovered GGI through a video or event and want to bring it to their friends</p>
        </div>
        <div class="who-item">
          <p><strong>Priests and deacons</strong> who want Magnalia in their parish library and GGI programs for their people</p>
        </div>
        <div class="who-item">
          <p><strong>Retirees</strong> with time, wisdom, and relationships — and a desire to invest them in something lasting</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="label text-gold">Getting Started</p>
        <h2>How It Works</h2>
      </div>
      <div class="steps reveal">
        <div class="step">
          <span class="step__number">1</span>
          <div class="step__content">
            <h3>Apply</h3>
            <p>Fill out the form below. Tell us about your city, your community, and what excites you about the Institute.</p>
          </div>
        </div>
        <div class="step">
          <span class="step__number">2</span>
          <div class="step__content">
            <h3>Connect</h3>
            <p>Victor will schedule a 20-minute call to get to know you, answer questions, and discuss how the program fits your context.</p>
          </div>
        </div>
        <div class="step">
          <span class="step__number">3</span>
          <div class="step__content">
            <h3>Launch</h3>
            <p>Receive your Ambassador kit and resources. Plan your first event or start sharing — on your own timeline, at your own pace.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- Application Form -->
  <section class="section section--linen" id="apply">
    <div class="container form-section">
      <div class="section-header">
        <p class="label text-gold">Apply Now</p>
        <h2>Become a GGI Ambassador</h2>
      </div>
      <form class="amb-form" data-ac-endpoint="/api/ambassador" data-ac-success="Application received! Victor will be in touch." method="POST">
        <div class="form-row">
          <div class="form-group">
            <label for="firstName">First Name *</label>
            <input type="text" id="firstName" name="firstName" required />
          </div>
          <div class="form-group">
            <label for="lastName">Last Name *</label>
            <input type="text" id="lastName" name="lastName" required />
          </div>
        </div>
        <div class="form-group">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" required />
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="city">City *</label>
            <input type="text" id="city" name="city" required />
          </div>
          <div class="form-group">
            <label for="province">Province *</label>
            <select id="province" name="province" required>
              <option value="">Select...</option>
              <option value="AB">Alberta</option>
              <option value="BC">British Columbia</option>
              <option value="MB">Manitoba</option>
              <option value="NB">New Brunswick</option>
              <option value="NL">Newfoundland & Labrador</option>
              <option value="NS">Nova Scotia</option>
              <option value="ON">Ontario</option>
              <option value="PE">Prince Edward Island</option>
              <option value="QC">Quebec</option>
              <option value="SK">Saskatchewan</option>
              <option value="NT">Northwest Territories</option>
              <option value="NU">Nunavut</option>
              <option value="YT">Yukon</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label for="connection">How are you connected to GGI? *</label>
          <select id="connection" name="connection" required>
            <option value="">Select...</option>
            <option value="patron">Current Patron or Friend</option>
            <option value="magnalia-subscriber">Magnalia Subscriber</option>
            <option value="letter-reader">Magnalia Letter Reader</option>
            <option value="event-attendee">Attended an Event</option>
            <option value="book-study">Book Study Participant</option>
            <option value="referral">Referred by Someone</option>
            <option value="new">Just Discovering GGI</option>
          </select>
        </div>
        <div class="form-group">
          <label for="community">Tell us about your community and what excites you about this role. *</label>
          <textarea id="community" name="community" rows="5" required placeholder="E.g., I lead a young adult group at my parish and think our members would love the Book Studies..."></textarea>
        </div>
        <div class="form-group">
          <label for="ideas">Any specific ideas for how you'd like to start? (Optional)</label>
          <textarea id="ideas" name="ideas" rows="3" placeholder="E.g., I'd like to host a wine-and-cheese evening in my home this fall..."></textarea>
        </div>
        <button type="submit" class="form-submit">Submit Application</button>
      </form>
    </div>
  </section>

  <!-- Back -->
  <section class="section" style="text-align: center; padding-block: 32px;">
    <div class="container">
      <Button href={`${base}support/`} variant="secondary">← Back to Support</Button>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero-amb {
    position: relative;
    min-height: 380px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-amb__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 30%;
  }

  .hero-amb__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(14, 51, 82, 0.75), rgba(14, 51, 82, 0.88));
  }

  .hero-amb__content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    padding-block: 60px;
  }

  .hero-amb__content h1 {
    color: var(--color-text-on-dark);
    margin: 8px 0 12px;
  }

  .hero-amb__subtitle {
    font-family: var(--font-body);
    font-size: 1.15rem;
    color: rgba(245, 239, 229, 0.85);
    line-height: 1.6;
  }

  /* Intro */
  .amb-intro {
    max-width: 700px;
    margin-inline: auto;
  }

  .amb-intro__lead {
    font-family: var(--font-body);
    font-size: 1.12rem;
    line-height: 1.8;
    color: var(--color-ink);
    margin-bottom: 14px;
  }

  .amb-intro p {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-gray);
  }

  /* Section header */
  .section-header {
    text-align: center;
    margin-bottom: var(--space-component);
  }

  .section-header h2 {
    margin-top: 8px;
  }

  /* Role cards */
  .roles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    max-width: 900px;
    margin-inline: auto;
  }

  .role-card {
    display: flex;
    background-color: var(--color-parchment);
    border: 1px solid rgba(90, 90, 110, 0.08);
    border-radius: 3px;
    overflow: hidden;
  }

  .role-card__accent {
    width: 5px;
    flex-shrink: 0;
    background-color: var(--color-gold);
  }

  .role-card__body {
    padding: 24px 20px;
  }

  .role-card h3 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 8px;
  }

  .role-card p {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-gray);
  }

  @media (min-width: 768px) {
    .roles-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Support grid */
  .support-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    max-width: 800px;
    margin-inline: auto;
  }

  .support-item {
    padding: 20px 24px;
    background-color: var(--color-linen);
    border-radius: 3px;
    display: flex;
    gap: 16px;
    align-items: baseline;
  }

  .support-item strong {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-navy);
    white-space: nowrap;
    min-width: 160px;
  }

  .support-item p {
    font-family: var(--font-body);
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--color-gray);
    margin: 0;
  }

  @media (max-width: 640px) {
    .support-item {
      flex-direction: column;
      gap: 4px;
    }
    .support-item strong {
      min-width: auto;
    }
  }

  @media (min-width: 640px) {
    .support-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Who section */
  .who-section {
    max-width: 900px;
    margin-inline: auto;
  }

  .who-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .who-item {
    padding: 16px 20px;
    background-color: var(--color-parchment);
    border-left: 3px solid var(--color-gold);
    border-radius: 0 3px 3px 0;
  }

  .who-item p {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-gray);
    margin: 0;
  }

  .who-item strong {
    color: var(--color-navy);
  }

  @media (min-width: 640px) {
    .who-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .who-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Steps */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 600px;
    margin-inline: auto;
  }

  .step {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .step__number {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-gold);
    line-height: 1;
    flex-shrink: 0;
    width: 40px;
    text-align: center;
  }

  .step__content h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 4px;
  }

  .step__content p {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-gray);
  }

  /* Form */
  .form-section {
    max-width: 640px;
    margin-inline: auto;
  }

  .amb-form {
    background-color: var(--color-parchment);
    border: 1px solid rgba(90, 90, 110, 0.1);
    border-radius: 3px;
    padding: 32px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  @media (max-width: 480px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }

  .form-group {
    margin-bottom: 16px;
  }

  .form-group label {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-navy);
    margin-bottom: 6px;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    padding: 10px 14px;
    border: 1px solid rgba(90, 90, 110, 0.2);
    border-radius: 3px;
    background-color: white;
    color: var(--color-ink);
    outline: none;
    transition: border-color var(--transition-fast);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--color-gold);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 80px;
  }

  .form-submit {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    padding: 14px 40px;
    background-color: var(--color-crimson);
    color: var(--color-parchment);
    border: none;
    border-radius: 3px;
    cursor: pointer;
    transition: background-color var(--transition-fast);
    display: block;
    width: 100%;
  }

  .form-submit:hover {
    background-color: #6b2124;
  }

  .section--linen {
    background-color: var(--color-linen);
  }
</style>
