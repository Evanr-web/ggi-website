---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GivingTier from '../../components/GivingTier.astro';
import Button from '../../components/Button.astro';
import SectionDivider from '../../components/SectionDivider.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Support the Institute" description="Your patronage builds Catholic intellectual life in Canada. Join as a Friend, Patron, or Underwriter.">

  <!-- Hero -->
  <section class="hero-compact section--dark">
    <div class="hero-compact__bg" style={`background-image: url(${import.meta.env.BASE_URL}images/art/Bodleian-Library-Oxford.jpg)`}></div>
    <div class="hero-compact__overlay"></div>
    <div class="hero-compact__content container">
      <h1 class="display">Support the Institute</h1>
      <p class="hero-compact__subtitle">Your patronage builds Catholic intellectual life in Canada.</p>
    </div>
  </section>

  <!-- Case for Support -->
  <section class="section">
    <div class="container case-section reveal">
      <div class="case-hook">
        <p class="support-hook">1,500 people. Every bishop in Canada. Four provinces. One year.</p>
        <h2>Now imagine year two.</h2>
      </div>
      <div class="case-body">
        <p>
          In its first twelve months, the Gregory the Great Institute published <em>Magnalia</em> and placed it
          in the hands of every Catholic bishop and seminary rector in Canada. We ran formation programs in
          four provinces. We hosted the inaugural Renewing Culture Conference. We launched Book Study groups
          that are now multiplying coast to coast. We did this on a lean budget with a small team — because
          the mission is real and the need is urgent.
        </p>
        <p>
          Catholic intellectual life in Canada has been in retreat for a generation. The institutions that
          once formed leaders, shaped public discourse, and transmitted the tradition have weakened or
          disappeared. The Gregory the Great Institute exists to rebuild that infrastructure — not by
          lamenting what was lost, but by building what comes next.
        </p>
        <p>
          Your support doesn't fund an organization. It funds a movement: courses that form the next
          generation of Catholic leaders, a journal that gives the Church's best thinkers a platform,
          research that equips Catholics to engage the culture with confidence, and gatherings that turn
          isolated believers into a community with shared purpose.
        </p>
        <p class="case-cta-line">
          <strong>Every tier below is a named relationship — not a donation receipt.</strong> You are not
          giving to a cause. You are joining a community that is building something that will outlast all of us.
        </p>
      </div>
    </div>
  </section>

  <!-- Giving Tiers -->
  <section class="section section--linen" style="padding-top: 36px;">
    <div class="container">
      <div class="section-header">
        <p class="label text-gold">Join the Mission</p>
        <h2>Choose Your Role</h2>
      </div>

      <div class="tiers-grid reveal">
        <GivingTier
          name="Friend of the Institute"
          monthlyPrice="$15+"
          annualPrice="$180+"
          description="The foundation. Join the growing community sustaining Catholic cultural renewal."
          benefits={[
            "Monthly prayer inclusion",
            "Magnalia Letter (curated monthly guide)",
            "Magnalia digital edition (PDF)",
            "Early event registration",
            "Named recognition on the website"
          ]}
          ctaText="Become a Friend"
          ctaHref={`${base}support/friend/`}
        />
        <GivingTier
          name="Patron"
          monthlyPrice="$50+"
          annualPrice="$600+"
          description="The backbone of the Institute. Patrons make everything possible."
          benefits={[
            "Everything in Friend, plus:",
            "Magnalia print subscription included",
            "Named recognition in Magnalia",
            "Signed copy of Renewing Catholic Schools",
            "Annual Patron gathering with Dr. Topping",
            "Conference early-bird + 10% discount"
          ]}
          featured={true}
          ctaText="Become a Patron"
          ctaHref={`${base}magnalia/patron/`}
        />
        <GivingTier
          name="Leadership Circle"
          monthlyPrice="—"
          annualPrice="$5,000+"
          description="Strategic partners building the future of Catholic culture in Canada."
          benefits={[
            "Everything in Patron, plus:",
            "Personal relationship with Dr. Topping",
            "Input on Institute direction",
            "Named recognition in flagship programs",
            "Annual Leadership gathering"
          ]}
          ctaText="Request a Conversation"
          ctaHref={`${base}support/leadership/`}
        />
      </div>
    </div>
  </section>

  <!-- Social Proof — Scrolling Endorsements -->
  <section class="section" style="padding-block: 48px;">
    <div class="container">
      <div class="endorsement-carousel" id="endorsement-carousel">
        <div class="endorsement-track">
          <blockquote class="endorsement-slide">
            <p>"I have known Dr. Ryan Topping and appreciated his work for a long time. I am delighted to see this important work that he is doing to continue building up the Catholic community and advancing the common good in Canada."</p>
            <footer>
              <img src={`${import.meta.env.BASE_URL}images/people/Garnett-Genuis-headshot.jpg`} alt="Garnett Genuis" class="endorsement-photo" />
              <div>
                <cite>Garnett Genuis, M.P.</cite>
              </div>
            </footer>
          </blockquote>
          <blockquote class="endorsement-slide">
            <p>"The Gregory the Great Institute shows great promise in its commitment to forming Canadian Catholic leaders in all walks of life. Dr Ryan Topping has established a reputation as one our country's most prolific and insightful Catholic scholars. Dr Topping is well placed to play a major role in the revival of Catholic culture and its active influence in Canadian public life."</p>
            <footer>
              <img src={`${import.meta.env.BASE_URL}images/people/Robert-Berard-headshot.jpg`} alt="Robert Nicholas Berard" class="endorsement-photo" />
              <div>
                <cite>Robert Nicholas Berard, Ph.D.</cite>
                <span>President, Fellowship of Catholic Scholars (Canada)</span>
              </div>
            </footer>
          </blockquote>
          <blockquote class="endorsement-slide">
            <p>"I have appreciated Dr. Ryan Topping's work for several years. I support the mission of the Gregory the Great Institute and look forward to seeing the good it will bring to the Church in Canada."</p>
            <footer>
              <img src={`${import.meta.env.BASE_URL}images/people/Michael-OBrien-headshot.jpg`} alt="Michael D. O'Brien" class="endorsement-photo" />
              <div>
                <cite>Michael D. O'Brien</cite>
                <span>Canadian author and painter</span>
              </div>
            </footer>
          </blockquote>
          <blockquote class="endorsement-slide">
            <p>"Dr. Ryan Topping is among Canada's most important philosopher-theologians. His work on renewing Catholic culture over the years stands in the tradition of Cardinal Newman and G.K. Chesterton. I anticipate good things from the Gregory the Great Institute."</p>
            <footer>
              <img src={`${import.meta.env.BASE_URL}images/people/Aidan-Nichols-headshot.jpg`} alt="Fr. Aidan Nichols" class="endorsement-photo" />
              <div>
                <cite>Fr. Aidan Nichols, O.P.</cite>
                <span>Theologian and author of over 40 books</span>
              </div>
            </footer>
          </blockquote>
        </div>
        <div class="endorsement-dots" id="endorsement-dots"></div>
      </div>
    </div>
  </section>

  <!-- Ambassador CTA -->
  <section class="section">
    <div class="container ambassador-cta reveal">
      <div class="ambassador-cta__inner">
        <div class="ambassador-cta__text">
          <p class="label text-gold">Grow the Mission</p>
          <h2>Become an Ambassador</h2>
          <p>
            Know people who should know about the Gregory the Great Institute? Ambassadors bring Catholic cultural renewal to their
            own communities — hosting events, sharing resources, and making introductions. We provide
            the materials and support. You provide the community.
          </p>
          <Button href={`${base}support/ambassadors/`} variant="primary">Learn More & Apply</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- One-Time Giving -->
  <section class="section section--linen">
    <div class="container" style="text-align: center; max-width: 600px; margin-inline: auto;">
      <h2 style="margin-bottom: 12px;">One-Time Gift</h2>
      <p style="font-family: var(--font-body); font-size: 1rem; color: var(--color-gray); margin-bottom: 24px; line-height: 1.7;">
        Prefer to make a one-time gift? Every contribution builds Catholic culture in Canada.
      </p>
      <Button href={`${import.meta.env.BASE_URL}support/donate/`} variant="primary">Make a Gift</Button>
    </div>
  </section>

  <!-- For Clergy & Institutions -->
  <section class="section">
    <div class="container institutional-section">
      <div class="institutional-card">
        <h2>For Parishes, Seminaries & Institutions</h2>
        <p>
          Put Magnalia in the hands of your community. Bulk orders of 10+ copies at $30 each — ideal for narthex distribution, seminary libraries, and reading groups.
        </p>
        <div class="institutional-ctas">
          <Button href={`${import.meta.env.BASE_URL}magnalia/subscribe/`} variant="secondary" size="small">Place a Bulk Order</Button>
          <Button href={`${import.meta.env.BASE_URL}contact/`} variant="tertiary" size="small">Invite Dr. Topping to Speak →</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Charitable Registration -->
  <section class="section--footnote">
    <div class="container">
      <p class="charitable-note">
        Tax-deductible donations are processed through Catholic Voices Canada. Please specify "New Cultural Institute"
        on your donation form. Charitable registration pending. For questions about giving, contact
        <a href="mailto:info@gregorythegreat.ca">info@gregorythegreat.ca</a>.
      </p>
    </div>
  </section>

</BaseLayout>

<style>
  .hero-compact {
    position: relative;
    min-height: 360px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-compact__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }

  .hero-compact__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(14, 51, 82, 0.72);
  }

  .hero-compact__content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    padding-block: 60px;
  }

  .hero-compact__content h1 {
    color: var(--color-text-on-dark);
    margin-bottom: 12px;
  }

  .hero-compact__subtitle {
    font-family: var(--font-body);
    font-size: 1.15rem;
    color: rgba(245, 239, 229, 0.85);
  }

  /* Case for Support */
  .case-section {
    max-width: 740px;
    margin-inline: auto;
  }

  .case-hook {
    text-align: center;
    margin-bottom: 32px;
  }

  .case-body p {
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: 1.8;
    color: var(--color-gray);
    margin-bottom: 16px;
  }

  .case-body p:last-child {
    margin-bottom: 0;
  }

  .case-cta-line {
    font-size: 1.05rem;
    color: var(--color-ink);
    padding-top: 8px;
    border-top: 1px solid rgba(184, 154, 71, 0.3);
    margin-top: 24px;
    padding-top: 24px;
    text-align: center;
  }

  .support-hook {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--color-gold);
    letter-spacing: 0.03em;
    margin-bottom: 4px;
  }

  /* Endorsement Carousel */
  .endorsement-carousel {
    max-width: 640px;
    margin-inline: auto;
    text-align: center;
    overflow: hidden;
    position: relative;
  }

  .endorsement-track {
    display: flex;
    transition: transform 0.5s ease;
  }

  .endorsement-slide {
    min-width: 100%;
    padding: 0 20px;
    box-sizing: border-box;
    margin: 0;
  }

  .endorsement-slide p {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-style: italic;
    line-height: 1.6;
    color: var(--color-navy);
    margin-bottom: 16px;
  }

  .endorsement-slide footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .endorsement-slide footer div {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: left;
  }

  .endorsement-photo {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    flex-shrink: 0;
  }

  .endorsement-slide cite {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 600;
    font-style: normal;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .endorsement-slide footer span {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-gray);
    font-style: italic;
  }

  .endorsement-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }

  :global(.endorsement-dot) {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: rgba(27, 42, 74, 0.2);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s;
  }

  :global(.endorsement-dot--active) {
    background-color: var(--color-crimson);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-component);
  }

  .section-header h2 {
    margin-top: 8px;
  }

  /* Tiers Grid */
  .tiers-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 640px) {
    .tiers-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .tiers-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Founding Fellow */
  .founding-fellow {
    margin-top: var(--space-component);
    padding: 28px;
    border: 1px solid rgba(184, 154, 71, 0.3);
    border-radius: 3px;
    background-color: var(--color-linen);
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
  }

  .founding-fellow h3 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--color-navy);
    margin: 8px 0 12px;
  }

  .founding-fellow p {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-gray);
    line-height: 1.6;
    margin-bottom: 20px;
  }

  /* Ambassador CTA */
  .ambassador-cta__inner {
    max-width: 640px;
    margin-inline: auto;
    text-align: center;
    padding: 40px 32px;
    border: 2px solid var(--color-gold);
    border-radius: 3px;
    background-color: var(--color-linen);
  }

  .ambassador-cta__text h2 {
    margin: 6px 0 12px;
  }

  .ambassador-cta__text p {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-gray);
    margin-bottom: 20px;
  }

  /* Institutional */
  .institutional-section {
    max-width: 700px;
    margin-inline: auto;
  }

  .institutional-card {
    padding: 32px;
    border: 2px solid var(--color-gold);
    border-radius: 3px;
    text-align: center;
  }

  .institutional-card h2 {
    margin-bottom: 12px;
  }

  .institutional-card p {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-gray);
    margin-bottom: 20px;
    line-height: 1.6;
  }

  .institutional-ctas {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Footnote */
  .section--footnote {
    padding: 24px 0;
    border-top: 1px solid rgba(90, 90, 110, 0.08);
  }

  .charitable-note {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--color-gray);
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
    line-height: 1.6;
  }

  .charitable-note a {
    color: var(--color-gold);
    text-decoration: none;
  }

  .section--linen {
    background-color: var(--color-linen);
  }
</style>

<script>
  const track = document.querySelector('.endorsement-track');
  const slides = document.querySelectorAll('.endorsement-slide');
  const dotsContainer = document.getElementById('endorsement-dots');
  let current = 0;

  // Create dots
  slides.forEach((_, i) => {
    const dot = document.createElement('button');
    dot.className = `endorsement-dot${i === 0 ? ' endorsement-dot--active' : ''}`;
    dot.setAttribute('aria-label', `Endorsement ${i + 1}`);
    dot.addEventListener('click', () => goTo(i));
    dotsContainer?.appendChild(dot);
  });

  function goTo(index: number) {
    current = index;
    if (track instanceof HTMLElement) {
      track.style.transform = `translateX(-${current * 100}%)`;
    }
    document.querySelectorAll('.endorsement-dot').forEach((d, i) => {
      d.classList.toggle('endorsement-dot--active', i === current);
    });
  }

  // Auto-advance every 6 seconds
  let autoTimer = setInterval(() => {
    goTo((current + 1) % slides.length);
  }, 6000);

  // Touch swipe support
  let touchStartX = 0;
  let touchEndX = 0;

  const carousel = document.getElementById('endorsement-carousel');

  carousel?.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
    clearInterval(autoTimer);
  }, { passive: true });

  carousel?.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) > 50) {
      if (diff > 0 && current < slides.length - 1) {
        goTo(current + 1);
      } else if (diff < 0 && current > 0) {
        goTo(current - 1);
      }
    }
    // Restart auto-advance after swipe
    autoTimer = setInterval(() => {
      goTo((current + 1) % slides.length);
    }, 6000);
  }, { passive: true });
</script>
