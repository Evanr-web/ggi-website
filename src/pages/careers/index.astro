---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import { getActiveCareerPostings } from '../../lib/sanity';
const base = import.meta.env.BASE_URL;

// Try Sanity first
let cmsPostings: any[] = [];
try { cmsPostings = await getActiveCareerPostings() || []; } catch (e) { /* fallback */ }
const hasCmsPostings = cmsPostings.length > 0;
---

<BaseLayout title="Careers & Opportunities — Gregory the Great Institute" description="Join the team renewing Catholic culture in Canada. Current jobs, internships, and volunteer opportunities.">

  <!-- Hero -->
  <section class="hero-careers section--dark">
    <div class="hero-careers__bg" style={`background-image: url(${base}images/art/school-of-athens.jpg)`}></div>
    <div class="hero-careers__overlay"></div>
    <div class="hero-careers__content container">
      <p class="label text-gold">Join the Mission</p>
      <h1 class="display">Careers & Opportunities</h1>
      <p class="hero-careers__subtitle">Help build the future of Catholic intellectual life in Canada.</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="section">
    <div class="container careers-intro reveal">
      <p>
        The Gregory the Great Institute is a small team doing big work — publishing, programming,
        and building community across Canada. We're always looking for talented people who share
        the mission and want to contribute their gifts.
      </p>
    </div>
  </section>

  <!-- Current Openings -->
  <section class="section section--linen">
    <div class="container">
      <div class="section-header">
        <p class="label text-gold">Current Openings</p>
        <h2>Open Positions</h2>
      </div>

      <!-- CMS Postings (from Sanity) -->
      {cmsPostings.map((posting: any) => (
        <div class="posting reveal">
          <div class="posting__header">
            <div>
              <h3>{posting.title}</h3>
              <div class="posting__meta">
                <span class={`posting__badge posting__badge--${posting.type}`}>{posting.type}</span>
                {posting.location && <span>{posting.location}</span>}
                {posting.deadline && <span>Deadline: {new Date(posting.deadline).toLocaleDateString('en-CA', { month: 'short', day: 'numeric', year: 'numeric' })}</span>}
              </div>
            </div>
          </div>
          <div class="posting__body">
            {posting.summary && <p>{posting.summary}</p>}
            <div class="posting__details">
              {posting.compensation && (
                <div class="posting__detail">
                  <strong>Compensation</strong>
                  <span>{posting.compensation}</span>
                </div>
              )}
              {posting.location && (
                <div class="posting__detail">
                  <strong>Location</strong>
                  <span>{posting.location}</span>
                </div>
              )}
              {posting.startDate && (
                <div class="posting__detail">
                  <strong>Start Date</strong>
                  <span>{new Date(posting.startDate).toLocaleDateString('en-CA', { month: 'long', year: 'numeric' })}</span>
                </div>
              )}
            </div>
            <div class="posting__actions">
              {(posting.detailsPdfUrl || posting.externalPdfUrl) && (
                <a href={posting.detailsPdfUrl || posting.externalPdfUrl} target="_blank" rel="noopener" class="posting__pdf-link">📄 View Full Job Description (PDF)</a>
              )}
              <Button href="#apply" variant="primary">Apply Now</Button>
            </div>
          </div>
        </div>
      ))}

      <!-- Hardcoded Internship Posting (fallback when Sanity is empty) -->
      {!hasCmsPostings && <div class="posting reveal">
        <div class="posting__header">
          <div>
            <h3>Communications & Development Intern</h3>
            <div class="posting__meta">
              <span class="posting__badge posting__badge--internship">Internship</span>
              <span>Edmonton, AB</span>
              <span>Summer 2026</span>
            </div>
          </div>
        </div>
        <div class="posting__body">
          <p>
            A summer internship funded through the Canada Summer Jobs program. Work alongside
            the Institute's communications and development team to support donor relations,
            event planning, content creation, and community engagement. Ideal for a university
            student passionate about Catholic culture, communications, or nonprofit work.
          </p>

          <div class="posting__details">
            <div class="posting__detail">
              <strong>Duration</strong>
              <span>8 weeks (Summer 2026)</span>
            </div>
            <div class="posting__detail">
              <strong>Compensation</strong>
              <span>Paid — Canada Summer Jobs rate</span>
            </div>
            <div class="posting__detail">
              <strong>Location</strong>
              <span>Edmonton, AB (in-person)</span>
            </div>
            <div class="posting__detail">
              <strong>Deadline</strong>
              <span>Until filled</span>
            </div>
          </div>

          <div class="posting__actions">
            <a href="https://adbcbf1f-fcf5-4099-8aa0-1d9b99602ff4.filesusr.com/ugd/437a61_94bcb2ff7ea940748db1658ede8a843a.pdf" target="_blank" rel="noopener" class="posting__pdf-link">📄 View Full Job Description (PDF)</a>
            <Button href="#apply" variant="primary">Apply Now</Button>
          </div>
        </div>
      </div>}

      <!-- Postings now driven by Sanity when available -->
    </div>
  </section>

  <SectionDivider />

  <!-- No Openings Fallback (hidden when there are postings) -->
  <!--
  <section class="section">
    <div class="container container--xs text-center">
      <h2>No Current Openings</h2>
      <p class="cta-desc" style="line-height: 1.7;">
        We don't have any positions open right now, but we're always interested in hearing from
        talented people. Subscribe to the Magnalia Letter to hear about future opportunities.
      </p>
      <Button href={`${base}magnalia/letter/`} variant="primary">Subscribe to the Letter</Button>
    </div>
  </section>
  -->

  <!-- Application Form -->
  <section class="section" id="apply">
    <div class="container form-section">
      <div class="section-header">
        <p class="label text-gold">Apply</p>
        <h2>Submit Your Application</h2>
      </div>
      <form class="career-form" data-ac-endpoint="/api/career" data-ac-success="Application received! We'll review it and be in touch." method="POST" enctype="multipart/form-data">
        <div class="form-row">
          <div class="form-group">
            <label for="firstName">First Name *</label>
            <input type="text" id="firstName" name="firstName" required />
          </div>
          <div class="form-group">
            <label for="lastName">Last Name *</label>
            <input type="text" id="lastName" name="lastName" required />
          </div>
        </div>
        <div class="form-group">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" required />
        </div>
        <div class="form-group">
          <label for="phone">Phone</label>
          <input type="tel" id="phone" name="phone" />
        </div>
        <div class="form-group">
          <label for="position">Position Applying For *</label>
          <select id="position" name="position" required>
            <option value="">Select...</option>
            {cmsPostings.map((p: any) => (
              <option value={p.slug?.current || p.title}>{p.title}</option>
            ))}
            {!hasCmsPostings && <option value="communications-intern-2026">Communications & Development Intern — Summer 2026</option>}
            <option value="general">General Interest / Future Openings</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message">Tell us about yourself and why you're interested *</label>
          <textarea id="message" name="message" rows="5" required placeholder="Your background, what draws you to the Institute, and what you'd bring to the role..."></textarea>
        </div>
        <div class="form-group">
          <label for="resume">Resume / CV (PDF) *</label>
          <input type="file" id="resume" name="resume" accept=".pdf,.doc,.docx" required />
          <p class="form-hint">PDF preferred. Max 5MB.</p>
        </div>
        <button type="submit" class="form-submit">Submit Application</button>
      </form>
    </div>
  </section>

  <!-- Volunteer -->
  <section class="section section--linen">
    <div class="container volunteer-section reveal">
      <div class="volunteer-inner">
        <p class="label text-gold">Not Looking for a Job?</p>
        <h2>Volunteer With Us</h2>
        <p>
          We rely on volunteers for events, Book Studies, and community outreach. If you'd like to
          contribute your time and talents — in any capacity — we'd love to hear from you.
        </p>
        <Button href={`${base}contact/`} variant="secondary">Get in Touch</Button>
      </div>
    </div>
  </section>

  <section class="text-center" style="padding: 24px 0 48px;">
    <a href={`${base}`} class="back-link">← Back to Home</a>
  </section>

</BaseLayout>

<style>
  .hero-careers {
    position: relative;
    min-height: 340px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-careers__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 30%;
  }

  .hero-careers__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(14, 51, 82, 0.75), rgba(14, 51, 82, 0.88));
  }

  .hero-careers__content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    padding-block: 60px;
  }

  .hero-careers__content h1 {
    color: var(--color-text-on-dark);
    margin: 8px 0 12px;
  }

  .hero-careers__subtitle {
    font-family: var(--font-body);
    font-size: 1.12rem;
    color: rgba(245, 239, 229, 0.85);
  }

  /* Intro */
  .careers-intro {
    max-width: 680px;
    margin-inline: auto;
  }

  .careers-intro p {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-gray);
    text-align: center;
  }

  /* Section header */
  .section-header {
    text-align: center;
    margin-bottom: var(--space-component);
  }

  .section-header h2 { margin-top: 8px; }

  /* Posting */
  .posting {
    max-width: 800px;
    margin-inline: auto;
    background-color: var(--color-parchment);
    border: 1px solid rgba(90, 90, 110, 0.1);
    border-radius: 3px;
    padding: 32px;
  }

  .posting__header h3 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--color-navy);
    margin-bottom: 8px;
  }

  .posting__meta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    font-family: var(--font-ui);
    font-size: 0.82rem;
    color: var(--color-gray);
    align-items: center;
  }

  .posting__badge {
    padding: 3px 10px;
    border-radius: 3px;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .posting__badge--internship {
    background-color: rgba(184, 154, 71, 0.15);
    color: var(--color-gold);
  }

  .posting__body {
    margin-top: 20px;
  }

  .posting__body > p {
    font-family: var(--font-body);
    font-size: 0.98rem;
    line-height: 1.7;
    color: var(--color-gray);
    margin-bottom: 20px;
  }

  .posting__details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 24px;
  }

  .posting__detail {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .posting__detail strong {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-navy);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .posting__detail span {
    font-family: var(--font-body);
    font-size: 0.92rem;
    color: var(--color-gray);
  }

  .posting__actions {
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }

  .posting__pdf-link {
    font-family: var(--font-ui);
    font-size: 0.88rem;
    color: var(--color-gold);
    text-decoration: none;
    font-weight: 500;
  }

  .posting__pdf-link:hover { color: var(--color-crimson); }

  @media (max-width: 480px) {
    .posting__details { grid-template-columns: 1fr; }
  }

  /* Form */
  .form-section {
    max-width: 640px;
    margin-inline: auto;
  }

  .career-form {
    background-color: var(--color-linen);
    border: 1px solid rgba(90, 90, 110, 0.1);
    border-radius: 3px;
    padding: 32px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  @media (max-width: 480px) {
    .form-row { grid-template-columns: 1fr; }
  }

  .form-group {
    margin-bottom: 16px;
  }

  .form-group label {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-navy);
    margin-bottom: 6px;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    padding: 10px 14px;
    border: 1px solid rgba(90, 90, 110, 0.2);
    border-radius: 3px;
    background-color: white;
    color: var(--color-ink);
    outline: none;
    transition: border-color var(--transition-fast);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--color-gold);
  }

  .form-group input[type="file"] {
    padding: 8px;
    font-size: 0.85rem;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 80px;
  }

  .form-hint {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--color-gray);
    margin-top: 4px;
  }

  .form-submit {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    padding: 14px 40px;
    background-color: var(--color-crimson);
    color: var(--color-parchment);
    border: none;
    border-radius: 3px;
    cursor: pointer;
    transition: background-color var(--transition-fast);
    display: block;
    width: 100%;
  }

  .form-submit:hover { background-color: #6b2124; }

  /* Volunteer */
  .volunteer-inner {
    max-width: 560px;
    margin-inline: auto;
    text-align: center;
  }

  .volunteer-inner h2 {
    margin: 6px 0 12px;
  }

  .volunteer-inner p {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-gray);
    margin-bottom: 20px;
  }

  .back-link {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-gold);
    text-decoration: none;
    font-weight: 500;
  }

  .back-link:hover { color: var(--color-crimson); }

  .section--linen { background-color: var(--color-linen); }
</style>
