---
interface Props {
  quote: string;
  attribution: string;
  title?: string;
  variant?: 'light' | 'dark';
}

const { quote, attribution, title, variant = 'light' } = Astro.props;
---

<blockquote class:list={['quote-block', `quote-block--${variant}`]}>
  <span class="quote-block__mark">&ldquo;</span>
  <p class="quote-block__text">{quote}</p>
  <footer class="quote-block__footer">
    <cite class="quote-block__attribution">{attribution}</cite>
    {title && <span class="quote-block__title">{title}</span>}
  </footer>
</blockquote>

<style>
  .quote-block {
    position: relative;
    padding: 16px 0;
    text-align: center;
    max-width: 720px;
    margin-inline: auto;
  }

  .quote-block__mark {
    font-family: var(--font-display);
    font-size: 4rem;
    line-height: 1;
    color: var(--color-gold);
    display: block;
    margin-bottom: 8px;
  }

  .quote-block__text {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-style: italic;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-navy);
  }

  .quote-block--dark .quote-block__text {
    color: var(--color-text-on-dark);
  }

  .quote-block__footer {
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .quote-block__attribution {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 600;
    font-style: normal;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .quote-block__title {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-gray);
    font-style: italic;
  }

  .quote-block--dark .quote-block__title {
    color: rgba(245, 239, 229, 0.6);
  }

  @media (max-width: 640px) {
    .quote-block__text {
      font-size: 1.25rem;
    }
    .quote-block__mark {
      font-size: 3rem;
    }
  }
</style>
