---
const navLinks = [
  { label: 'Magnalia', href: '/magnalia' },
  { label: 'Programs', href: '/programs' },
  { label: 'Events', href: '/events' },
  { label: 'About', href: '/about' },
  { label: 'Library', href: '/library' },
  { label: 'Support', href: '/support' },
];

const secondaryLinks = [
  { label: 'Contact & Speaker Booking', href: '/contact' },
  { label: 'For Clergy & Institutions', href: '/magnalia/subscribe#institutional' },
  { label: 'Privacy Policy', href: '/privacy' },
];

const currentYear = new Date().getFullYear();
---

<!-- Footer CTA Strip -->
<div class="footer-cta-strip">
  <div class="container footer-cta-strip__inner">
    <p class="footer-cta-strip__text">Become a Friend of the Institute — from $10/month</p>
    <a href="/support" class="footer-cta-strip__btn">Support the Mission</a>
  </div>
</div>

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <!-- Column 1: Brand -->
      <div class="footer__brand">
        <img src="/images/branding/ggi-seal.png" alt="GGI Seal" class="footer__logo" />
        <p class="footer__tagline">Fides&ensp;•&ensp;Ratio&ensp;•&ensp;Cultura</p>
        <p class="footer__mission">
          Equipping Christians to renew culture in the light of faith and reason.
        </p>
      </div>

      <!-- Column 2: Navigation -->
      <div class="footer__col">
        <p class="footer__heading">Navigate</p>
        <nav aria-label="Footer navigation">
          {navLinks.map(link => (
            <a href={link.href} class="footer__link">{link.label}</a>
          ))}
        </nav>
      </div>

      <!-- Column 3: Contact -->
      <div class="footer__col">
        <p class="footer__heading">Get in Touch</p>
        <a href="mailto:info@gregorythegreat.ca" class="footer__email">info@gregorythegreat.ca</a>
        {secondaryLinks.map(link => (
          <a href={link.href} class="footer__link">{link.label}</a>
        ))}
        <div class="footer__social">
          <a href="https://www.youtube.com/@gregorythegreatinstitute" aria-label="YouTube" target="_blank" rel="noopener">YouTube</a>
          <a href="https://www.instagram.com/gregorythegreatinstitute/" aria-label="Instagram" target="_blank" rel="noopener">Instagram</a>
        </div>
      </div>

      <!-- Column 4: Newsletter -->
      <div class="footer__col">
        <p class="footer__heading">Magnalia Letter</p>
        <p class="footer__newsletter-desc">Free monthly essays, event invitations, and reading recommendations.</p>
        <form class="footer__form" action="#" method="POST">
          <input type="text" name="firstName" placeholder="First name" class="footer__input" required />
          <input type="email" name="email" placeholder="Email address" class="footer__input" required />
          <button type="submit" class="footer__submit">Subscribe</button>
        </form>
      </div>
    </div>

    <hr class="gold-rule" style="opacity: 0.3;" />

    <div class="footer__bottom">
      <p class="footer__legal">
        &copy; {currentYear} Gregory the Great Institute. All rights reserved.
      </p>
      <p class="footer__charity">
        Tax-deductible donations processed through Catholic Voices Canada. Charitable registration pending.
      </p>
    </div>
  </div>
</footer>

<style>
  /* CTA Strip */
  .footer-cta-strip {
    background-color: var(--color-parchment);
    border-top: 1px solid var(--color-gold);
    border-bottom: 1px solid rgba(14, 51, 82, 0.08);
    padding: 16px 0;
  }

  .footer-cta-strip__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .footer-cta-strip__text {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-navy);
  }

  .footer-cta-strip__btn {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-parchment);
    background-color: var(--color-gold);
    padding: 8px 24px;
    border-radius: 3px;
    text-decoration: none;
    transition: background-color var(--transition-fast);
  }

  .footer-cta-strip__btn:hover {
    background-color: #a08638;
    color: var(--color-parchment);
  }

  /* Footer */
  .footer {
    background-color: var(--color-navy);
    color: var(--color-text-on-dark);
    padding-block: var(--space-section) var(--space-component);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-component);
  }

  .footer__logo {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    margin-bottom: 12px;
  }

  .footer__tagline {
    font-family: var(--font-display);
    font-size: 1rem;
    font-style: italic;
    color: var(--color-gold);
    margin-bottom: 10px;
  }

  .footer__mission {
    font-family: var(--font-body);
    font-size: 0.88rem;
    line-height: 1.6;
    color: rgba(245, 239, 229, 0.65);
    max-width: 280px;
  }

  .footer__heading {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 14px;
    color: var(--color-text-on-dark);
  }

  .footer__col nav,
  .footer__col {
    display: flex;
    flex-direction: column;
  }

  .footer__link {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 400;
    color: rgba(245, 239, 229, 0.7);
    text-decoration: none;
    padding: 4px 0;
    transition: color var(--transition-fast);
  }

  .footer__link:hover {
    color: var(--color-gold);
  }

  .footer__email {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--color-gold);
    text-decoration: none;
    margin-bottom: 12px;
    display: block;
  }

  .footer__email:hover {
    text-decoration: underline;
  }

  .footer__social {
    display: flex;
    gap: 16px;
    margin-top: 12px;
  }

  .footer__social a {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(245, 239, 229, 0.5);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__social a:hover {
    color: var(--color-gold);
  }

  /* Newsletter form */
  .footer__newsletter-desc {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: rgba(245, 239, 229, 0.6);
    line-height: 1.5;
    margin-bottom: 14px;
  }

  .footer__form {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-width: 260px;
  }

  .footer__input {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    padding: 10px 12px;
    background: rgba(245, 239, 229, 0.06);
    border: 1px solid rgba(245, 239, 229, 0.15);
    border-radius: 3px;
    color: var(--color-text-on-dark);
    outline: none;
    transition: border-color var(--transition-fast);
  }

  .footer__input::placeholder {
    color: rgba(245, 239, 229, 0.35);
  }

  .footer__input:focus {
    border-color: var(--color-gold);
  }

  .footer__submit {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 10px 20px;
    background-color: var(--color-gold);
    color: var(--color-navy);
    border: none;
    border-radius: 3px;
    cursor: pointer;
    transition: background-color var(--transition-fast);
  }

  .footer__submit:hover {
    background-color: #a08638;
  }

  /* Bottom */
  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .footer__legal,
  .footer__charity {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    color: rgba(245, 239, 229, 0.35);
  }

  /* Responsive */
  @media (min-width: 640px) {
    .footer__top {
      grid-template-columns: 1.4fr 0.8fr 1fr;
    }

    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  @media (min-width: 1024px) {
    .footer__top {
      grid-template-columns: 1.5fr 0.8fr 1fr 1.2fr;
    }
  }
</style>
