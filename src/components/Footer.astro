---
const base = import.meta.env.BASE_URL;
const navLinks = [
  { label: 'Magnalia', href: `${base}magnalia/` },
  { label: 'Programs', href: `${base}programs/` },
  { label: 'Events', href: `${base}events/` },
  { label: 'About', href: `${base}about/` },
  { label: 'Library', href: `${base}library/` },
  { label: 'Support', href: `${base}support/` },
];

const secondaryLinks = [
  { label: 'Contact & Speaker Booking', href: `${base}contact/` },
  { label: 'For Clergy & Institutions', href: `${base}magnalia/subscribe/#institutional` },
  { label: 'Careers & Opportunities', href: `${base}careers/` },
  { label: 'Privacy Policy', href: `${base}privacy/` },
  { label: 'Image Credits', href: `${base}credits/` },
];

const currentYear = new Date().getFullYear();
---

<!-- Footer CTA Strip -->
<div class="footer-cta-strip">
  <div class="container footer-cta-strip__inner">
    <p class="footer-cta-strip__text">Become a Friend of the Institute — from $15/month</p>
    <a href={`${import.meta.env.BASE_URL}support/`} class="footer-cta-strip__btn">Support the Mission</a>
  </div>
</div>

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer__top">
      <!-- Column 1: Brand -->
      <div class="footer__brand">
        <img src={`${import.meta.env.BASE_URL}images/branding/ggi-seal.png`} alt="GGI Seal" class="footer__logo" />
        <p class="footer__tagline">Fides&ensp;•&ensp;Ratio&ensp;•&ensp;Cultura</p>
        <p class="footer__mission">
          Equipping Christians to renew culture in the light of faith and reason.
        </p>
      </div>

      <!-- Column 2: Navigation -->
      <div class="footer__col">
        <p class="footer__heading">Navigate</p>
        <nav aria-label="Footer navigation">
          {navLinks.map(link => (
            <a href={link.href} class="footer__link">{link.label}</a>
          ))}
        </nav>
      </div>

      <!-- Column 3: Contact -->
      <div class="footer__col">
        <p class="footer__heading">Get in Touch</p>
        <a href="mailto:info@gregorythegreat.ca" class="footer__email">info@gregorythegreat.ca</a>
        {secondaryLinks.map(link => (
          <a href={link.href} class="footer__link">{link.label}</a>
        ))}
        <div class="footer__social">
          <a href="https://www.youtube.com/@gregorythegreatinstitute" aria-label="YouTube" target="_blank" rel="noopener" class="footer__social-icon">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a href="https://www.instagram.com/gregorythegreatinstitute/" aria-label="Instagram" target="_blank" rel="noopener" class="footer__social-icon">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a>
          <a href="https://gregorythegreat.substack.com" aria-label="Substack" target="_blank" rel="noopener" class="footer__social-icon">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24l9.6-5.55 9.48 5.55V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/></svg>
          </a>
        </div>
      </div>

      <!-- Column 4: Newsletter -->
      <div class="footer__col">
        <p class="footer__heading">Magnalia Letter</p>
        <p class="footer__newsletter-desc">Free monthly essays, event invitations, and reading recommendations.</p>
        <form class="footer__form" action="#" method="POST">
          <input type="text" name="firstName" placeholder="First name" class="footer__input" required aria-label="First name" />
          <input type="email" name="email" placeholder="Email address" class="footer__input" required aria-label="Email address" />
          <button type="submit" class="footer__submit">Subscribe</button>
        </form>
      </div>
    </div>

    <hr class="gold-rule" style="opacity: 0.3;" />

    <div class="footer__bottom">
      <p class="footer__legal">
        &copy; {currentYear} Gregory the Great Institute. All rights reserved.
      </p>
      <p class="footer__charity">
        Tax-deductible donations processed through Catholic Voices Canada. Charitable registration pending.
      </p>
    </div>
  </div>
</footer>

<style>
  /* CTA Strip */
  .footer-cta-strip {
    background-color: var(--color-parchment);
    border-top: 1px solid var(--color-gold);
    border-bottom: 1px solid rgba(14, 51, 82, 0.08);
    padding: 16px 0;
  }

  .footer-cta-strip__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .footer-cta-strip__text {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-navy);
  }

  .footer-cta-strip__btn {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-parchment);
    background-color: var(--color-gold);
    padding: 8px 24px;
    border-radius: 3px;
    text-decoration: none;
    transition: background-color var(--transition-fast);
  }

  .footer-cta-strip__btn:hover {
    background-color: #a08638;
    color: var(--color-parchment);
  }

  /* Footer */
  .footer {
    background-color: var(--color-navy);
    color: var(--color-text-on-dark);
    padding-block: var(--space-section) var(--space-component);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-component);
  }

  .footer__logo {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    margin-bottom: 12px;
  }

  .footer__tagline {
    font-family: var(--font-display);
    font-size: 1rem;
    font-style: italic;
    color: var(--color-gold);
    margin-bottom: 10px;
  }

  .footer__mission {
    font-family: var(--font-body);
    font-size: 0.88rem;
    line-height: 1.6;
    color: rgba(245, 239, 229, 0.65);
    max-width: 280px;
  }

  .footer__heading {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 14px;
    color: var(--color-text-on-dark);
  }

  .footer__col nav,
  .footer__col {
    display: flex;
    flex-direction: column;
  }

  .footer__link {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 400;
    color: rgba(245, 239, 229, 0.7);
    text-decoration: none;
    padding: 4px 0;
    transition: color var(--transition-fast);
  }

  .footer__link:hover {
    color: var(--color-gold);
  }

  .footer__email {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--color-gold);
    text-decoration: none;
    margin-bottom: 12px;
    display: block;
  }

  .footer__email:hover {
    text-decoration: underline;
  }

  .footer__social {
    display: flex;
    gap: 16px;
    margin-top: 12px;
  }

  .footer__social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: rgba(245, 239, 229, 0.08);
    color: rgba(245, 239, 229, 0.6);
    text-decoration: none;
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .footer__social-icon:hover {
    background-color: rgba(184, 154, 71, 0.2);
    color: var(--color-gold);
  }

  /* Newsletter form */
  .footer__newsletter-desc {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: rgba(245, 239, 229, 0.6);
    line-height: 1.5;
    margin-bottom: 14px;
  }

  .footer__form {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-width: 260px;
  }

  .footer__input {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    padding: 10px 12px;
    background: rgba(245, 239, 229, 0.06);
    border: 1px solid rgba(245, 239, 229, 0.15);
    border-radius: 3px;
    color: var(--color-text-on-dark);
    outline: none;
    transition: border-color var(--transition-fast);
  }

  .footer__input::placeholder {
    color: rgba(245, 239, 229, 0.35);
  }

  .footer__input:focus {
    border-color: var(--color-gold);
  }

  .footer__submit {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 10px 20px;
    background-color: var(--color-gold);
    color: var(--color-navy);
    border: none;
    border-radius: 3px;
    cursor: pointer;
    transition: background-color var(--transition-fast);
  }

  .footer__submit:hover {
    background-color: #a08638;
  }

  /* Bottom */
  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .footer__legal,
  .footer__charity {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    color: rgba(245, 239, 229, 0.35);
  }

  /* Responsive */
  @media (min-width: 640px) {
    .footer__top {
      grid-template-columns: 1.4fr 0.8fr 1fr;
    }

    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  @media (min-width: 1024px) {
    .footer__top {
      grid-template-columns: 1.5fr 0.8fr 1fr 1.2fr;
    }
  }
</style>
