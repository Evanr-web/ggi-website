---
const footerLinks = [
  { label: 'About', href: '/about' },
  { label: 'Programs', href: '/programs' },
  { label: 'Magnalia', href: '/magnalia' },
  { label: 'Events', href: '/events' },
  { label: 'Give', href: '/give' },
  { label: 'Contact', href: '/contact' },
  { label: 'Privacy Policy', href: '/privacy' },
];

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <img src="/images/branding/ggi-seal.png" alt="GGI Seal" class="footer__logo" />
        <p class="footer__tagline">Fides&ensp;•&ensp;Ratio&ensp;•&ensp;Cultura</p>
        <p class="footer__mission">
          Equipping Christians to renew culture in the light of faith and reason.
        </p>
      </div>

      <nav class="footer__nav" aria-label="Footer navigation">
        {footerLinks.map(link => (
          <a href={link.href} class="footer__link">{link.label}</a>
        ))}
      </nav>

      <div class="footer__contact">
        <p class="footer__heading">Get in Touch</p>
        <a href="mailto:info@gregorythegreat.ca" class="footer__email">info@gregorythegreat.ca</a>
        <div class="footer__social">
          <a href="https://www.youtube.com/@gregorythegreatinstitute" aria-label="YouTube" target="_blank" rel="noopener">YouTube</a>
          <a href="https://www.instagram.com/gregorythegreatinstitute/" aria-label="Instagram" target="_blank" rel="noopener">Instagram</a>
        </div>
      </div>
    </div>

    <hr class="gold-rule" />

    <div class="footer__bottom">
      <p class="footer__legal">
        &copy; {currentYear} Gregory the Great Institute. All rights reserved.
      </p>
      <p class="footer__charity">
        Donations processed through Catholic Voices Canada. Charitable registration pending.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-navy);
    color: var(--color-text-on-dark);
    padding-block: var(--space-section) var(--space-component);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-component);
  }

  .footer__logo {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    margin-bottom: 16px;
  }

  .footer__tagline {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-style: italic;
    color: var(--color-gold);
    margin-bottom: 12px;
  }

  .footer__mission {
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgba(245, 239, 229, 0.75);
    max-width: 320px;
  }

  .footer__nav {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer__link {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-on-dark);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__link:hover {
    color: var(--color-gold);
  }

  .footer__heading {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .footer__email {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--color-gold);
    text-decoration: none;
    display: block;
    margin-bottom: 16px;
  }

  .footer__email:hover {
    text-decoration: underline;
  }

  .footer__social {
    display: flex;
    gap: 16px;
  }

  .footer__social a {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(245, 239, 229, 0.65);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__social a:hover {
    color: var(--color-gold);
  }

  .footer .gold-rule {
    margin-block: var(--space-component) 20px;
    opacity: 0.4;
  }

  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .footer__legal,
  .footer__charity {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: rgba(245, 239, 229, 0.45);
  }

  @media (min-width: 640px) {
    .footer__top {
      grid-template-columns: 1.5fr 1fr 1fr;
    }

    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }
</style>
