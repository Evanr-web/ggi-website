---
/**
 * Canada map with province clusters + accordion groups.
 * Used on the Book Studies (Inklings) page.
 * Accepts optional `sanityGroups` prop — if provided, uses Sanity data.
 * Falls back to hardcoded data if no Sanity data is available.
 */
const base = import.meta.env.BASE_URL;

interface City {
  name: string;
  groups: number;
}

interface Province {
  code: string;
  name: string;
  cities: City[];
  pin: { left: string; top: string };
}

interface Props {
  sanityGroups?: Array<{ province: string; city: string; groups: number }>;
}

const { sanityGroups } = Astro.props;

// Pin positions for each province on the map SVG
const pinPositions: Record<string, { left: string; top: string }> = {
  BC: { left: '6%', top: '66%' },
  AB: { left: '20%', top: '68%' },
  SK: { left: '29%', top: '74%' },
  MB: { left: '42%', top: '76%' },
  ON: { left: '57%', top: '80%' },
  QC: { left: '70%', top: '74%' },
  NB: { left: '80%', top: '78%' },
  NS: { left: '87%', top: '82%' },
  PE: { left: '85%', top: '74%' },
  NL: { left: '82%', top: '60%' },
};

const provinceNames: Record<string, string> = {
  BC: 'British Columbia', AB: 'Alberta', SK: 'Saskatchewan', MB: 'Manitoba',
  ON: 'Ontario', QC: 'Quebec', NB: 'New Brunswick', NS: 'Nova Scotia',
  PE: 'Prince Edward Island', NL: 'Newfoundland & Labrador',
};

// Build provinces from Sanity data or fallback
let provinces: Province[];

if (sanityGroups && sanityGroups.length > 0) {
  // Group Sanity data by province
  const byProvince = new Map<string, City[]>();
  for (const g of sanityGroups) {
    if (!byProvince.has(g.province)) byProvince.set(g.province, []);
    byProvince.get(g.province)!.push({ name: g.city, groups: g.groups });
  }
  provinces = Array.from(byProvince.entries())
    .filter(([code]) => pinPositions[code])
    .map(([code, cities]) => ({
      code,
      name: provinceNames[code] || code,
      cities,
      pin: pinPositions[code],
    }))
    .sort((a, b) => {
      const order = ['BC', 'AB', 'SK', 'MB', 'ON', 'QC', 'NB', 'NS', 'PE', 'NL'];
      return order.indexOf(a.code) - order.indexOf(b.code);
    });
} else {
  // Fallback hardcoded data
  provinces = [
    { code: 'BC', name: 'British Columbia', pin: pinPositions.BC, cities: [
      { name: 'Vancouver', groups: 2 }, { name: 'Kelowna', groups: 1 }
    ]},
    { code: 'AB', name: 'Alberta', pin: pinPositions.AB, cities: [
      { name: 'Edmonton', groups: 3 }, { name: 'St. Albert', groups: 1 }, { name: 'Sherwood Park', groups: 1 },
      { name: 'Spruce Grove', groups: 1 }, { name: 'Fort McMurray', groups: 1 }, { name: 'Red Deer', groups: 1 },
      { name: 'Lethbridge', groups: 1 }, { name: 'Calgary', groups: 3 }
    ]},
    { code: 'SK', name: 'Saskatchewan', pin: pinPositions.SK, cities: [
      { name: 'Saskatoon', groups: 3 }, { name: 'Regina', groups: 2 }
    ]},
    { code: 'MB', name: 'Manitoba', pin: pinPositions.MB, cities: [
      { name: 'Winnipeg', groups: 2 }
    ]},
    { code: 'ON', name: 'Ontario', pin: pinPositions.ON, cities: [
      { name: 'Toronto', groups: 5 }, { name: 'Ottawa', groups: 3 }
    ]},
    { code: 'QC', name: 'Quebec', pin: pinPositions.QC, cities: [
      { name: 'Montreal', groups: 1 }
    ]},
    { code: 'NS', name: 'Nova Scotia', pin: pinPositions.NS, cities: [
      { name: 'Halifax', groups: 2 }
    ]},
    { code: 'NL', name: 'Newfoundland & Labrador', pin: pinPositions.NL, cities: [
      { name: "St. John's", groups: 1 }
    ]},
  ];
}

const totalGroups = provinces.reduce((sum, p) => sum + p.cities.reduce((s, c) => s + c.groups, 0), 0);
const totalCities = provinces.reduce((sum, p) => sum + p.cities.length, 0);
const shortNames: Record<string, string> = { BC: 'B.C.', AB: 'Alberta', SK: 'Sask.', MB: 'Manitoba', ON: 'Ontario', QC: 'Quebec', NS: 'N.S.', NL: 'N.L.' };
---

<!-- Canada Map -->
<div class="bs-map-container">
  <div class="bs-map-wrapper">
    <img src={`${base}images/canada-map.svg`} alt="Map of Canada showing Inklings Club locations" class="bs-map-img" />
    {provinces.map(p => {
      const provGroups = p.cities.reduce((s, c) => s + c.groups, 0);
      return (
        <button class="bs-pin bs-pin--cluster" style={`left: ${p.pin.left}; top: ${p.pin.top};`} data-province={p.code} type="button">
          <span class="bs-pin__count">{provGroups}</span>
          <span class="bs-pin__label">{shortNames[p.code] || p.name}</span>
        </button>
      );
    })}
  </div>
  <p class="bs-map-total">
    <strong>{totalGroups} groups</strong> in <strong>{totalCities} cities</strong> across <strong>{provinces.length} provinces</strong>
  </p>
</div>

<!-- Province Accordions -->
<div class="bs-accordions" id="bs-accordions">
  {provinces.map(p => {
    const provGroups = p.cities.reduce((s, c) => s + c.groups, 0);
    const cityLabel = p.cities.length === 1 ? '1 city' : `${p.cities.length} cities`;
    return (
      <details class="bs-accordion" data-province={p.code}>
        <summary class="bs-accordion__header">
          <span class="bs-accordion__name">{p.name}</span>
          <span class="bs-accordion__count">{provGroups} groups · {cityLabel}</span>
          <span class="bs-accordion__chevron">▸</span>
        </summary>
        <div class="bs-accordion__body">
          {p.cities.map(c => (
            <div class="bs-city">
              <span class="bs-city__name">{c.name}</span>
              <span class="bs-city__groups">{c.groups} {c.groups === 1 ? 'group' : 'groups'}</span>
              <button class="bs-city__join" data-province={p.code} data-city={c.name} type="button">Join →</button>
            </div>
          ))}
        </div>
      </details>
    );
  })}
</div>

<!-- Don't see your city -->
<div class="bs-not-listed">
  <p class="bs-not-listed__text">
    <strong>Don't see your city?</strong> No problem — sign up below with your location and when there's enough
    interest in your area, we'll connect you with a group or help you start one.
  </p>
  <a href="#join-form" class="bs-not-listed__link">Sign up below →</a>
</div>

<style>
  /* Map Container */
  .bs-map-container {
    max-width: 700px;
    margin: 0 auto 12px;
  }

  .bs-map-wrapper {
    position: relative;
    width: 100%;
  }

  .bs-map-img {
    width: 100%;
    height: auto;
  }

  .bs-pin {
    position: absolute;
    transform: translate(-50%, -50%);
    cursor: pointer;
    z-index: 2;
    background: none;
    border: none;
    padding: 0;
  }

  .bs-pin::before {
    content: '';
    display: block;
    width: 14px;
    height: 14px;
    background: var(--color-gold);
    border: 2px solid white;
    border-radius: 50%;
    box-shadow: 0 2px 6px rgba(0,0,0,0.25);
    margin: 0 auto;
  }

  .bs-pin--cluster::before {
    width: 0;
    height: 0;
    border: none;
    box-shadow: none;
    background: none;
  }

  .bs-pin__count {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--color-gold);
    color: white;
    border: 2px solid white;
    border-radius: 50%;
    font-family: var(--font-ui);
    font-size: 13px;
    font-weight: 700;
    box-shadow: 0 2px 8px rgba(0,0,0,0.25);
    margin: 0 auto;
  }

  .bs-pin__label {
    display: block;
    font-family: var(--font-ui);
    font-size: 10px;
    font-weight: 600;
    color: var(--color-navy);
    text-align: center;
    white-space: nowrap;
    margin-top: 2px;
    text-shadow: 0 0 4px rgba(255,255,255,0.9), 0 0 8px rgba(255,255,255,0.7);
  }

  .bs-pin--ghost::before {
    background: rgba(198, 160, 50, 0.3);
    border: 2px dashed var(--color-gold);
    box-shadow: none;
  }

  .bs-pin--ghost .bs-pin__label {
    color: rgba(90, 90, 110, 0.5);
    font-style: italic;
    font-weight: 400;
  }

  /* Map total */
  .bs-map-total {
    text-align: center;
    font-family: var(--font-ui);
    font-size: 0.88rem;
    color: var(--color-gray);
    margin-top: 12px;
  }

  .bs-map-total strong {
    color: var(--color-navy);
  }

  /* Province Accordions */
  .bs-accordions {
    max-width: 640px;
    margin-inline: auto;
  }

  .bs-accordion {
    border-bottom: 1px solid rgba(90, 90, 110, 0.1);
  }

  .bs-accordion__header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .bs-accordion__header::-webkit-details-marker { display: none; }

  .bs-accordion__name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-navy);
    flex: 1;
  }

  .bs-accordion__count {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-gray);
  }

  .bs-accordion__chevron {
    font-size: 0.9rem;
    color: var(--color-gold);
    transition: transform 0.2s ease;
  }

  .bs-accordion[open] .bs-accordion__chevron {
    transform: rotate(90deg);
  }

  .bs-accordion__body {
    padding: 0 0 14px 16px;
  }

  .bs-city {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 0;
    border-bottom: 1px solid rgba(90, 90, 110, 0.04);
  }

  .bs-city:last-child { border-bottom: none; }

  .bs-city__name {
    font-family: var(--font-ui);
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-navy);
    min-width: 130px;
  }

  .bs-city__groups {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    color: var(--color-gray);
    flex: 1;
  }

  .bs-city__join {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-gold);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    white-space: nowrap;
  }

  .bs-city__join:hover {
    color: var(--color-crimson);
  }

  /* Not listed callout */
  .bs-not-listed {
    max-width: 640px;
    margin: 28px auto 0;
    padding: 20px 24px;
    background: white;
    border: 1px dashed var(--color-gold);
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .bs-not-listed__text {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-gray);
    line-height: 1.5;
  }

  .bs-not-listed__text strong {
    color: var(--color-navy);
  }

  .bs-not-listed__link {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-gold);
    text-decoration: none;
    white-space: nowrap;
  }

  .bs-not-listed__link:hover {
    color: var(--color-crimson);
  }

  @media (max-width: 480px) {
    .bs-not-listed {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
