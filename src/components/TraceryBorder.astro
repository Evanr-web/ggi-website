---
/**
 * Thin gothic tracery line — use at section boundaries.
 * Renders a repeating pointed-arch pattern as a horizontal rule.
 */
interface Props {
  /** 'gold' on light backgrounds, 'light' on dark backgrounds */
  color?: 'gold' | 'light';
}

const { color = 'gold' } = Astro.props;
---

<div class:list={['tracery-border', `tracery-border--${color}`]} role="separator" aria-hidden="true">
  <svg class="tracery-border__svg" viewBox="0 0 800 16" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <pattern id={`tb-arch-${color}`} x="0" y="0" width="40" height="16" patternUnits="userSpaceOnUse">
        {/* Small pointed arch */}
        <path d="M0 15 Q10 1, 20 1 Q30 1, 40 15" fill="none" stroke="currentColor" stroke-width="0.7" />
        {/* Tiny cusp dot at apex */}
        <circle cx="20" cy="5" r="1.5" fill="none" stroke="currentColor" stroke-width="0.4" />
      </pattern>
    </defs>
    <rect width="800" height="16" fill={`url(#tb-arch-${color})`} />
  </svg>
</div>

<style>
  .tracery-border {
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }

  .tracery-border__svg {
    width: 100%;
    height: 12px;
    display: block;
  }

  .tracery-border--gold {
    color: var(--color-gold);
    opacity: 0.25;
  }

  .tracery-border--light {
    color: var(--color-text-on-dark);
    opacity: 0.1;
  }
</style>
