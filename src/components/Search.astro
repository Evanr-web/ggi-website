---
/**
 * Site search powered by Pagefind.
 * Dropdown search bar — triggered by .search-trigger buttons in Navigation.
 * Only one instance rendered (after nav).
 */
const base = import.meta.env.BASE_URL;
---

<div class="search-bar" id="search-bar" aria-hidden="true">
  <div class="search-bar__inner container">
    <div id="search-container"></div>
    <button class="search-bar__close" aria-label="Close search" type="button">&times;</button>
  </div>
</div>

<script is:inline data-base={base}>
  (function() {
    var BASE = document.currentScript.getAttribute('data-base');
    var pagefindLoaded = false;
    var pagefindReady = false;

    function loadPagefind() {
      if (pagefindLoaded) return;
      pagefindLoaded = true;

      var script = document.createElement('script');
      script.src = BASE + 'pagefind/pagefind-ui.js';
      script.onload = function() {
        if (typeof window.PagefindUI === 'undefined') return;
        new window.PagefindUI({
          element: '#search-container',
          showSubResults: true,
          showImages: false,
          bundlePath: BASE + 'pagefind/',
          resetStyles: false,
        });
        pagefindReady = true;
        focusInput();
      };
      document.head.appendChild(script);
    }

    function focusInput() {
      setTimeout(function() {
        var input = document.querySelector('#search-container input');
        if (input) { input.focus(); input.click(); }
      }, 150);
    }

    var bar = document.getElementById('search-bar');
    var closeBtn = document.querySelector('.search-bar__close');
    var triggers = document.querySelectorAll('.search-trigger');

    function openSearch() {
      bar.classList.add('search-bar--open');
      bar.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      loadPagefind();
      if (pagefindReady) focusInput();
    }

    function closeSearch() {
      bar.classList.remove('search-bar--open');
      bar.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    function toggleSearch() {
      bar.classList.contains('search-bar--open') ? closeSearch() : openSearch();
    }

    triggers.forEach(function(btn) {
      btn.addEventListener('click', toggleSearch);
    });
    if (closeBtn) closeBtn.addEventListener('click', closeSearch);

    document.addEventListener('click', function(e) {
      if (bar.classList.contains('search-bar--open') && !bar.contains(e.target)) {
        var clickedTrigger = false;
        triggers.forEach(function(btn) { if (btn.contains(e.target)) clickedTrigger = true; });
        if (!clickedTrigger) closeSearch();
      }
    });

    document.addEventListener('keydown', function(e) {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        openSearch();
      }
      if (e.key === 'Escape' && bar.classList.contains('search-bar--open')) {
        closeSearch();
      }
    });
  })();
</script>

<style>
  /* Dropdown bar */
  .search-bar {
    position: fixed;
    top: 72px;
    left: 0;
    right: 0;
    z-index: 250;
    background: var(--color-navy);
    border-bottom: 2px solid var(--color-gold);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease, opacity 0.25s ease;
    opacity: 0;
  }

  .search-bar--open {
    max-height: 80vh;
    overflow-y: auto;
    opacity: 1;
    padding: 8px 0;
  }

  .search-bar__inner {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding-top: 24px;
    padding-bottom: 24px;
  }

  #search-container {
    flex: 1;
  }

  .search-bar__close {
    background: none;
    border: none;
    color: rgba(245, 239, 229, 0.6);
    font-size: 1.4rem;
    cursor: pointer;
    padding: 4px 8px;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 4px;
    transition: color var(--transition-fast);
  }

  .search-bar__close:hover {
    color: var(--color-gold);
  }

  /* Pagefind UI overrides — dark theme for navy bar */
  :global(.pagefind-ui__search-input) {
    font-family: var(--font-ui) !important;
    font-size: 1rem !important;
    padding: 12px 16px !important;
    border: 1px solid rgba(245, 239, 229, 0.2) !important;
    border-radius: 3px !important;
    width: 100% !important;
    outline: none !important;
    background: rgba(245, 239, 229, 0.06) !important;
    color: var(--color-text-on-dark) !important;
  }

  :global(.pagefind-ui__search-input::placeholder) {
    color: rgba(245, 239, 229, 0.5) !important;
  }

  :global(.pagefind-ui__search-input:focus) {
    border-color: var(--color-gold) !important;
    box-shadow: 0 0 0 3px rgba(184, 154, 71, 0.2) !important;
  }

  :global(.pagefind-ui__result) {
    padding: 14px 0 !important;
    border-bottom: 1px solid rgba(245, 239, 229, 0.08) !important;
  }

  :global(.pagefind-ui__result-link) {
    font-family: var(--font-display) !important;
    font-size: 1rem !important;
    font-weight: 600 !important;
    color: var(--color-gold) !important;
  }

  :global(.pagefind-ui__result-link:hover) {
    color: #d4ad3a !important;
  }

  :global(.pagefind-ui__result-excerpt) {
    font-family: var(--font-body) !important;
    font-size: 0.85rem !important;
    color: rgba(245, 239, 229, 0.7) !important;
    line-height: 1.6 !important;
  }

  :global(.pagefind-ui__message) {
    font-family: var(--font-ui) !important;
    color: rgba(245, 239, 229, 0.6) !important;
  }

  :global(.pagefind-ui__search-clear) {
    color: rgba(245, 239, 229, 0.5) !important;
  }

  :global(mark.pagefind-ui__result-highlight) {
    background: rgba(184, 154, 71, 0.25) !important;
    color: var(--color-text-on-dark) !important;
  }

  :global(.pagefind-ui__form::before) {
    background-color: rgba(245, 239, 229, 0.5) !important;
  }
</style>

<link rel="stylesheet" href={`${base}pagefind/pagefind-ui.css`} />
