---
interface Props {
  title: string;
  parentLabel?: string;
  parentHref?: string;
}

const { title, parentLabel, parentHref } = Astro.props;
---

<section class="coming-soon">
  <div class="container coming-soon__inner">
    <p class="coming-soon__label">Coming Soon</p>
    <h1 class="coming-soon__title">{title}</h1>
    <p class="coming-soon__desc">This page is under construction. Check back soon.</p>
    {parentHref && parentLabel && (
      <a href={parentHref} class="coming-soon__back">← Back to {parentLabel}</a>
    )}
  </div>
</section>

<style>
  .coming-soon {
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-section) 0;
  }

  .coming-soon__label {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 12px;
  }

  .coming-soon__title {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-navy);
    margin-bottom: 12px;
  }

  .coming-soon__desc {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-gray);
    margin-bottom: 28px;
    line-height: 1.6;
  }

  .coming-soon__back {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-gold);
    text-decoration: none;
    font-weight: 500;
  }

  .coming-soon__back:hover {
    color: var(--color-crimson);
  }
</style>
