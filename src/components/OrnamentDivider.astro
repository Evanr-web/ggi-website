---
interface Props {
  variant: 'vine' | 'celtic' | 'cross';
  showLabel?: boolean;
}

const { variant, showLabel = false } = Astro.props;

// Unique IDs to avoid SVG conflicts when multiple are on same page
const id = `od-${variant}`;
---

<div class="ornament-divider" role="separator" aria-hidden="true">
  {showLabel && <p class="ornament-divider__label">{variant === 'vine' ? '① Vine Scroll' : variant === 'celtic' ? '② Celtic Interlace' : '③ Cross Band'}</p>}

  <div class="ornament-divider__wrap">
    {variant === 'vine' && (
      <svg class="ornament-divider__svg" viewBox="0 0 400 32" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id={`${id}-pat`} x="0" y="0" width="100" height="32" patternUnits="userSpaceOnUse">
            <path d="M0 16 C12 4, 25 4, 38 14 C45 19, 50 22, 56 22 C68 22, 75 4, 100 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
            <path d="M28 10 C24 4, 18 3, 16 8" fill="none" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" />
            <path d="M30 9 C28 3, 34 2, 36 7" fill="none" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" />
            <circle cx="22" cy="6" r="1.5" fill="currentColor" opacity="0.4" />
            <circle cx="25" cy="4" r="1.3" fill="currentColor" opacity="0.35" />
            <circle cx="24" cy="8" r="1.2" fill="currentColor" opacity="0.3" />
            <path d="M68 24 C72 28, 78 29, 80 24" fill="none" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" />
            <path d="M66 23 C68 29, 62 30, 60 25" fill="none" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" />
            <path d="M45 18 C43 14, 40 14, 41 18" fill="none" stroke="currentColor" stroke-width="0.5" stroke-linecap="round" />
            <path d="M88 12 C90 8, 93 9, 92 13" fill="none" stroke="currentColor" stroke-width="0.5" stroke-linecap="round" />
          </pattern>
        </defs>
        <rect width="400" height="32" fill={`url(#${id}-pat)`} />
      </svg>
    )}

    {variant === 'celtic' && (
      <svg class="ornament-divider__svg" viewBox="0 0 400 24" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id={`${id}-pat`} x="0" y="0" width="48" height="24" patternUnits="userSpaceOnUse">
            <path d="M0 6 C8 6, 8 18, 16 18 C24 18, 24 6, 32 6 C40 6, 40 18, 48 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            <path d="M0 18 C8 18, 8 6, 16 6 C24 6, 24 18, 32 18 C40 18, 40 6, 48 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            {/* Background-colored breaks to simulate weave */}
            <rect x="5" y="7" width="6" height="5" fill="var(--color-parchment, #f8ebd9)" />
            <rect x="21" y="12" width="6" height="5" fill="var(--color-parchment, #f8ebd9)" />
            <rect x="37" y="7" width="6" height="5" fill="var(--color-parchment, #f8ebd9)" />
            {/* Redraw the "over" strands at crossings */}
            <path d="M5 11 C8 6, 8 6, 11 11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            <path d="M21 13 C24 18, 24 18, 27 13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            <path d="M37 11 C40 6, 40 6, 43 11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </pattern>
        </defs>
        <rect width="400" height="24" fill={`url(#${id}-pat)`} />
      </svg>
    )}

    {variant === 'cross' && (
      <svg class="ornament-divider__svg ornament-divider__svg--short" viewBox="0 0 400 20" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id={`${id}-pat`} x="0" y="0" width="40" height="20" patternUnits="userSpaceOnUse">
            <line x1="0" y1="10" x2="40" y2="10" stroke="currentColor" stroke-width="0.5" opacity="0.4" />
            <path d="M18 4 L20 2 L22 4 L22 8 L26 8 L28 10 L26 12 L22 12 L22 16 L20 18 L18 16 L18 12 L14 12 L12 10 L14 8 L18 8 Z" fill="none" stroke="currentColor" stroke-width="0.8" />
            <path d="M19 9 L20 8 L21 9 L20 10 Z" fill="currentColor" opacity="0.5" />
          </pattern>
        </defs>
        <rect width="400" height="20" fill={`url(#${id}-pat)`} />
      </svg>
    )}
  </div>
</div>

<style>
  .ornament-divider {
    text-align: center;
    padding-block: 4px;
  }

  .ornament-divider__label {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gray);
    margin-bottom: 4px;
    opacity: 0.6;
  }

  .ornament-divider__wrap {
    max-width: 520px;
    margin-inline: auto;
    /* CSS fade at edges instead of SVG mask */
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
  }

  .ornament-divider__svg {
    width: 100%;
    height: 28px;
    display: block;
    color: var(--color-gold);
    opacity: 0.5;
  }

  .ornament-divider__svg--short {
    height: 20px;
  }
</style>
