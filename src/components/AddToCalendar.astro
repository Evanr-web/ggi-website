---
interface Props {
  title: string;
  date: string;
  endDate?: string;
  location?: string;
  description?: string;
}

const { title, date, endDate, location, description } = Astro.props;

// Format dates for .ics (YYYYMMDD)
const fmtIcs = (d: string) => d.replace(/-/g, '');
const startDate = fmtIcs(date);
const finishDate = endDate ? fmtIcs(endDate) : startDate;

// For all-day events, end date in .ics needs to be the day AFTER
const endPlusOne = (d: string) => {
  const dt = new Date(d + 'T12:00:00');
  dt.setDate(dt.getDate() + 1);
  return dt.toISOString().slice(0, 10).replace(/-/g, '');
};

const icsEnd = endPlusOne(endDate || date);
const cleanDesc = (description || `${title} — Gregory the Great Institute`).replace(/\n/g, '\\n');
const icsLocation = (location || '').replace(/,/g, '\\,');
const stamp = new Date().toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
---

<button
  class="add-to-cal"
  data-ics-title={title}
  data-ics-start={startDate}
  data-ics-end={icsEnd}
  data-ics-location={location || ''}
  data-ics-description={description || `${title} — Gregory the Great Institute`}
  aria-label="Add to calendar"
>
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
  <span>Add to Calendar</span>
</button>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.add-to-cal').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        const title = el.dataset.icsTitle || 'Event';
        const start = el.dataset.icsStart || '';
        const end = el.dataset.icsEnd || '';
        const location = el.dataset.icsLocation || '';
        const description = el.dataset.icsDescription || '';
        const stamp = new Date().toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
        const uid = `${start}-${Math.random().toString(36).slice(2, 8)}@gregorythegreat.ca`;

        const ics = [
          'BEGIN:VCALENDAR',
          'VERSION:2.0',
          'PRODID:-//Gregory the Great Institute//Events//EN',
          'CALSCALE:GREGORIAN',
          'METHOD:PUBLISH',
          'BEGIN:VEVENT',
          `DTSTART;VALUE=DATE:${start}`,
          `DTEND;VALUE=DATE:${end}`,
          `DTSTAMP:${stamp}`,
          `UID:${uid}`,
          `SUMMARY:${title.replace(/,/g, '\\,')}`,
          `DESCRIPTION:${description.replace(/,/g, '\\,').replace(/\n/g, '\\n')}`,
          location ? `LOCATION:${location.replace(/,/g, '\\,')}` : '',
          `URL:${window.location.href}`,
          'END:VEVENT',
          'END:VCALENDAR'
        ].filter(Boolean).join('\r\n');

        const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `${title.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()}.ics`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
      });
    });
  });
</script>

<style>
  .add-to-cal {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-navy);
    background: rgba(14, 51, 82, 0.05);
    border: 1px solid rgba(14, 51, 82, 0.1);
    border-radius: 4px;
    padding: 7px 12px;
    cursor: pointer;
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .add-to-cal:hover {
    background: rgba(14, 51, 82, 0.1);
    border-color: rgba(14, 51, 82, 0.2);
  }

  .add-to-cal svg {
    flex-shrink: 0;
  }
</style>
