---
/**
 * EventRegistration — renders a registration section based on status.
 *
 * - "coming-soon" → "Registration Starting Soon" + Get Notified email form
 * - "open"        → Zeffy ticketing embed
 * - "closed"      → "Registration Closed" message
 *
 * Props:
 *   status: 'coming-soon' | 'open' | 'closed'
 *   zeffyFormUrl?: string   — Zeffy embed path (required when status is 'open')
 *   notifyTag?: string      — AC tag for notify signups (optional, used in hidden field)
 *   eventTitle?: string     — event name for the notify form context
 */

interface Props {
  status: 'coming-soon' | 'open' | 'closed';
  zeffyFormUrl?: string;
  notifyTag?: string;
  eventTitle?: string;
}

const { status, zeffyFormUrl, notifyTag, eventTitle } = Astro.props;
---

<div id="register" class="event-registration">
  {status === 'coming-soon' && (
    <div class="event-registration__header">
      <p class="label text-gold">Registration</p>
      <h2>Registration Starting Soon</h2>
      <p class="event-registration__subtitle">Get notified when registration opens.</p>
    </div>
    <div class="event-registration__notify">
      <form class="notify-form" data-ac-endpoint="/api/event-interest" data-ac-success="You're on the list! We'll notify you when registration opens." method="POST">
        <div class="notify-form__row">
          <div class="notify-form__field">
            <label for="reg-notify-firstName">First Name</label>
            <input type="text" id="reg-notify-firstName" name="firstName" required placeholder="First name" />
          </div>
          <div class="notify-form__field">
            <label for="reg-notify-email">Email</label>
            <input type="email" id="reg-notify-email" name="email" required placeholder="you@example.com" />
          </div>
        </div>
        {notifyTag && <input type="hidden" name="notifyTag" value={notifyTag} />}
        {eventTitle && <input type="hidden" name="eventTitle" value={eventTitle} />}
        <input type="text" name="website" style="display:none" tabindex="-1" autocomplete="off" />
        <div class="cf-turnstile" data-sitekey="0x4AAAAAADm6eYaBvIIwZNRm" data-size="compact"></div>
        <button type="submit" class="notify-form__submit">Notify Me</button>
        <p class="notify-form__note">No spam — we'll only email you when registration opens.</p>
      </form>
    </div>
  )}

  {status === 'open' && zeffyFormUrl && (
    <div class="event-registration__header">
      <p class="label text-gold">Registration</p>
      <h2>Register Now</h2>
      <p class="event-registration__subtitle">Tickets include all sessions, meals, and materials.</p>
    </div>
    <div class="event-registration__zeffy">
      <div data-zeffy-embed data-form-url={zeffyFormUrl}></div>
      <div data-zeffy-embed-fallback style="display:none;">
        <div style="position:relative;overflow:hidden;height:450px;width:100%;padding-top:450px;">
          <iframe
            title="Registration form powered by Zeffy"
            style="position: absolute; border: 0; top:0;left:0;bottom:0;right:0;width:100%;height:100%"
            data-zeffy-embed-src={`https://www.zeffy.com${zeffyFormUrl}`}
            allowpaymentrequest
            allowTransparency="true"
          ></iframe>
        </div>
      </div>
      <script
        src="https://www.zeffy.com/embed/v2/zeffy-embed.js"
        onerror="document.querySelectorAll('[data-zeffy-embed-fallback]').forEach(function(el){el.style.display='block';el.querySelectorAll('iframe[data-zeffy-embed-src]').forEach(function(f){f.src=f.getAttribute('data-zeffy-embed-src');});});"
        is:inline>
      </script>
    </div>
  )}

  {status === 'closed' && (
    <div class="event-registration__header">
      <p class="label text-gold">Registration</p>
      <h2>Registration Closed</h2>
      <p class="event-registration__subtitle">Registration for this event has closed. Thank you for your interest.</p>
    </div>
  )}
</div>

<style>
  .event-registration {
    margin-top: 48px;
    padding-top: 16px;
  }

  .event-registration__header {
    text-align: center;
    margin-bottom: 32px;
  }

  .event-registration__header h2 {
    margin-top: 8px;
    margin-bottom: 8px;
  }

  .event-registration__subtitle {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-gray);
  }

  /* Zeffy embed */
  .event-registration__zeffy {
    max-width: 700px;
    margin-inline: auto;
  }

  /* Notify form */
  .event-registration__notify {
    max-width: 560px;
    margin-inline: auto;
  }

  .notify-form {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .notify-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  @media (max-width: 480px) {
    .notify-form__row {
      grid-template-columns: 1fr;
    }
  }

  .notify-form__field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .notify-form__field label {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-navy);
  }

  .notify-form__field input {
    font-family: var(--font-body);
    font-size: 0.95rem;
    padding: 10px 14px;
    border: 1px solid rgba(90, 90, 110, 0.2);
    border-radius: 3px;
    background: white;
    color: var(--color-navy);
    transition: border-color var(--transition-fast);
  }

  .notify-form__field input:focus {
    outline: none;
    border-color: var(--color-gold);
    box-shadow: 0 0 0 3px rgba(198, 160, 50, 0.15);
  }

  .notify-form__submit {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 12px 32px;
    background: var(--color-crimson);
    color: white;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    align-self: center;
    transition: background var(--transition-fast);
  }

  .notify-form__submit:hover {
    background: #6b1d00;
  }

  .notify-form__note {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: var(--color-gray);
    text-align: center;
  }
</style>
