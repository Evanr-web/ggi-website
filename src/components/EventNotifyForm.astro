---
/**
 * "Notify Me of Future Events" form.
 * Submits to /api/event-interest with selected event interests.
 * Reusable on any past/closed event page or standalone.
 */
---

<div class="notify-form-wrap">
  <form class="notify-form" data-ac-endpoint="/api/event-interest" data-ac-success="You're on the list! We'll notify you when registration opens." method="POST">
    <div class="notify-form__row">
      <div class="notify-form__field">
        <label for="notify-firstName">First Name</label>
        <input type="text" id="notify-firstName" name="firstName" required placeholder="First name" />
      </div>
      <div class="notify-form__field">
        <label for="notify-email">Email</label>
        <input type="email" id="notify-email" name="email" required placeholder="you@example.com" />
      </div>
    </div>
    <fieldset class="notify-form__interests">
      <legend>I'm interested in:</legend>
      <label class="notify-check">
        <input type="checkbox" name="events" value="conference-2026" />
        <span>Renewing Culture Conference</span>
      </label>
      <label class="notify-check">
        <input type="checkbox" name="events" value="music-camp-2026" />
        <span>Music & Leadership Camp</span>
      </label>
      <label class="notify-check">
        <input type="checkbox" name="events" value="book-study-sep-2026" />
        <span>Book Studies</span>
      </label>
      <label class="notify-check">
        <input type="checkbox" name="events" value="masterclass" />
        <span>Masterclasses & Short Courses</span>
      </label>
    </fieldset>
    <input type="text" name="website" style="display:none" tabindex="-1" autocomplete="off" />
    <div class="cf-turnstile" data-sitekey="0x4AAAAAADm6eYaBvIIwZNRm"></div>
    <button type="submit" class="notify-form__submit">Notify Me</button>
    <p class="notify-form__note">No spam. We'll only email you when registration opens for events you selected.</p>
  </form>
</div>

<style>
  .notify-form-wrap {
    max-width: 560px;
    margin-inline: auto;
  }

  .notify-form {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .notify-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  @media (max-width: 480px) {
    .notify-form__row {
      grid-template-columns: 1fr;
    }
  }

  .notify-form__field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .notify-form__field label {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-navy);
  }

  .notify-form__field input {
    font-family: var(--font-body);
    font-size: 0.95rem;
    padding: 10px 14px;
    border: 1px solid rgba(90, 90, 110, 0.2);
    border-radius: 3px;
    background: white;
    color: var(--color-navy);
    transition: border-color var(--transition-fast);
  }

  .notify-form__field input:focus {
    outline: none;
    border-color: var(--color-gold);
    box-shadow: 0 0 0 3px rgba(198, 160, 50, 0.15);
  }

  .notify-form__interests {
    border: none;
    padding: 0;
    margin: 0;
  }

  .notify-form__interests legend {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 10px;
  }

  .notify-check {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 0.92rem;
    color: var(--color-ink, #2c2c2c);
    cursor: pointer;
    padding: 6px 0;
  }

  .notify-check input[type="checkbox"] {
    accent-color: var(--color-gold);
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .notify-form__submit {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 12px 32px;
    background: var(--color-crimson);
    color: white;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    align-self: center;
    transition: background var(--transition-fast);
  }

  .notify-form__submit:hover {
    background: #6b1d00;
  }

  .notify-form__note {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: var(--color-gray);
    text-align: center;
  }
</style>
