---
/**
 * Gothic Revival ornamental border — horizontal repeating tile.
 * Uses a generated SVG image (rosette frieze + quatrefoil medallions).
 */
interface Props {
  /** Height of the border in px. Default 60. */
  height?: number;
  /** Opacity 0-1. Default 0.35. */
  opacity?: number;
}

const { height = 60, opacity = 0.35 } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<div
  class="gothic-border"
  role="separator"
  aria-hidden="true"
  style={`height: ${height}px; opacity: ${opacity}; background-image: url(${base}images/gothic-border-tile.svg);`}
></div>

<style>
  .gothic-border {
    width: 100%;
    background-repeat: repeat-x;
    background-position: center;
    background-size: auto 100%;
  }
</style>
