---
interface Props {
  title: string;
  url?: string;
  text?: string;
  compact?: boolean;
}

const { title, url, text, compact = false } = Astro.props;
const shareText = text || `Check out "${title}" from the Gregory the Great Institute`;
---

<div class:list={['share-bar', compact && 'share-bar--compact']} data-share-title={title} data-share-text={shareText} data-share-url={url || ''}>
  {!compact && <span class="share-bar__label">Spread the Word</span>}

  <!-- Native share (mobile) -->
  <button class="share-bar__btn share-bar__btn--native" aria-label="Share" title="Share" hidden>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
    <span>Share</span>
  </button>

  <!-- Fallback buttons (desktop / no Web Share API) -->
  <div class="share-bar__fallback">
    <button class="share-bar__btn share-bar__btn--copy" aria-label="Copy link" title="Copy link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      <span class="share-bar__copy-label">Copy Link</span>
    </button>

    <a class="share-bar__btn share-bar__btn--email" aria-label="Share via email" title="Email">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      <span>Email</span>
    </a>

    <a class="share-bar__btn share-bar__btn--whatsapp" target="_blank" rel="noopener noreferrer" aria-label="Share on WhatsApp" title="WhatsApp">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
      <span>WhatsApp</span>
    </a>

    <a class="share-bar__btn share-bar__btn--facebook" target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook" title="Facebook">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      <span>Facebook</span>
    </a>


  </div>
</div>

<!-- Toast notification -->
<div class="share-toast" id="share-toast" aria-live="polite" hidden>Link copied!</div>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.share-bar').forEach((bar) => {
      const el = bar as HTMLElement;
      const title = el.dataset.shareTitle || '';
      const text = el.dataset.shareText || '';
      const pageUrl = el.dataset.shareUrl || window.location.href;

      // Show native share button on supported devices
      const nativeBtn = el.querySelector('.share-bar__btn--native') as HTMLElement;
      const fallback = el.querySelector('.share-bar__fallback') as HTMLElement;

      if (navigator.share) {
        nativeBtn.hidden = false;
        nativeBtn.addEventListener('click', async () => {
          try {
            await navigator.share({ title, text: `${text}\n`, url: pageUrl });
          } catch (e) {
            // User cancelled — that's fine
          }
        });
      }

      // Copy link
      const copyBtn = el.querySelector('.share-bar__btn--copy');
      copyBtn?.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(pageUrl);
          const label = copyBtn.querySelector('.share-bar__copy-label');
          if (label) {
            const original = label.textContent;
            label.textContent = 'Copied!';
            setTimeout(() => { label.textContent = original; }, 2000);
          }
          const toast = document.getElementById('share-toast');
          if (toast) {
            toast.hidden = false;
            setTimeout(() => { toast.hidden = true; }, 2500);
          }
        } catch {
          // Fallback: select from input
          const input = document.createElement('input');
          input.value = pageUrl;
          document.body.appendChild(input);
          input.select();
          document.execCommand('copy');
          document.body.removeChild(input);
        }
      });

      // Email
      const emailBtn = el.querySelector('.share-bar__btn--email') as HTMLAnchorElement;
      if (emailBtn) {
        emailBtn.href = `mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(`${text}\n\n${pageUrl}`)}`;
      }

      // WhatsApp
      const waBtn = el.querySelector('.share-bar__btn--whatsapp') as HTMLAnchorElement;
      if (waBtn) {
        waBtn.href = `https://wa.me/?text=${encodeURIComponent(`${text}\n${pageUrl}`)}`;
      }

      // Facebook
      const fbBtn = el.querySelector('.share-bar__btn--facebook') as HTMLAnchorElement;
      if (fbBtn) {
        fbBtn.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`;
      }

      // X / Twitter
      const xBtn = el.querySelector('.share-bar__btn--x') as HTMLAnchorElement;
      if (xBtn) {
        xBtn.href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(pageUrl)}`;
      }
    });
  });
</script>

<style>
  .share-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .share-bar__label {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    margin-right: 4px;
  }

  .share-bar__fallback {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .share-bar__btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-navy);
    background: rgba(14, 51, 82, 0.05);
    border: 1px solid rgba(14, 51, 82, 0.1);
    border-radius: 4px;
    padding: 7px 12px;
    cursor: pointer;
    text-decoration: none;
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .share-bar__btn:hover {
    background: rgba(14, 51, 82, 0.1);
    border-color: rgba(14, 51, 82, 0.2);
    color: var(--color-navy);
  }

  .share-bar__btn--native {
    background: var(--color-navy);
    color: var(--color-parchment);
    border-color: var(--color-navy);
    font-weight: 600;
  }

  .share-bar__btn--native:hover {
    background: #0a2640;
    color: var(--color-parchment);
  }

  .share-bar__btn svg {
    flex-shrink: 0;
  }

  /* Compact variant — just icons, no labels */
  .share-bar--compact .share-bar__btn span {
    display: none;
  }

  .share-bar--compact .share-bar__btn {
    padding: 7px 9px;
  }

  .share-bar--compact .share-bar__btn--native span {
    display: inline;
  }

  .share-bar--compact .share-bar__btn--native {
    padding: 7px 12px;
  }

  /* Toast */
  .share-toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-navy);
    color: var(--color-parchment);
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 10px 20px;
    border-radius: 6px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    z-index: 9999;
    animation: toast-in 0.25s ease;
  }

  @keyframes toast-in {
    from { opacity: 0; transform: translateX(-50%) translateY(10px); }
    to { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  @media (max-width: 640px) {
    .share-bar__fallback .share-bar__btn span {
      display: none;
    }

    .share-bar__fallback .share-bar__btn {
      padding: 7px 9px;
    }
  }
</style>
