---
interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  href?: string;
  meta?: string;
}

const { title, description, image, imageAlt = '', href, meta } = Astro.props;
---

{href ? (
  <a href={href} class="card card--link">
    {image && (
      <div class="card__image-wrap">
        <img src={image} alt={imageAlt} class="card__image" loading="lazy" />
      </div>
    )}
    <div class="card__body">
      {meta && <p class="card__meta label">{meta}</p>}
      <h3 class="card__title">{title}</h3>
      {description && <p class="card__desc">{description}</p>}
      <div class="card__accent"></div>
    </div>
  </a>
) : (
  <article class="card">
    {image && (
      <div class="card__image-wrap">
        <img src={image} alt={imageAlt} class="card__image" loading="lazy" />
      </div>
    )}
    <div class="card__body">
      {meta && <p class="card__meta label">{meta}</p>}
      <h3 class="card__title">{title}</h3>
      {description && <p class="card__desc">{description}</p>}
      <div class="card__accent"></div>
    </div>
  </article>
)}

<style>
  .card {
    display: block;
    background-color: var(--color-linen);
    border: 1px solid rgba(90, 90, 110, 0.12);
    border-radius: 3px;
    overflow: hidden;
    transition: box-shadow var(--transition-base), border-color var(--transition-base);
    text-decoration: none;
    color: inherit;
  }

  .card:hover {
    box-shadow: 0 4px 20px rgba(14, 51, 82, 0.08);
  }

  .card--link {
    cursor: pointer;
  }

  .card--link:hover {
    border-color: var(--color-gold);
  }

  .card__image-wrap {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .card:hover .card__image {
    transform: scale(1.03);
  }

  .card__body {
    padding: 24px;
  }

  .card__meta {
    color: var(--color-gray);
    margin-bottom: 8px;
  }

  .card__title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 12px;
    line-height: 1.3;
  }

  .card--link:hover .card__title {
    color: var(--color-gold);
  }

  .card__desc {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-gray);
  }

  .card__accent {
    width: 40px;
    height: 2px;
    background-color: var(--color-gold);
    margin-top: 20px;
  }
</style>
