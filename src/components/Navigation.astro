---
const navItems = [
  { label: 'Magnalia', href: '/magnalia' },
  { label: 'Programs', href: '/programs' },
  { label: 'Events', href: '/events' },
  {
    label: 'About',
    href: '/about',
    dropdown: [
      { label: 'Mission & Vision', href: '/about' },
      { label: 'Our Story', href: '/about/story' },
      { label: 'Leadership', href: '/about/leadership' },
      { label: 'Founding Director', href: '/about/founding-director' },
      { label: 'Impact Report', href: '/about/impact' },
    ],
  },
  { label: 'Library', href: '/library' },
];
---

<header class="nav">
  <div class="nav__inner container">
    <a href="/" class="nav__logo" aria-label="Gregory the Great Institute — Home">
      <img src="/images/branding/ggi-seal.png" alt="GGI Seal" class="nav__logo-img" />
      <div class="nav__brand">
        <span class="nav__wordmark">Gregory the Great Institute</span>
      </div>
    </a>

    <nav class="nav__links" aria-label="Main navigation">
      {navItems.map(item => (
        item.dropdown ? (
          <div class="nav__dropdown-wrap">
            <a href={item.href} class="nav__link nav__link--dropdown">
              {item.label}
              <svg class="nav__chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <div class="nav__dropdown">
              {item.dropdown.map(sub => (
                <a href={sub.href} class="nav__dropdown-link">{sub.label}</a>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.href} class="nav__link">{item.label}</a>
        )
      ))}
    </nav>

    <a href="/support" class="nav__cta">Support</a>

    <button class="nav__hamburger" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="nav__mobile" aria-hidden="true">
    <nav>
      {navItems.map(item => (
        <>
          <a href={item.href} class="nav__mobile-link">{item.label}</a>
          {item.dropdown && item.dropdown.map(sub => (
            <a href={sub.href} class="nav__mobile-link nav__mobile-link--sub">{sub.label}</a>
          ))}
        </>
      ))}
      <a href="/support" class="nav__mobile-link nav__mobile-link--cta">Support the Institute</a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 200;
    background-color: var(--color-navy);
    border-bottom: 1px solid rgba(184, 154, 71, 0.15);
    overflow: visible;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    gap: 20px;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    gap: 16px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav__logo-img {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    border: 3px solid var(--color-navy);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
    margin-top: 4px;
    margin-bottom: -36px;
    position: relative;
    z-index: 201;
    background-color: var(--color-navy);
  }

  .nav__brand {
    display: flex;
    flex-direction: column;
  }

  .nav__wordmark {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-on-dark);
    letter-spacing: 0.03em;
    line-height: 1.3;
  }

  .nav__links {
    display: none;
    align-items: center;
    gap: 28px;
    flex: 1;
    justify-content: center;
  }

  .nav__link {
    font-family: var(--font-ui);
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--color-text-on-dark);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color var(--transition-fast);
    white-space: nowrap;
  }

  .nav__link:hover {
    color: var(--color-gold);
  }

  .nav__link--dropdown {
    display: flex;
    align-items: center;
    gap: 4px;
    cursor: pointer;
  }

  .nav__chevron {
    transition: transform var(--transition-fast);
  }

  /* Dropdown */
  .nav__dropdown-wrap {
    position: relative;
  }

  .nav__dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: -12px;
    padding-top: 12px;
  }

  .nav__dropdown-wrap:hover .nav__dropdown {
    display: block;
  }

  .nav__dropdown-wrap:hover .nav__chevron {
    transform: rotate(180deg);
  }

  .nav__dropdown-link {
    display: block;
    background-color: var(--color-navy);
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 400;
    color: var(--color-text-on-dark);
    text-decoration: none;
    padding: 10px 20px;
    white-space: nowrap;
    border-bottom: 1px solid rgba(245, 239, 229, 0.06);
    transition: color var(--transition-fast), background-color var(--transition-fast);
    min-width: 200px;
  }

  .nav__dropdown-link:first-child {
    border-radius: 3px 3px 0 0;
  }

  .nav__dropdown-link:last-child {
    border-radius: 0 0 3px 3px;
    border-bottom: none;
  }

  .nav__dropdown-link:hover {
    color: var(--color-gold);
    background-color: rgba(184, 154, 71, 0.08);
  }

  /* CTA Button */
  .nav__cta {
    display: none;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-navy);
    background-color: var(--color-gold);
    padding: 10px 32px;
    border-radius: 3px;
    text-decoration: none;
    letter-spacing: 0.02em;
    box-shadow: 0 2px 8px rgba(198, 160, 50, 0.3);
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .nav__cta:hover {
    background-color: #d4ad3a;
    box-shadow: 0 4px 16px rgba(198, 160, 50, 0.45);
    transform: translateY(-1px);
    color: var(--color-navy);
  }

  /* Hamburger */
  .nav__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  .nav__hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--color-text-on-dark);
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  /* Mobile menu */
  .nav__mobile {
    display: none;
    background-color: var(--color-navy);
    padding: 8px 0 24px;
    border-top: 1px solid rgba(184, 154, 71, 0.12);
  }

  .nav__mobile nav {
    display: flex;
    flex-direction: column;
    padding-inline: var(--space-element);
  }

  .nav__mobile-link {
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-on-dark);
    text-decoration: none;
    padding: 12px 0;
    border-bottom: 1px solid rgba(245, 239, 229, 0.06);
    transition: color var(--transition-fast);
  }

  .nav__mobile-link:hover {
    color: var(--color-gold);
  }

  .nav__mobile-link--sub {
    padding-left: 20px;
    font-size: 0.9rem;
    font-weight: 400;
    color: rgba(245, 239, 229, 0.7);
  }

  .nav__mobile-link--cta {
    color: var(--color-gold);
    font-weight: 600;
    border-bottom: none;
    margin-top: 12px;
    padding-top: 16px;
    border-top: 1px solid rgba(184, 154, 71, 0.2);
  }

  /* Desktop */
  @media (min-width: 1024px) {
    .nav__links { display: flex; }
    .nav__cta { display: inline-block; }
    .nav__hamburger { display: none; }
  }

  @media (max-width: 1023px) and (min-width: 640px) {
    .nav__wordmark { font-size: 1rem; }
  }

  @media (max-width: 639px) {
    .nav__wordmark { display: none; }
  }
</style>

<script>
  const hamburger = document.querySelector('.nav__hamburger');
  const mobileMenu = document.querySelector('.nav__mobile');

  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.style.display === 'block';
    if (mobileMenu) mobileMenu.style.display = isOpen ? 'none' : 'block';
    hamburger.setAttribute('aria-expanded', String(!isOpen));
    if (mobileMenu) mobileMenu.setAttribute('aria-hidden', String(isOpen));
  });
</script>
