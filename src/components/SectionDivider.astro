---
interface Props {
  thick?: boolean;
  contained?: boolean;
  /** 'tracery' (default) uses gothic pattern; 'rule' uses plain gold line */
  variant?: 'tracery' | 'rule';
}

const { thick = false, contained = true, variant = 'tracery' } = Astro.props;
---

{variant === 'rule' ? (
  contained ? (
    <div class="container">
      <hr class:list={['gold-rule', thick && 'gold-rule--thick']} />
    </div>
  ) : (
    <hr class:list={['gold-rule', thick && 'gold-rule--thick']} />
  )
) : (
  <div class={contained ? 'container' : undefined}>
    <div class="tracery-divider" role="separator" aria-hidden="true">
      <svg class="tracery-divider__svg" viewBox="0 0 600 40" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
        {/* Repeating pointed arch band with trefoil cusps */}
        <defs>
          <pattern id="tracery-arch" x="0" y="0" width="60" height="40" patternUnits="userSpaceOnUse">
            {/* Main pointed arch */}
            <path d="M0 38 Q15 2, 30 2 Q45 2, 60 38" fill="none" stroke="currentColor" stroke-width="0.8" />
            {/* Inner trefoil: three small lobes */}
            <circle cx="30" cy="16" r="5" fill="none" stroke="currentColor" stroke-width="0.5" />
            <circle cx="22" cy="24" r="4.5" fill="none" stroke="currentColor" stroke-width="0.5" />
            <circle cx="38" cy="24" r="4.5" fill="none" stroke="currentColor" stroke-width="0.5" />
          </pattern>
        </defs>
        <rect width="600" height="40" fill="url(#tracery-arch)" />
        {/* Fade edges */}
        <defs>
          <linearGradient id="tracery-fade" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="white" stop-opacity="1" />
            <stop offset="15%" stop-color="white" stop-opacity="0" />
            <stop offset="85%" stop-color="white" stop-opacity="0" />
            <stop offset="100%" stop-color="white" stop-opacity="1" />
          </linearGradient>
          <mask id="tracery-mask">
            <rect width="600" height="40" fill="white" />
            <rect width="600" height="40" fill="url(#tracery-fade)" />
          </mask>
        </defs>
      </svg>
    </div>
  </div>
)}

<style>
  .tracery-divider {
    display: flex;
    justify-content: center;
    padding-block: 4px;
  }

  .tracery-divider__svg {
    width: 100%;
    max-width: 480px;
    height: 32px;
    color: var(--color-gold);
    opacity: 0.35;
  }
</style>
