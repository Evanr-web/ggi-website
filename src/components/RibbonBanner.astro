---
import { getSiteSettings } from '../lib/sanity';

// Try Sanity first, fall back to hardcoded defaults
let enabled = true;
let message = "We're hiring! Communications & Development Intern — Canada Summer Jobs 2026.";
let linkText = "Apply Now →";
let linkUrl = "/careers/";
let style = "laurel";
let bannerId = "hiring-intern-2026";

try {
  const settings = await getSiteSettings();
  if (settings?.ribbonBanner) {
    const rb = settings.ribbonBanner;
    enabled = rb.enabled ?? false;
    message = rb.message ?? message;
    linkText = rb.linkText ?? linkText;
    linkUrl = rb.linkUrl ?? linkUrl;
    style = rb.style ?? style;
    bannerId = `ribbon-${message.slice(0, 20).replace(/\W/g, '-').toLowerCase()}`;
  }
} catch (e) {
  // Sanity unavailable — use hardcoded defaults
}
---

{enabled && (
  <div class={`ribbon ribbon--${style}`} id="ribbon-banner" data-banner-id={bannerId} role="banner" style="display:none;">
    <div class="ribbon__inner">
      <span class="ribbon__message">{message}</span>
      {linkText && linkUrl && (
        <a href={linkUrl} class="ribbon__link" data-ribbon-cta>{linkText}</a>
      )}
      <button class="ribbon__close" aria-label="Dismiss banner">×</button>
    </div>
  </div>
)}

<style>
  .ribbon {
    width: 100%;
    padding: 8px 16px;
    text-align: center;
    font-family: var(--font-ui);
    font-size: 0.82rem;
    line-height: 1.4;
    position: relative;
    z-index: 1001;
  }

  .ribbon--gold {
    background-color: var(--color-gold);
    color: var(--color-navy);
  }

  .ribbon--navy {
    background-color: var(--color-navy);
    color: var(--color-parchment);
  }

  .ribbon--crimson {
    background-color: var(--color-crimson);
    color: var(--color-parchment);
  }

  .ribbon--laurel {
    background-color: #2d6a4f;
    color: #f5efe5;
  }

  .ribbon__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    max-width: 1200px;
    margin-inline: auto;
  }

  .ribbon__message {
    font-weight: 500;
  }

  .ribbon__link {
    font-weight: 700;
    color: var(--color-gold);
    text-decoration: underline;
    text-underline-offset: 2px;
    white-space: nowrap;
  }

  .ribbon--gold .ribbon__link { color: var(--color-crimson); }
  .ribbon--laurel .ribbon__link { color: var(--color-gold); }

  .ribbon__close {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: inherit;
    font-size: 1.2rem;
    cursor: pointer;
    opacity: 0.6;
    padding: 4px 8px;
    line-height: 1;
  }

  .ribbon__close:hover { opacity: 1; }

  @media (max-width: 640px) {
    .ribbon { font-size: 0.75rem; padding: 8px 36px 8px 12px; }
    .ribbon__inner { gap: 6px; flex-wrap: wrap; justify-content: center; text-align: center; }
  }
</style>

<script>
  const ribbon = document.getElementById('ribbon-banner');
  if (ribbon) {
    const id = ribbon.dataset.bannerId;
    const key = `ribbon-dismissed-${id}`;

    if (localStorage.getItem(key)) {
      ribbon.remove();
    } else {
      ribbon.style.display = '';

      ribbon.querySelector('.ribbon__close')?.addEventListener('click', () => {
        localStorage.setItem(key, '1');
        ribbon.remove();
      });

      ribbon.querySelector('[data-ribbon-cta]')?.addEventListener('click', () => {
        localStorage.setItem(key, '1');
      });
    }
  }
</script>
