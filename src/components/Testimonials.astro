---
/**
 * Testimonials section — renders quotes from participants/supporters.
 * Pass an array of { quote, attribution } objects.
 * If the array is empty or undefined, renders nothing.
 */
interface Props {
  testimonials?: Array<{ quote: string; attribution?: string }>;
  heading?: string;
}

const { testimonials, heading = 'What People Are Saying' } = Astro.props;
const items = testimonials?.filter(t => t.quote) || [];
---

{items.length > 0 && (
  <section class="testimonials">
    <div class="container">
      <p class="label testimonials__label">Testimonials</p>
      <h2 class="testimonials__heading">{heading}</h2>
      <div class="testimonials__list">
        {items.map((t, i) => (
          <blockquote class="testimonials__item">
            <p class="testimonials__quote">&ldquo;{t.quote}&rdquo;</p>
            {t.attribution && (
              <footer class="testimonials__attribution">{t.attribution}</footer>
            )}
            {i < items.length - 1 && <div class="testimonials__divider"><span class="tagline-cross">✠</span></div>}
          </blockquote>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .testimonials {
    background-color: var(--color-navy, #0e3352);
    padding: 64px 0;
  }

  .testimonials__label {
    text-align: center;
    color: var(--color-gold, #b89a47);
  }

  .testimonials__heading {
    text-align: center;
    color: var(--color-text-on-dark, #f5efe5);
    margin-bottom: 48px;
  }

  .testimonials__list {
    max-width: 680px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .testimonials__item {
    margin: 0;
    padding: 0;
    text-align: center;
  }

  .testimonials__quote {
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--color-text-on-dark, #f5efe5);
    font-style: italic;
    margin: 0 0 12px;
  }

  .testimonials__attribution {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-gold, #b89a47);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .testimonials__divider {
    text-align: center;
    padding: 32px 0;
    color: var(--color-gold, #b89a47);
    opacity: 0.4;
    font-size: 0.9rem;
  }
</style>
